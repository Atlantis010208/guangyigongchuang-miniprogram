.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50px;
  background: #ffffff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 0.5px solid rgba(0, 0, 0, 0.1);
  z-index: 999;
}

.tab-bar-border {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 0;
  border-top: 0;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4px 0 2px;
}

.tab-bar-icon {
  width: 26px;
  height: 26px;
}

.tab-bar-text {
  font-size: 10px;
  font-weight: 500;
  margin-top: 2px;
  line-height: 1;
}

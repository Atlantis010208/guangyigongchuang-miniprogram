<view class="detail-page">
  <block wx:if="{{images && images.length}}">
    <swiper class="banner" indicator-dots autoplay circular style="height: {{bannerHeight}}rpx" current="{{current}}" bindchange="onSwiperChange">
      <block wx:for="{{images}}" wx:key="*this">
        <swiper-item>
          <image class="banner-image" src="{{item}}" mode="aspectFit" bindtap="onPreviewImage" data-src="{{item}}" bindload="onBannerLoad" data-idx="{{index}}"></image>
        </swiper-item>
      </block>
    </swiper>
  </block>
  <block wx:else>
    <view class="banner" style="height: {{bannerHeight}}rpx"></view>
  </block>

  <view class="info">
    <text class="name">{{name}}</text>
    <text class="price">¥{{price}}</text>
  </view>

  <!-- 规格选择 -->
  <view class="card">
    <text class="section-title">选择版本</text>
    <view wx:for="{{variantGroups}}" wx:key="name" class="variant-group">
      <text class="variant-name">{{item.name}}</text>
      <view class="variant-options">
        <view wx:for="{{item.options}}" wx:key="*this" wx:for-item="opt" class="variant-chip {{item.selected===opt ? 'selected' : ''}}" data-group="{{item.key}}" data-value="{{opt}}" bindtap="onSelectVariant">{{opt}}</view>
      </view>
    </view>
    <view class="quantity">
      <text class="q-label">数量</text>
      <view class="stepper">
        <view class="step-btn" bindtap="onDec">-</view>
        <text class="step-val">{{quantity}}</text>
        <view class="step-btn" bindtap="onInc">+</view>
      </view>
    </view>
    <view class="total-line"><text class="total-label">合计</text><text class="total-val">¥{{totalPrice || (price * quantity)}}</text></view>
  </view>

  <!-- 商品简介 -->
  <view class="card">
    <text class="section-title">产品介绍</text>
    <text class="desc">{{desc}}</text>
  </view>

  <!-- 商品详情图 -->
  <view class="card detail-images">
    <text class="section-title">商品详情</text>
    <view class="detail-image-list">
      <block wx:if="{{detailImages && detailImages.length}}">
        <image 
          wx:for="{{detailImages}}" 
          wx:key="index" 
          class="detail-image" 
          src="{{item}}" 
          mode="widthFix"
          lazy-load
          bindtap="onPreviewDetailImage"
          data-src="{{item}}"
        />
      </block>
      <block wx:else>
        <view class="empty-detail">
          <text class="empty-text">暂无详情图片</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 规格参数 -->
  <view class="card">
    <text class="section-title">产品参数</text>
    <view class="params">
      <view wx:for="{{params}}" wx:key="key" class="param-row">
        <text class="param-line">{{item.key}}：{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>
</view>

<!-- Vant Weapp 商品导航组件 - 必须放在页面容器外部 -->
<van-goods-action safe-area-inset-bottom>
  <!-- 左侧图标按钮：客服 - 使用 dot 属性显示小红点 -->
  <van-goods-action-icon
    icon="chat-o"
    text="客服"
    dot
    bind:click="onContact"
  />
  <!-- 购物车 - 使用 info 属性显示数量徽标 -->
  <van-goods-action-icon
    icon="cart-o"
    text="购物车"
    info="{{cartCount}}"
    bind:click="onGoCart"
  />
  <!-- 收藏按钮 -->
  <van-goods-action-icon
    icon="{{favIcon}}"
    text="收藏"
    bind:click="onToggleFav"
  />
  <!-- 朴素按钮：加入购物车 - 使用 plain 属性，蓝色渐变 -->
  <van-goods-action-button
    text="加入购物车"
    type="warning"
    plain
    color=" #36cfc9"
    bind:click="onAddToCart"
  />
  <!-- 主按钮：立即购买 - 使用蓝色渐变 -->
  <van-goods-action-button
    text="立即购买"
    type="danger"
    color="linear-gradient(to right, #36cfc9, #1890ff)"
    bind:click="onBuyNow"
  />
</van-goods-action>

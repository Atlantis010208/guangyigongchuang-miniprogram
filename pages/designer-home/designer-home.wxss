/* CSS Variables representing Tailwind classes */
page {
  --primary: #007AFF;
  --background-light: #F5F5F7;
  --surface-light: #FFFFFF;
  --text-primary-light: #1D1D1F;
  --text-secondary-light: #86868B;
  
  background-color: var(--background-light);
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: var(--text-primary-light);
  -webkit-font-smoothing: antialiased;
}

.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.main-content {
  padding: 0 20px 96px 20px; /* px-5 pb-24 */
  max-width: 448px; /* max-w-md */
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

/* Header */
.header {
  margin-top: 8px; /* mt-2 */
  margin-bottom: 24px; /* mb-6 */
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.h1 {
  font-size: 30px; /* text-3xl */
  font-weight: 700; /* font-bold */
  line-height: 36px;
  letter-spacing: -0.025em; /* tracking-tight */
  color: var(--text-primary-light);
}

.p {
  color: var(--text-secondary-light);
  margin-top: 4px; /* mt-1 */
  font-weight: 500; /* font-medium */
  font-size: 16px;
}

.avatar-container {
  height: 40px; /* h-10 */
  width: 40px; /* w-10 */
  border-radius: 9999px; /* rounded-full */
  overflow: hidden;
  background-color: #E5E7EB; /* bg-gray-200 */
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* shadow-sm */
}

.avatar {
  height: 100%;
  width: 100%;
  object-fit: cover;
}

/* Category Scroll */
.category-scroll {
  margin-bottom: 32px; /* mb-8 */
  margin-left: -20px; /* -mx-5 */
  width: calc(100% + 40px);
  padding: 8px 20px; /* px-5 py-2 */
  box-sizing: border-box;
}

.category-list {
  display: flex;
  column-gap: 12px; /* space-x-3 */
}

.category-btn {
  background-color: var(--surface-light);
  color: var(--text-primary-light);
  border: 1px solid #F3F4F6; /* border-gray-100 */
  padding: 10px 20px; /* px-5 py-2.5 */
  border-radius: 9999px; /* rounded-full */
  font-size: 14px; /* text-sm */
  font-weight: 500; /* font-medium */
  white-space: nowrap;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* shadow-sm */
  transition: all 0.2s;
}

.category-btn.active {
  background-color: var(--text-primary-light);
  color: #FFFFFF;
  font-weight: 600; /* font-semibold */
  border-color: transparent;
}

/* Section Header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16px; /* mb-4 */
  padding: 0 4px; /* px-1 */
}

.h2 {
  font-size: 20px; /* text-xl */
  font-weight: 700; /* font-bold */
  color: var(--text-primary-light);
}

.filter-group {
  display: flex;
  align-items: center;
  column-gap: 4px; /* space-x-1 */
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32px; /* h-8 */
  width: 32px; /* w-8 */
  border-radius: 9999px; /* rounded-full */
  background-color: transparent;
  color: var(--text-secondary-light);
  transition: background-color 0.2s;
  margin-right: 4px; /* mr-1 */
}

.filter-btn:active {
  background-color: #F3F4F6; /* hover:bg-gray-100 */
}

.view-all-btn {
  color: var(--primary);
  font-size: 14px; /* text-sm */
  font-weight: 500; /* font-medium */
  display: flex;
  align-items: center;
  transition: opacity 0.2s;
}

.view-all-btn:active {
  opacity: 0.8;
}

.arrow-icon {
  margin-left: 2px; /* ml-0.5 */
}

/* Demand List */
.demand-list {
  display: flex;
  flex-direction: column;
  row-gap: 24px; /* space-y-6 */
}

.card {
  background-color: var(--surface-light);
  border-radius: 20px; /* rounded-2xl */
  padding: 20px; /* p-5 */
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04); /* shadow-apple */
  border: 1px solid transparent;
  transition: all 0.2s;
}

.card:active {
  transform: scale(0.99);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px; /* mb-4 */
}

.tag-blue, .tag-purple, .tag-gray {
  display: inline-block;
  padding: 4px 10px; /* px-2.5 py-1 */
  border-radius: 6px; /* rounded-md */
  font-size: 12px; /* text-xs */
  font-weight: 600; /* font-semibold */
  margin-bottom: 8px; /* mb-2 */
  text-transform: uppercase;
  letter-spacing: 0.025em; /* tracking-wide */
}

.tag-blue {
  background-color: #EFF6FF; /* bg-blue-50 */
  color: #2563EB; /* text-blue-600 */
}

.tag-purple {
  background-color: #FAF5FF; /* bg-purple-50 */
  color: #9333EA; /* text-purple-600 */
}

.tag-gray {
  background-color: #F9FAFB; /* bg-gray-50 */
  color: #4B5563; /* text-gray-600 */
}

.card-title {
  font-size: 20px; /* text-xl */
  font-weight: 700; /* font-bold */
  line-height: 1.25; /* leading-tight */
  color: var(--text-primary-light);
}

.card-subtitle {
  color: var(--text-secondary-light);
  font-size: 14px; /* text-sm */
  margin-top: 4px; /* mt-1 */
}

.card-icon {
  height: 40px; /* h-10 */
  width: 40px; /* w-10 */
  border-radius: 9999px; /* rounded-full */
  background-color: #F3F4F6; /* bg-gray-100 */
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px; /* gap-2 */
  margin-bottom: 24px; /* mb-6 */
}

.stat-box {
  background-color: #F9FAFB; /* bg-gray-50 */
  border-radius: 16px; /* rounded-xl */
  padding: 12px; /* p-3 */
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 12px; /* text-xs */
  color: var(--text-secondary-light);
  margin-bottom: 4px; /* mb-1 */
}

.stat-value {
  display: block;
  font-weight: 700; /* font-bold */
  color: var(--text-primary-light);
  font-size: 14px; /* text-sm */
}

/* Action Buttons */
.action-group {
  display: flex;
  column-gap: 12px; /* space-x-3 */
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 14px 0; /* py-3.5 */
  border-radius: 16px; /* rounded-xl */
  font-size: 14px; /* text-sm */
  font-weight: 600; /* font-semibold */
  line-height: 1;
  text-align: center;
  border: none;
  transition: background-color 0.2s;
}

.btn-secondary::after, .btn-primary::after {
  display: none;
}

.btn-secondary {
  color: var(--text-primary-light);
  background-color: #F3F4F6; /* bg-gray-100 */
}

.btn-secondary-hover {
  background-color: #E5E7EB; /* hover:bg-gray-200 */
}

.btn-primary {
  color: #FFFFFF;
  background-color: #000000; /* bg-black */
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); /* shadow-lg */
}

.btn-primary-hover {
  background-color: #111827; /* hover:bg-gray-900 */
}

/* 新需求提示条 */
.new-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  background-color: #EFF6FF;
  border: 1px solid #BFDBFE;
  border-radius: 12px;
  padding: 10px 16px;
  margin-top: 12px;
  animation: tipSlideIn 0.3s ease-out;
}

.new-tip-text {
  font-size: 14px;
  font-weight: 500;
  color: #2563EB;
}

@keyframes tipSlideIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

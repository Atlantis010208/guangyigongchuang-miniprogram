<view class="page-container">
  
  <view class="main-content">
    <view class="header">
      <view class="header-text">
        <text class="h1">发现</text>
        <text class="p">灯光设计项目</text>
      </view>
      <view class="avatar-container" bindtap="goToProfile">
        <image class="avatar" src="{{userAvatarDisplay || user.avatar || '/images/个人中心.png'}}" mode="aspectFill" binderror="onAvatarError"></image>
      </view>
    </view>

    <scroll-view class="category-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}" enhanced="{{true}}" bounces="{{true}}">
      <view class="category-list">
        <view class="category-btn {{currentCategory === index ? 'active' : ''}}" 
              wx:for="{{categories}}" 
              wx:key="index"
              data-index="{{index}}"
              bindtap="switchCategory">
          {{item}}
        </view>
      </view>
    </scroll-view>

    <!-- 新需求提示条 -->
    <view class="new-tip" wx:if="{{showNewTip}}" bindtap="onTapNewTip">
      <van-icon name="bell" size="14px" color="#2563EB" />
      <text class="new-tip-text">有 {{newCount}} 条新需求，点击刷新</text>
    </view>

    <!-- 邀请提示卡 -->
    <view class="invite-banner" wx:if="{{pendingInviteCount > 0}}" bindtap="goToInvites">
      <view class="invite-banner-left">
        <image class="invite-banner-icon" src="/images/消息.png" mode="aspectFit"></image>
        <view class="invite-banner-text">
          <text class="invite-banner-title">您有 {{pendingInviteCount}} 条新邀请</text>
          <text class="invite-banner-sub">业主邀请您承接设计项目</text>
        </view>
      </view>
      <view class="invite-banner-action">
        <text class="invite-banner-btn">立即查看</text>
        <van-icon name="arrow" size="12px" color="#2563EB" />
      </view>
    </view>

    <view class="section-header">
      <text class="h2">可用需求</text>
      <view class="filter-group">
        <view class="filter-btn" bindtap="goToFilter">
          <van-icon name="filter-o" size="20px" color="#86868B" />
        </view>
        <view class="view-all-btn" bindtap="viewAllDemands">
          <text>查看全部</text>
          <van-icon name="arrow" size="14px" custom-class="arrow-icon" />
        </view>
      </view>
    </view>

    <view class="demand-list">
      <block wx:for="{{demands}}" wx:key="_id">
        <view class="card">
          <view class="card-header">
            <view>
              <view class="tag-{{item.tagType}}" wx:if="{{item.tagText}}">{{item.tagText}}</view>
              <view class="card-title">{{item.title}}</view>
              <view class="card-subtitle">{{item.service}}</view>
              <view class="card-owner" wx:if="{{item.ownerName}}">业主：{{item.ownerName}}</view>
            </view>
            <view class="card-icon">
              <!-- 动态根据空间类型展示图标 -->
              <van-icon name="{{item.space === '住宅' ? 'wap-home-o' : (item.space === '商铺' ? 'shop-o' : 'hotel-o')}}" size="20px" color="#6B7280" />
            </view>
          </view>

          <view class="stats-grid">
            <view class="stat-box">
              <text class="stat-label">预算</text>
              <text class="stat-value">{{item.budget}}</text>
            </view>
            <view class="stat-box">
              <text class="stat-label">面积</text>
              <text class="stat-value">{{item.area}}m²</text>
            </view>
            <view class="stat-box">
              <text class="stat-label">进度</text>
              <text class="stat-value">{{item.stage}}</text>
            </view>
          </view>

          <view class="action-group">
            <button class="btn-secondary" hover-class="btn-secondary-hover" bindtap="onViewDemand" data-id="{{item._id}}">查看详情</button>
            <button class="btn-primary" hover-class="btn-primary-hover" bindtap="acceptOrder" data-id="{{item._id}}" data-title="{{item.title}}">立即接单</button>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 筛选弹窗组件 -->
  <designer-filter-popup 
    show="{{showFilter}}" 
    bind:close="onCloseFilter" 
    bind:confirm="onConfirmFilter"
  />
</view>

.container {
  min-height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx; /* 顶部留白 */
}

.content {
  width: 100%;
  padding: 0 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 40rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.2;
}

.desc {
  font-size: 30rpx;
  color: #86868b; /* Apple 风格的灰色 */
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  max-width: 600rpx;
}

.action-btn {
  background-color: #0071e3; /* Apple 蓝色 */
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 999rpx; /* 圆角胶囊 */
  padding: 24rpx 0;
  width: 320rpx !important; /* 强制覆盖可能的小程序默认样式 */
  text-align: center;
  line-height: 1.4;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.copied {
  background-color: #86868b; /* 灰色 */
  color: #fff;
}
<view class="page">
  <!-- 主内容区：只展示当前步骤 -->
  <view class="main-content">
    <block wx:for="{{steps}}" wx:key="id" wx:for-item="step" wx:for-index="index">
      <view class="step-container {{currentStep === index ? 'active' : ''}}" wx:if="{{currentStep === index}}">
        <!-- 标题区域 -->
        <view class="step-header">
          <view class="step-title">{{step.title}}</view>
          <view class="step-subtitle" wx:if="{{step.subtitle}}">{{step.subtitle}}</view>
        </view>

        <!-- 选项列表 (Choice) -->
        <view class="options-list" wx:if="{{step.type === 'choice'}}">
          <block wx:for="{{step.options}}" wx:key="*this" wx:for-item="option">
            <view class="option-card {{(step.id === 'space' && space === option) || (step.id === 'service' && service === option) || (step.id === 'budget' && budget === option) || (step.id === 'stage' && stage === option) || (step.id === 'share' && share === option) || (step.id === 'coCreate' && coCreate === option) ? 'selected' : ''}}" 
                  bindtap="handleOptionSelect" 
                  data-id="{{step.id}}" 
                  data-option="{{option}}">
              <text class="option-text">{{option}}</text>
              
              <!-- "其他" 选项展开输入框 -->
              <view class="other-input-container {{(step.id === 'space' && space === '其他' && option === '其他') || (step.id === 'budget' && budget === '其他' && option === '其他') ? 'show' : ''}}" catchtap="true">
                <input class="other-input" 
                       placeholder="请输入详细信息..." 
                       placeholder-class="other-input-placeholder"
                       value="{{step.id === 'space' ? spaceOther : budgetOther}}" 
                       bindinput="handleOtherInput" 
                       bindconfirm="handleOtherConfirm"
                       bindblur="handleOtherConfirm"
                       bindkeyboardheightchange="onKeyboardHeightChange"
                       adjust-position="{{false}}"
                       data-id="{{step.id}}" />
              </view>
            </view>
          </block>
        </view>

        <!-- 数字输入框 (Input) -->
        <view class="input-container" wx:if="{{step.type === 'input'}}">
          <text class="input-label">{{step.inputLabel}}</text>
          <input class="huge-input" 
                 type="number" 
                 placeholder="{{step.inputPlaceholder}}" 
                 placeholder-class="huge-input-placeholder"
                 value="{{area}}" 
                 bindinput="handleNumberInput" 
                 bindconfirm="handleNumberConfirm"
                 bindblur="handleNumberConfirm"
                 bindkeyboardheightchange="onKeyboardHeightChange"
                 adjust-position="{{false}}"
                 data-id="{{step.id}}" />
        </view>
      </view>
    </block>
  </view>

  <!-- 底部悬浮操作栏 -->
  <view class="footer-bar" style="bottom: {{keyboardHeight}}px; transition: bottom 0.3s ease;">
    <view class="footer-content">
      <button class="btn-prev" wx:if="{{currentStep > 0}}" bindtap="handlePrev">上一步</button>
      <button class="btn-next {{!isNextValid ? 'disabled' : ''}}" bindtap="{{currentStep === steps.length - 1 ? 'onSubmit' : 'handleNext'}}" disabled="{{!isNextValid}}">
        {{currentStep === steps.length - 1 ? '提交需求' : '下一步'}}
      </button>
    </view>
  </view>
</view>

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", Arial, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

/* 主内容区 */
.main-content {
  flex: 1;
  padding: 24rpx 48rpx 200rpx;
  overflow-y: auto;
  position: relative;
}

/* 隐藏滚动条 */
.main-content::-webkit-scrollbar {
  display: none;
}

.step-container {
  display: none;
  width: 100%;
  animation: slideIn 0.7s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

.step-container.active {
  display: block;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-60rpx);
    filter: blur(8rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
    filter: blur(0);
  }
}

/* 标题区域 */
.step-header {
  margin-top: 32rpx;
  margin-bottom: 48rpx;
}

.step-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #000;
  line-height: 1.3;
  letter-spacing: -1rpx;
  margin-bottom: 20rpx;
}

.step-subtitle {
  font-size: 30rpx;
  color: #888;
  line-height: 1.6;
  font-weight: 300;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 36rpx 40rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: none;
  position: relative;
  overflow: hidden;
}

.option-card:active {
  transform: scale(0.98);
}

.option-card.selected {
  background-color: #000;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.15);
}

.option-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #000;
  transition: color 0.3s ease;
  letter-spacing: 0;
}

.option-card.selected .option-text {
  color: #fff;
}

/* 其他输入框 */
.other-input-container {
  height: 0;
  opacity: 0;
  margin-top: 0;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.other-input-container.show {
  height: 80rpx;
  opacity: 1;
  margin-top: 24rpx;
}

.other-input {
  width: 100%;
  height: 100%;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
  font-size: 30rpx;
  color: #fff;
  font-weight: 300;
}

.other-input-placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* 面积输入框 */
.input-container {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.04);
}

.input-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #a0a5ab;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.huge-input {
  width: 100%;
  height: 120rpx;
  font-size: 80rpx;
  font-weight: 700;
  color: #000;
  letter-spacing: -2rpx;
}

.huge-input-placeholder {
  color: #e5e5e5;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #f5f5f5 70%, rgba(245, 245, 245, 0));
  z-index: 50;
  pointer-events: none;
}

.footer-content {
  display: flex;
  gap: 24rpx;
  pointer-events: auto;
}

.btn-prev {
  width: 200rpx;
  flex-shrink: 0;
  height: 104rpx;
  border-radius: 52rpx;
  background-color: #fff;
  color: #000;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  transition: all 0.3s ease;
}

.btn-prev:active {
  transform: scale(0.98);
  background-color: #f0f0f0;
}

.btn-prev::after {
  border: none;
}

.btn-next {
  flex: 1;
  height: 104rpx;
  border-radius: 52rpx;
  background-color: #000;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.btn-next.disabled {
  background-color: #c4c4c4;
  color: #fff;
  opacity: 1;
  box-shadow: none;
}

.btn-next:not(.disabled):active {
  transform: scale(0.98);
}

.btn-next::after {
  border: none;
}


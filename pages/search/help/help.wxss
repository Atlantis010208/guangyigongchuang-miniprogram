/* 页面整体容器 */
.container {
  min-height: 100vh;
  background-color: #F5F7FA; /* 浅灰背景 */
  padding: 30rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
  color: #333333;
}

/* 卡片容器 */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx; /* 大圆角 */
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04); /* 轻微阴影 */
  overflow: hidden;
}

/* 子卡片容器（用于详细说明页的子项） */
.sub-card {
  background-color: #FFFFFF;
  border: 1px solid #F0F0F0; /* 细边框 */
  border-radius: 16rpx; /* 稍小的圆角 */
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.sub-card:last-child {
  margin-bottom: 0;
}

/* 子卡片标题 */
.sub-card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* 分割线（卡片内标题下方 - 苹果蓝） */
.card-divider-green {
  height: 1px;
  background-color: #007AFF; /* 苹果蓝分割线 */
  margin: 24rpx 0 32rpx;
  width: 100%;
}

/* 顶部大标题 */
.page-header {
  padding-bottom: 10rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
}

/* 章节标题 */
.section-header {
  margin-bottom: 10rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333; /* 默认黑色 */
  display: flex;
  align-items: center;
}

/* 序号样式 (一、二、三、) - 保持黑色 */
.section-title-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 10rpx;
}

/* 标题文本样式 - 苹果蓝 */
.section-title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #007AFF; /* Apple Blue */
  transition: opacity 0.2s;
}

/* 蓝色标题点击效果 */
.section-title-text:active {
  opacity: 0.6;
}

/* 箭头图标 */
.section-arrow {
  width: 16rpx;
  height: 16rpx;
  margin-left: auto;
  border-top: 4rpx solid #C0C4CC;
  border-right: 4rpx solid #C0C4CC;
  transform: rotate(45deg);
  flex-shrink: 0;
}

/* 通用文本段落 */
.text-paragraph {
  font-size: 30rpx;
  line-height: 1.8;
  color: #555555; /* 深灰字体 */
  margin-bottom: 24rpx;
  text-align: justify;
}

.text-paragraph:last-child {
  margin-bottom: 0;
}

.extra-margin {
  margin-top: 30rpx;
}

/* 粗体文本 */
.bold {
  font-weight: bold;
  color: #333333;
}

/* 灰色小字 */
.text-gray {
  color: #999999;
  font-size: 26rpx;
  margin-top: 8rpx;
  display: block;
}

/* 子章节（简介/说明） */
.sub-section {
  margin-bottom: 32rpx;
}

.subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.text-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.text-block text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #555555;
}

/* 高亮框（黄色小手提示） */
.highlight-box {
  background-color: #FFF9E6; /* 浅黄色背景 */
  padding: 24rpx;
  border-radius: 12rpx;
  margin-top: 24rpx;
}

.highlight-box text {
  font-size: 28rpx;
  color: #856404; /* 深黄色文字 */
  line-height: 1.6;
}

/* 列表容器 */
.list-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 有序列表项 */
.list-item-ordered {
  display: flex;
  align-items: flex-start;
}

.order-num {
  font-size: 30rpx;
  font-weight: bold;
  color: #0052D9;
  margin-right: 16rpx;
  min-width: 40rpx; /* 保持对齐 */
}

.list-item-ordered text:last-child {
  font-size: 30rpx;
  line-height: 1.6;
  color: #555555;
}

/* 无序列表项 */
.list-item-bullet {
  display: flex;
  align-items: flex-start;
}

.bullet-point {
  font-size: 20rpx; /* 小一点的圆点 */
  color: #0052D9;
  margin-right: 20rpx;
  margin-top: 14rpx; /* 对齐文本 */
}

.list-item-bullet text:last-child {
  font-size: 30rpx;
  line-height: 1.6;
  color: #555555;
}

/* 用户反馈列表项 */
.feedback-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.feedback-left {
  display: flex;
  align-items: center;
}

.feedback-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  /* 如果没有图片，可以用颜色块代替调试 */
  /* background-color: #07C160; */
}

.feedback-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.feedback-arrow {
  color: #CCCCCC;
  font-size: 32rpx;
}

/* 底部页脚 */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
  margin-top: 0;
  border-top: none; /* 移除之前的分割线 */
}

.footer text {
  font-size: 24rpx;
  color: #999999;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #007AFF 0%, #0062cc 100%); /* 渐变背景 */
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.35), 0 2rpx 8rpx rgba(0, 0, 0, 0.05); /* 高级感阴影 */
  z-index: 100;
  
  /* 初始隐藏状态：透明、下沉 */
  opacity: 0;
  visibility: hidden;
  transform: translateY(20rpx);
  transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
}

/* 显示状态 */
.fab.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.fab:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

.fab-icon-img {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 6rpx;
}

.fab-text {
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 1;
}

/* 全局分割线（卡片之间 - 灰色） */
.divider {
  height: 1px;
  background-color: #EEEEEE;
  margin: 40rpx 0;
  width: 100%;
}
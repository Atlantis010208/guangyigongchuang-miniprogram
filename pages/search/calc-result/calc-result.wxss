/* 计算结果页面样式 */

page {
  background-color: #F5F7FA;
  height: 100vh;
}

.result-page {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: #F5F7FA;
  display: flex;
  flex-direction: column;
}

/* 滚动区域 */
.result-scroll {
  flex: 1;
  padding: 24rpx 30rpx 180rpx;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

/* 核心结果大卡片 */
.main-card {
  text-align: center;
  padding-top: 30rpx;
}

.card-header {
  text-align: left;
  margin-bottom: 40rpx;
}

.card-title {
  font-size: 33rpx;
  color: #000;
  font-weight: 500;
  display: block;
  margin-bottom: 30rpx;
}

.card-header-line {
  height: 1rpx;
  background: #F0F0F0;
  margin: 0 10rpx;
}

.main-val-area {
  margin-bottom: 40rpx;
}

.val-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.val-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.big-num {
  font-size: 80rpx;
  font-weight: bold;
  color: #2979FF;
  line-height: 1;
}

.big-unit {
  font-size: 32rpx;
  color: #999;
  margin-left: 10rpx;
}

.sub-val-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sub-num {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.sub-num.gold { 
  color: #FBC02D; 
}

.sub-num.blue { 
  color: #43A047; 
}

.sub-num.green { 
  color: #E53935; 
}

/* 三列布局时的样式调整 */
.sub-val-row.three-cols {
  justify-content: space-between;
  padding: 0 20rpx;
}

.sub-label {
  font-size: 24rpx;
  color: #999;
}

.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 0 -30rpx 30rpx;
}

/* 详情列表 (内嵌卡片风格) */
.detail-card-inner {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.detail-list {
  display: flex;
  flex-direction: column;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  position: relative;
}

/* 自定义分割线 (伪元素实现) */
.detail-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  height: 1rpx;
  background: #F5F5F5;
}

.detail-item:last-child::after {
  display: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-val {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  padding: 20rpx 32rpx 60rpx;
  box-shadow: 0 -1rpx 0 rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 24rpx;
  z-index: 100;
}

.btn-white {
  flex: 1;
  height: 96rpx;
  background: #F2F2F7;
  border: none;
  border-radius: 48rpx;
  color: #000;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-white::after { 
  border: none; 
}

.btn-white:active {
  background: #E5E5EA;
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-green {
  flex: 1.5;
  height: 96rpx;
  background: #007AFF;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 122, 255, 0.25);
  transition: all 0.2s;
}

.btn-green::after { 
  border: none; 
}

.btn-green:active {
  background: #0062CC;
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(0, 122, 255, 0.2);
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

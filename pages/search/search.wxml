<!-- 照度计算器（统一版）：根据 isPro 动态渲染免费版/付费版 UI -->
<view class="page">
<wxs module="tools">
  module.exports.getModeName = function(tab) {
    if (tab === 'count') return '按照度算灯具';
    if (tab === 'quantity') return '按数量算灯具';
    if (tab === 'lux') return '按灯具算照度';
    return '计算结果';
  }
  module.exports.getModeDesc = function(tab) {
    if (tab === 'count') return '已知单一空间灯具数量，反推单盏灯所需亮度参数\n*仅限单一灯具类型';
    if (tab === 'quantity') return '已知单一空间目标照度/亮度，反推所需灯具数量\n*仅限单一灯具类型';
    if (tab === 'lux') return '已知灯具参数和数量，计算整体照度/亮度是否符合国家标准\n*适合复杂灯具组合';
    return '本计算器可估算灯具照明效果';
  }
</wxs>
  <!-- Loading 状态 -->
  <view wx:if="{{checkingPermission}}" class="loading-mask">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 主内容区域 -->
  <view wx:else>
    
    <!-- ==================== 免费版 UI ==================== -->
    <view wx:if="{{!isPro}}" class="free-version">
      <!-- 顶部标签 -->
      <view class="tabs">
        <view class="tab {{activeTab==='lux' ? 'active' : ''}}" bindtap="switchTab" data-tab="lux">
          <text class="tab-text">根据灯具算照度</text>
          <view class="tab-underline" wx:if="{{activeTab==='lux'}}"></view>
        </view>
        <view class="tab {{activeTab==='count' ? 'active' : ''}}" bindtap="switchTab" data-tab="count">
          <text class="tab-text">根据照度算灯具</text>
          <view class="tab-underline" wx:if="{{activeTab==='count'}}"></view>
        </view>
      </view>

      <!-- Tab 1: 根据灯具算照度 -->
      <view wx:if="{{activeTab==='lux'}}">
        <view class="card">
          <view class="card-heading">
            <text class="heading-title">灯具类型列表</text>
            <text class="heading-desc">（未用类型填0，米数/数量留空视为0）</text>
            <view class="heading-actions"><button class="param-btn" bindtap="openLampParamsFree">灯具参数</button></view>
          </view>

          <view class="cells lamp-cells">
            <view class="cell" wx:for="{{lampTypeRows}}" wx:key="index">
              <text class="label fixed">{{item.displayName || item.name}}</text>
              <view class="lamp-inline">
                <text class="spec">米数/数量</text>
                <input class="input lamp-input" type="number" value="{{item.lengthQty}}" data-index="{{index}}" bindinput="onLampLenInput" placeholder="0" placeholder-style="color:#9c9c9c"/>
              </view>
            </view>
          </view>
          <view class="cell"><text class="label">总光通量</text><view class="value"><text class="result">{{totalFluxCalc}}</text><text class="unit">lm</text></view></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">房间面积</text><input class="input" type="number" value="{{area}}" data-field="area" bindinput="onFieldInput" placeholder="平方米" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">利用系数</text><input class="input" type="digit" value="{{utilFactor}}" data-field="utilFactor" bindinput="onFieldInput" placeholder="0.8" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">维护系数</text><input class="input" type="digit" value="{{maintenanceFactor}}" data-field="maintenanceFactor" bindinput="onFieldInput" placeholder="0.8" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell"><text class="label">平均照度</text><view class="value"><text class="result">{{avgLux}}</text><text class="unit">勒克斯</text></view></view>
        </view>
      </view>

      <!-- Tab 2: 根据照度算灯具 -->
      <view wx:if="{{activeTab==='count'}}">
        <view class="card">
          <view class="cell" hover-class="cell-active"><text class="label fixed">照度值</text><input class="input" type="number" value="{{targetLux}}" data-field="targetLux" bindinput="onFieldInput" placeholder="勒克斯" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">单灯光通量</text><input class="input" type="number" value="{{lampFlux}}" data-field="lampFlux" bindinput="onFieldInput" placeholder="流明" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">房间面积</text><input class="input" type="number" value="{{area}}" data-field="area" bindinput="onFieldInput" placeholder="平方米" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">利用系数</text><input class="input" type="digit" value="{{utilFactor}}" data-field="utilFactor" bindinput="onFieldInput" placeholder="0.8" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell" hover-class="cell-active"><text class="label fixed">维护系数</text><input class="input" type="digit" value="{{maintenanceFactor}}" data-field="maintenanceFactor" bindinput="onFieldInput" placeholder="0.8" placeholder-style="color:#9c9c9c"/></view>
          <view class="cell"><text class="label">灯具数量</text><view class="value"><text class="result">{{calcLampCount}}</text><text class="unit">套</text></view></view>
          <view class="cell"><text class="label">单位面积平均功率</text><view class="value"><text class="result">{{avgPowerPerArea}}</text><text class="unit">W/m²</text></view></view>
        </view>
      </view>

      <!-- 计算规则说明 -->
      <view class="note" bindtap="onOpenRules"><text class="note-text">注：《照度计算器规则》</text></view>
    </view>

    <!-- ==================== 付费版 UI (Pixel-Perfect) ==================== -->
    <view wx:if="{{isPro && !showResult}}" class="pro-version-v2">
      <!-- 蓝色渐变头部 -->
      <view class="v2-header">
        <image class="v2-header-bg" src="{{headerBgFileId}}" mode="aspectFill"></image>
        <image class="v2-logo" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/LOGO/光乙照明 logo源文件(长版本-透明-白字).png" mode="aspectFit"></image>
        <text class="v2-overlay-title">照度计算器</text>
        <text class="v2-overlay-subtitle">{{tools.getModeName(activeTab)}}</text>
        <text class="v2-overlay-desc">{{tools.getModeDesc(activeTab)}}</text>
      </view>

      <!-- 悬浮内容区域 -->
      <view class="v2-content">
        
        <!-- 大卡片：包含 Tab 切换 + 通用输入 -->
        <view class="v2-card group-card">
          <!-- 1. Tab 切换 -->
          <view class="v2-tabs" style="margin-bottom: 30rpx;">
            <view class="v2-tab-item {{activeTab==='count' ? 'active' : ''}}" bindtap="switchTab" data-tab="count">按照度算参数</view>
            <view class="v2-tab-item {{activeTab==='quantity' ? 'active' : ''}}" bindtap="switchTab" data-tab="quantity">按照度算数量</view>
            <view class="v2-tab-item {{activeTab==='lux' ? 'active' : ''}}" bindtap="switchTab" data-tab="lux">按灯具算照度</view>
          </view>

          <!-- 2. 通用输入：空间类型、目标照度、房间面积 -->
          <view class="v2-input-row">
            <text class="v2-label">空间类型</text>
            <picker class="v2-input-box picker" mode="selector" range="{{roomTypes}}" range-key="name" value="{{roomTypeIndex < 0 ? 0 : roomTypeIndex}}" bindchange="onRoomTypeChange">
              <view class="picker-text {{roomTypeIndex >= 0 ? '' : 'placeholder'}}">
                {{roomTypeIndex >= 0 ? roomTypes[roomTypeIndex].name : '请选择空间'}}
              </view>
            </picker>
          </view>

          <view class="v2-input-row">
            <text class="v2-label">目标照度 <text class="v2-unit">(Lx)</text></text>
            <input class="v2-input-box" type="number" value="{{targetLux}}" data-field="targetLux" bindinput="onFieldInput" placeholder="请输入照度" placeholder-style="color:#C0C4CC"/>
          </view>

          <view class="v2-input-row">
            <text class="v2-label">房间面积 <text class="v2-unit">(㎡)</text></text>
            <input class="v2-input-box" type="number" value="{{area}}" data-field="area" bindinput="onFieldInput" placeholder="请输入面积" placeholder-style="color:#C0C4CC"/>
          </view>
        </view>

        <!-- 表单内容 - 剩余差异部分 -->
        
        <!-- 场景 1: 按照度算灯具 -->
        <block wx:if="{{activeTab==='count'}}">
          <!-- 卡片 3: 系数信息 -->
          <view class="v2-card group-card">
            <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenUtilFactorInfo">
                <text class="v2-label">利用系数</text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <view class="v2-input-box formula">
                  <picker class="formula-picker" mode="selector" range="{{floorHeights}}" range-key="name" value="{{floorHeightIndex}}" bindchange="onFloorHeightChange">
                    <text class="{{floorHeightIndex >= 0 ? 'selected-val' : ''}}">{{floorHeightIndex >= 0 ? floorHeights[floorHeightIndex].name : '选层高'}}</text>
                  </picker>
                  <text class="op">×</text>
                  <picker class="formula-picker" mode="selector" range="{{colorOptions}}" range-key="name" value="{{colorIndex}}" bindchange="onColorChange">
                    <text class="{{colorIndex >= 0 ? 'selected-val' : ''}}">{{colorIndex >= 0 ? colorOptions[colorIndex].name : '选色彩'}}</text>
                  </picker>
                  <text class="op">=</text>
                  <text class="res">{{utilFactor || '0.8'}}</text>
              </view>
            </view>

            <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenMntFactorInfo">
                <text class="v2-label">维护系数</text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <view class="v2-input-box formula">
                  <picker class="formula-picker" mode="selector" range="{{maintenanceOptions}}" range-key="name" value="{{maintenanceIndex}}" bindchange="onMaintenanceChange">
                    <text class="{{maintenanceIndex >= 0 ? 'selected-val' : ''}}">{{maintenanceIndex >= 0 ? maintenanceOptions[maintenanceIndex].name : '请选择环境特征'}}</text>
                  </picker>
                  <text class="op">=</text>
                  <text class="res">{{maintenanceFactor || '0.8'}}</text>
              </view>
            </view>
          </view>

          <!-- 卡片 2: 灯具信息 (光通量) -->
          <view class="v2-card group-card">
            <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenLampFluxInfo" style="width: auto; padding-right: 20rpx;">
                <text class="v2-label">单灯光通量 <text class="v2-unit">(Lm)</text></text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <input class="v2-input-box" type="number" value="{{lampFlux}}" data-field="lampFlux" bindinput="onFieldInput" placeholder="请输入光通量" placeholder-style="color:#C0C4CC"/>
            </view>
          </view>

        </block>

        <!-- 场景 2: 按数量算灯具 -->
        <block wx:if="{{activeTab==='quantity'}}">
          <!-- 卡片 3: 系数信息 -->
          <view class="v2-card group-card">
             <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenUtilFactorInfo">
                <text class="v2-label">利用系数</text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <view class="v2-input-box formula">
                  <picker class="formula-picker" mode="selector" range="{{floorHeights}}" range-key="name" value="{{floorHeightIndex}}" bindchange="onFloorHeightChange">
                    <text class="{{floorHeightIndex >= 0 ? 'selected-val' : ''}}">{{floorHeightIndex >= 0 ? floorHeights[floorHeightIndex].name : '选层高'}}</text>
                  </picker>
                  <text class="op">×</text>
                  <picker class="formula-picker" mode="selector" range="{{colorOptions}}" range-key="name" value="{{colorIndex}}" bindchange="onColorChange">
                    <text class="{{colorIndex >= 0 ? 'selected-val' : ''}}">{{colorIndex >= 0 ? colorOptions[colorIndex].name : '选色彩'}}</text>
                  </picker>
                  <text class="op">=</text>
                  <text class="res">{{utilFactor || '0.8'}}</text>
              </view>
            </view>

            <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenMntFactorInfo">
                <text class="v2-label">维护系数</text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <view class="v2-input-box formula">
                  <picker class="formula-picker" mode="selector" range="{{maintenanceOptions}}" range-key="name" value="{{maintenanceIndex}}" bindchange="onMaintenanceChange">
                    <text class="{{maintenanceIndex >= 0 ? 'selected-val' : ''}}">{{maintenanceIndex >= 0 ? maintenanceOptions[maintenanceIndex].name : '请选择环境特征'}}</text>
                  </picker>
                  <text class="op">=</text>
                  <text class="res">{{maintenanceFactor || '0.8'}}</text>
              </view>
            </view>
          </view>

          <!-- 卡片 2: 灯具信息 (数量) -->
          <view class="v2-card group-card">
            <view class="v2-input-row">
              <text class="v2-label">灯具数量 <text class="v2-unit">(盏)</text></text>
              <input class="v2-input-box" type="number" value="{{lampCount}}" data-field="lampCount" bindinput="onFieldInput" placeholder="请输入数量" placeholder-style="color:#C0C4CC"/>
            </view>
          </view>

        </block>

        <!-- 场景 3: 按灯具算照度 -->
        <block wx:if="{{activeTab==='lux'}}">
          <!-- 卡片 3: 系数信息 -->
          <view class="v2-card group-card">
            <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenUtilFactorInfo">
                <text class="v2-label">利用系数</text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <view class="v2-input-box formula">
                  <picker class="formula-picker" mode="selector" range="{{floorHeights}}" range-key="name" value="{{floorHeightIndex}}" bindchange="onFloorHeightChange">
                    <text class="{{floorHeightIndex >= 0 ? 'selected-val' : ''}}">{{floorHeightIndex >= 0 ? floorHeights[floorHeightIndex].name : '选层高'}}</text>
                  </picker>
                  <text class="op">×</text>
                  <picker class="formula-picker" mode="selector" range="{{colorOptions}}" range-key="name" value="{{colorIndex}}" bindchange="onColorChange">
                    <text class="{{colorIndex >= 0 ? 'selected-val' : ''}}">{{colorIndex >= 0 ? colorOptions[colorIndex].name : '选色彩'}}</text>
                  </picker>
                  <text class="op">=</text>
                  <text class="res">{{utilFactor || '0.8'}}</text>
              </view>
            </view>

            <view class="v2-input-row">
              <view class="v2-label-wrap" bindtap="onOpenMntFactorInfo">
                <text class="v2-label">维护系数</text>
                <image class="v2-info-icon" src="/images/使用说明.png"></image>
              </view>
              <view class="v2-input-box formula">
                  <picker class="formula-picker" mode="selector" range="{{maintenanceOptions}}" range-key="name" value="{{maintenanceIndex}}" bindchange="onMaintenanceChange">
                    <text class="{{maintenanceIndex >= 0 ? 'selected-val' : ''}}">{{maintenanceIndex >= 0 ? maintenanceOptions[maintenanceIndex].name : '请选择环境特征'}}</text>
                  </picker>
                  <text class="op">=</text>
                  <text class="res">{{maintenanceFactor || '0.8'}}</text>
              </view>
            </view>
          </view>

          <!-- 卡片 2: 灯具列表 -->
          <view class="v2-card group-card">
            <view class="v2-lamp-list">
                <view class="v2-input-row v2-add-row">
                  <view class="v2-label-wrap" bindtap="onOpenSourceUtilInfo">
                    <text class="v2-label">添加灯具</text>
                    <image class="v2-info-icon" src="/images/使用说明.png"></image>
                  </view>
                  <picker class="v2-input-box picker" mode="selector" range="{{lampAddOptions}}" value="{{lampAddValue}}" bindchange="onAddLampChange">
                    <view class="picker-text {{lampAddValue===0 ? 'placeholder' : ''}}">
                      {{lampAddOptions[lampAddValue]}}
                      <text class="v2-picker-arrow">▼</text>
                    </view>
                  </picker>
                </view>
                <view class="v2-lamp-item" wx:for="{{selectedLamps}}" wx:key="lampId">
                   <view class="v2-lamp-header">
                      <view class="v2-lamp-title-group">
                        <text class="v2-lamp-name">{{item.displayName || item.name}}</text>
                        <image class="v2-btn-edit" src="/images/编辑.png" data-lampid="{{item.lampId}}" bindtap="onRenameLamp"></image>
                      </view>
                      <view class="v2-lamp-remove" data-lampid="{{item.lampId}}" bindtap="onRemoveLamp">×</view>
                   </view>
                   <view class="v2-lamp-body">
                      <view class="v2-input-mini">
                         <text>功率</text>
                         <input type="number" value="{{item.powerW}}" data-lampid="{{item.lampId}}" bindinput="onSelectedLampPowerInput" placeholder="0"/>
                         <text>W</text>
                      </view>
                      <view class="v2-input-mini">
                         <text>利用率</text>
                         <input type="digit" value="{{item.sourceUtil}}" data-lampid="{{item.lampId}}" data-field="sourceUtil" bindinput="onSelectedLampInput" placeholder="1.0"/>
                      </view>
                      <view class="v2-input-mini">
                         <text>数量</text>
                         <input type="number" value="{{item.lengthQty}}" data-lampid="{{item.lampId}}" bindinput="onSelectedLampInput" placeholder="0"/>
                         <wxs module="unitTools">
                           module.exports.getUnit = function(name) {
                             if (!name) return '个';
                             if (name.indexOf('灯带') > -1 || name.indexOf('线性灯') > -1) {
                               return '米';
                             }
                             return '个';
                           }
                         </wxs>
                         <text>{{unitTools.getUnit(item.displayName || item.name)}}</text>
                      </view>
                   </view>
                </view>
             </view>
          </view>
        </block>

        <!-- 即刻计算按钮 -->
        <button class="v2-btn-calculate" bindtap="onCalculate">即刻计算</button>
        
      </view>
    </view>

  </view>
</view>

<!-- ==================== 弹窗层 ==================== -->

<!-- 免费版：灯具参数弹窗 -->
<view wx:if="{{showLampParams && !isPro}}" class="popup-mask" catchtouchmove="noop">
  <view class="popup-panel" catchtap="noop">
    <view class="popup-header">
      <text class="popup-title">灯具参数</text>
      <text class="popup-close" bindtap="closeLampParams">关闭</text>
    </view>
    <scroll-view scroll-y class="popup-body">
      <view class="lamp-table">
        <view class="lamp-table-header">
          <view class="th name"><text class="title">灯具类型</text></view>
          <view class="th"><text class="title">功率(W)</text></view>
          <view class="th"><text class="title">光效</text></view>
          <view class="th"><text class="title">利用率</text></view>
        </view>
        <view class="lamp-table-row" wx:for="{{lampTypeRows}}" wx:key="index">
          <text class="td name">{{item.displayName || item.name}}</text>
          <input class="td td-input" type="number" value="{{item.powerW}}" data-index="{{index}}" data-field="powerW" bindinput="onLampMetaInput" placeholder="0"/>
          <input class="td td-input" type="number" value="{{item.efficacy}}" data-index="{{index}}" data-field="efficacy" bindinput="onLampMetaInput" placeholder="0"/>
          <input class="td td-input" type="digit" value="{{item.sourceUtil}}" data-index="{{index}}" data-field="sourceUtil" bindinput="onLampMetaInput" placeholder="0~1"/>
        </view>
      </view>
    </scroll-view>
    <view class="popup-actions">
      <button class="btn ghost" bindtap="resetLampParams">重置参数</button>
      <button class="btn primary" bindtap="saveLampParamsFree">保存并关闭</button>
    </view>
  </view>
  <view class="popup-backdrop" bindtap="closeLampParams"></view>
</view>

<!-- 付费版：灯具参数弹窗 -->
<view wx:if="{{showLampParams && isPro}}" class="popup-mask" catchtouchmove="noop">
  <view class="popup-panel" catchtap="noop">
    <view class="popup-header">
      <text class="popup-title">灯具参数</text>
      <text class="popup-close" bindtap="closeLampParams">关闭</text>
    </view>
    <scroll-view scroll-y class="popup-body">
      <view class="lamp-table" wx:if="{{editingLamp}}">
        <view class="lamp-table-header">
          <view class="th name"><text class="title">类型</text></view>
          <view class="th"><text class="title">功率(W)</text></view>
          <view class="th"><text class="title">光效</text></view>
          <view class="th"><text class="title">利用率</text></view>
        </view>
        <view class="lamp-table-row">
          <text class="td name">{{editingLamp.displayName || editingLamp.name}}</text>
          <input class="td td-input" type="number" value="{{editingLamp.powerW}}" data-field="powerW" bindinput="onEditingLampInput" placeholder="0"/>
          <input class="td td-input" type="number" value="{{editingLamp.efficacy}}" data-field="efficacy" bindinput="onEditingLampInput" placeholder="0"/>
          <input class="td td-input" type="digit" value="{{editingLamp.sourceUtil}}" data-field="sourceUtil" bindinput="onEditingLampInput" placeholder="0~1"/>
        </view>
      </view>
    </scroll-view>
    <view class="popup-actions">
      <button class="btn primary" bindtap="saveLampParams">保存并关闭</button>
    </view>
  </view>
  <view class="popup-backdrop" bindtap="closeLampParams"></view>
</view>

<!-- 免费版：升级引导弹窗 -->
<view wx:if="{{showUpgradeModal}}" class="upgrade-modal-mask" catchtouchmove="stopPropagation">
  <view class="upgrade-modal-content" catchtap="stopPropagation">
    <view class="modal-close-btn" bindtap="onUpgradeCancel">×</view>
    
    <view class="modal-header">
      <text class="modal-icon">🎁</text>
      <text class="modal-title">升级高级版</text>
      <text class="modal-subtitle">解锁全部专业功能</text>
    </view>
    
    <view class="modal-body">
      <view class="feature-list">
        <view class="feature-item">
          <view class="feature-icon-wrapper"><text class="feature-icon">📊</text></view>
          <view class="feature-content">
            <text class="feature-title">现代化界面</text>
            <text class="feature-desc">更美观的卡片式设计</text>
          </view>
        </view>
        <view class="feature-item">
          <view class="feature-icon-wrapper"><text class="feature-icon">🏠</text></view>
          <view class="feature-content">
            <text class="feature-title">空间类型智能推荐</text>
            <text class="feature-desc">自动匹配合适的照度值</text>
          </view>
        </view>
        <view class="feature-item">

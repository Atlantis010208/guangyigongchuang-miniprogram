<!-- 光源利用率说明弹窗 -->
<view wx:if="{{showSourceUtilModal}}" class="util-modal-mask" bindtap="closeSourceUtilModal">
  <view class="util-modal-content" catchtap="stopPropagation">
    <view class="util-modal-close" bindtap="closeSourceUtilModal">×</view>
    
    <view class="util-modal-header">
      <text class="util-modal-title">光源利用率说明</text>
      <text class="util-modal-subtitle">不同照明方式参考数值</text>
    </view>
    
    <scroll-view scroll-y class="util-modal-body">
      <view class="util-section">
        <view class="util-table">
          <view class="util-table-row header">
            <text class="util-cell col-mode">照明方式</text>
            <text class="util-cell col-rate">利用率</text>
            <text class="util-cell col-type">包含类型</text>
          </view>
          
          <view class="util-table-row">
            <view class="util-cell col-mode">
              <view>间接照明</view>
              <view>2次反射</view>
            </view>
            <text class="util-cell col-rate">0.15</text>
            <text class="util-cell col-type">反灯槽灯带（10W/80lm/W/0.15）：反光灯槽、窗帘灯带、护墙板灯带、柜体灯带</text>
          </view>

          <view class="util-table-row">
            <view class="util-cell col-mode">
              <view>间接照明</view>
              <view>1次反射</view>
            </view>
            <text class="util-cell col-rate">0.30</text>
            <text class="util-cell col-type">正灯槽灯带（10W/80lm/W/0.30）：回型天花灯槽、边吊正灯槽</text>
          </view>

          <view class="util-table-row">
            <view class="util-cell col-mode">
              <view>直接照明</view>
              <view>带灯罩类</view>
            </view>
            <text class="util-cell col-rate">0.8-0.9</text>
            <text class="util-cell col-type">线性灯（10W/80lm/W/0.8）、吊灯（25W/80lm/W/0.9）、装饰灯（10W/80lm/W/0.9）</text>
          </view>

          <view class="util-table-row">
            <view class="util-cell col-mode">
              <view>直接照明</view>
              <view>无灯罩类</view>
            </view>
            <text class="util-cell col-rate">0.95</text>
            <text class="util-cell col-type">筒灯（7W/65lm/W）、射灯（3W/65lm/W）、吸顶灯、灯泡</text>
          </view>
        </view>
      </view>

      <view class="util-note">
        <text class="util-note-text">提示：计算公式为「灯具总光通量 = 功率 × 发光效率 × 数量 × 光源利用率」。发光效率是灯具本身的光电转换能力（筒灯/射灯65 lm/W，其他80 lm/W），光源利用率反映照明方式的光损失（间接照明因反射损失较大，利用率较低）。</text>
      </view>
    </scroll-view>
    
    <view class="util-modal-footer">
      <button class="util-btn-confirm" bindtap="closeSourceUtilModal">我知道了</button>
    </view>
  </view>
</view>


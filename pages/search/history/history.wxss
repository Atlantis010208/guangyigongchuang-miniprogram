page {
  background-color: #F5F7FA;
}

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 顶部提示栏 */
.header-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #F5F7FA;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-action {
  font-size: 26rpx;
  color: #8E8E93;
}

/* 列表区域 */
.history-list {
  padding: 0 24rpx;
  box-sizing: border-box;
}

.history-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item:active {
  background-color: #f9f9f9;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.edit-btn {
  padding: 10rpx;
  margin-right: -10rpx;
}

.edit-btn image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-summary {
  font-size: 28rpx;
  color: #666;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
}

.item-time {
  font-size: 24rpx;
  color: #8E8E93;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
}

.item-result {
  font-size: 28rpx;
  color: #367BE6; /* 使用照度计算器的主色调蓝色 */
  font-weight: 500;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.footer-tip text {
  font-size: 24rpx;
  color: #C0C4CC;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
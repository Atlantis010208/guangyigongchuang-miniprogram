page {
  background-color: #F2F2F7;
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden; /* 防止水平滚动 */
  box-sizing: border-box; /* 确保 page 也使用 border-box */
}

.no-scroll {
  overflow: hidden;
  height: 100vh;
}

/* 使用新的根节点类名，避开全局 container */
.gallery-root {
  min-height: 100vh;
  display: block; /* 改回 block，防止 flex 导致子元素撑破容器 */
  width: 100%;
  overflow-x: hidden; /* 强制裁剪溢出部分 */
  box-sizing: border-box; /* 关键：防止 padding 撑破屏幕 */
}

.content-wrapper {
  padding: 20rpx 30rpx 100rpx; /* 稍微减小一点左右边距，或者保持40但加上 box-sizing */
  width: 100%;
  box-sizing: border-box; /* 关键：防止 padding 撑破屏幕 */
}

/* Header */
.header {
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #1C1C1E;
  letter-spacing: -1rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  font-weight: 500;
}

/* Search Bar */
.search-container {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  width: 100%;
}

.search-box {
  position: relative;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
  width: 100%;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1C1C1E;
  min-width: 0; /* 防止 input 撑破 flex 容器 */
}

.search-placeholder {
  color: #8E8E93;
}

/* 清空按钮：仅当 searchQuery 非空时显示，点击清空输入并恢复列表 */
.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #D1D1D6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
  opacity: 0;
  transform: scale(0.6);
  pointer-events: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.search-clear.visible {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.search-clear-hover {
  background-color: #A1A1A6;
}

.search-clear-icon {
  width: 22rpx;
  height: 22rpx;
  filter: brightness(0) invert(1); /* 让 x.svg 显示为白色 */
}

/* Sticky Horizontal Tags */
.sticky-tags-container {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  height: 120rpx;
  padding-top: 10rpx;
  background: linear-gradient(to bottom, rgba(242, 242, 247, 0.95) 0%, rgba(242, 242, 247, 0) 100%);
  z-index: 1000;
  display: flex;
  align-items: center;
  transform: translateY(-100%);
  opacity: 0;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  pointer-events: none;
}

.sticky-tags-container.visible {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.sticky-scroll {
  width: 100%;
  height: 100%;
  white-space: nowrap;
  display: flex;
  align-items: center;
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
}

.sticky-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 36rpx;
  margin-right: 20rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1C1E;
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.sticky-tag:first-child {
  margin-left: 30rpx;
}

.sticky-tag:last-child {
  margin-right: 30rpx;
}

.sticky-tag.active {
  color: #FFFFFF;
  background: #1A1A1A;
  font-weight: 600;
  border-color: #1A1A1A;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* Categories (Dynamic Infinite Cloud Layout via WXS) */
.cloud-wrap {
  position: relative;
  width: 100%;
  height: 300rpx; /* 固定视口高度，由 JS 生成足够多的标签副本铺满。需与 gallery.js 的 VIEWPORT_H 保持一致 */
  margin-bottom: 50rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.cloud-viewport {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  /* 以自身中心为原点 (0,0) 进行渲染 */
}

.cloud-tag-wrap {
  position: absolute;
  top: 0;
  left: 0;
  /* 移除负 margin，改由 WXS 配合 translate3d(-50%, -50%, 0) 精确居中 */
  transform: translate3d(0, 0, 0) scale(0);
  opacity: 0;
  transition: background-color 0.2s ease, color 0.2s ease;
  will-change: transform, opacity;
  display: flex;
  justify-content: center;
  align-items: center;
  pointer-events: none; /* 让外层不拦截点击 */
}

.cloud-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #1A1A1A; /* 更深的纯黑色文字 */
  border-radius: 64rpx; /* 大圆角胶囊 */
  height: 64rpx; /* 固定高度，确保气泡规整 */
  padding: 0 32rpx; /* 增大左右内边距，使其更接近圆形或椭圆 */
  background-color: #F0F0F0; /* 截图中的浅灰底色 */
  white-space: nowrap;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 500;
  pointer-events: auto;
  
  /* 严格控制宽度，匹配 dx=200 的网格限制 */
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Active State */
.cloud-tag.active {
  background-color: #1A1A1A;
  color: #FFFFFF;
}

.cloud-mask-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 112rpx; /* ≈ 视口高度 × 0.28，与 .cloud-wrap height 同步缩放 */
  background: linear-gradient(to bottom, #F2F2F7 0%, rgba(242, 242, 247, 0) 100%);
  pointer-events: none;
  z-index: 999;
}

.cloud-mask-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx; /* ≈ 视口高度 × 0.28，与 .cloud-wrap height 同步缩放 */
  background: linear-gradient(to top, #F2F2F7 0%, rgba(242, 242, 247, 0) 100%);
  pointer-events: none;
  z-index: 999;
}

/* Masonry Gallery */
.gallery-container {
  padding: 0 10rpx;
  box-sizing: border-box;
  width: 100%;
}

.masonry {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

.masonry-col {
  width: 48%; /* 给点间隙，避免挤在一起 */
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.image-card {
  margin-bottom: 30rpx;
  border-radius: 48rpx;
  overflow: hidden;
  background-color: #E5E5EA;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.04);
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}

.hover-scale:active {
  transform: scale(0.98);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
}

.image-wrap {
  position: relative;
  width: 100%;
  box-sizing: border-box; /* 添加以防万一 */
}

.aspect-square { padding-bottom: 100%; }
.aspect-3-4 { padding-bottom: 133.33%; }
.aspect-4-3 { padding-bottom: 75%; }

.gallery-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  /* 默认 opacity:1：image 在 src 加载前自然空白（露出 image-card 的灰底占位），
     加载完成后由组件直接渲染像素。不再依赖 bindload 回调 setData 来切换 .loaded 类，
     避免 wx:if 分支切换或网络异常时图片永远 opacity:0 的问题。 */
  opacity: 1;
  object-fit: cover; /* 确保图片覆盖满容器且不溢出 */
}

.skeleton {
  width: 100%;
  border-radius: 48rpx;
  background-color: #E5E5EA;
  margin-bottom: 30rpx;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* Favorite Button */
.favorite-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: all 0.3s ease;
}

.favorite-btn:active {
  transform: scale(0.8);
}

.icon-heart {
  width: 32rpx;
  height: 32rpx;
  color: #FFFFFF;
}

/* Loading More */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #8E8E93;
  font-size: 28rpx;
  font-weight: 500;
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-top-color: transparent;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 32rpx;
}

.empty-icon {
  width: 48rpx;
  height: 48rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8E8E93;
}

/* Fullscreen Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.visible {
  opacity: 1;
  visibility: visible;
}

.modal-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1010;
  transition: background 0.3s;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.2);
}

.icon-close {
  width: 40rpx;
  height: 40rpx;
  filter: invert(100%);
}

.modal-swiper {
  width: 100%;
  height: 100%;
  will-change: transform, opacity;
}

/* 非拖拽状态下的平滑回弹 / 续动关闭 */
.modal-swiper.swiper-elastic {
  transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
              opacity 0.25s ease;
}

.modal-swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-image-wrap {
  width: 100%;
  height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-image {
  width: 100%;
  height: 100%;
}

.modal-controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 40rpx 60rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.9), rgba(0,0,0,0.4), transparent);
  display: flex;
  justify-content: center;
  transform: translateY(40rpx);
  opacity: 0;
  transition: all 0.5s ease;
  z-index: 1010;
}

.modal-controls.visible {
  transform: translateY(0);
  opacity: 1;
}

.modal-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  margin-right: 32rpx;
}

.action-btn.pill {
  height: 96rpx;
  padding: 0 64rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

.action-btn.pill text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.icon-heart-large {
  width: 40rpx;
  height: 40rpx;
  color: #FFFFFF;
  filter: invert(100%);
}

.icon-download {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  filter: invert(100%);
}

page {
  background-color: #F2F2F7;
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden; /* 防止水平滚动 */
  box-sizing: border-box; /* 确保 page 也使用 border-box */
}

.no-scroll {
  overflow: hidden;
  height: 100vh;
}

/* 使用新的根节点类名，避开全局 container */
.gallery-root {
  min-height: 100vh;
  display: block; /* 改回 block，防止 flex 导致子元素撑破容器 */
  width: 100%;
  overflow-x: hidden; /* 强制裁剪溢出部分 */
  box-sizing: border-box; /* 关键：防止 padding 撑破屏幕 */
}

.content-wrapper {
  padding: 20rpx 30rpx 100rpx; /* 稍微减小一点左右边距，或者保持40但加上 box-sizing */
  width: 100%;
  box-sizing: border-box; /* 关键：防止 padding 撑破屏幕 */
}

/* Header */
.header {
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #1C1C1E;
  letter-spacing: -1rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8E8E93;
  margin-top: 4rpx;
  font-weight: 500;
}

/* Search Bar */
.search-container {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  width: 100%;
}

.search-box {
  position: relative;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
  width: 100%;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1C1C1E;
  min-width: 0; /* 防止 input 撑破 flex 容器 */
}

.search-placeholder {
  color: #8E8E93;
}

/* Categories */
.category-scroll {
  width: calc(100% + 60rpx); /* 父级有 30rpx 的左右 padding，这里加上 60rpx */
  margin-left: -30rpx;
  margin-right: -30rpx;
  margin-bottom: 0; /* 将原来的 margin-bottom 移到 padding-bottom，避免阴影被截断 */
  white-space: nowrap;
  box-sizing: border-box;
}

.category-list {
  display: flex;
  padding: 0 30rpx 50rpx; /* 增加底部内边距，让卡片阴影完整显示。总间距保持 50rpx 不变 */
  box-sizing: border-box;
}

/* 修复 scroll-view 最后一个元素右侧 padding 失效的问题 */
.category-list::after {
  content: "";
  display: block;
  min-width: 14rpx; /* 30rpx (期望留白) - 16rpx (最后一个item的margin-right) = 14rpx */
  height: 1px;
  flex-shrink: 0;
}

.category-item {
  display: inline-block;
  padding: 16rpx 40rpx;
  background-color: #FFFFFF;
  color: #8E8E93;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  margin-right: 16rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.category-item.active {
  background-color: #1C1C1E;
  color: #FFFFFF;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* Masonry Gallery */
.gallery-container {
  padding: 0 10rpx;
  box-sizing: border-box;
  width: 100%;
}

.masonry {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

.masonry-col {
  width: 48%; /* 给点间隙，避免挤在一起 */
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.image-card {
  margin-bottom: 30rpx;
  border-radius: 48rpx;
  overflow: hidden;
  background-color: #E5E5EA;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.04);
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  width: 100%;
  box-sizing: border-box;
}

.hover-scale:active {
  transform: scale(0.98);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
}

.image-wrap {
  position: relative;
  width: 100%;
  box-sizing: border-box; /* 添加以防万一 */
}

.aspect-square { padding-bottom: 100%; }
.aspect-3-4 { padding-bottom: 133.33%; }
.aspect-4-3 { padding-bottom: 75%; }

.gallery-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.5s ease;
  object-fit: cover; /* 确保图片覆盖满容器且不溢出 */
}

.gallery-img.loaded {
  opacity: 1;
}

.skeleton {
  width: 100%;
  border-radius: 48rpx;
  background-color: #E5E5EA;
  margin-bottom: 30rpx;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* Favorite Button */
.favorite-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: all 0.3s ease;
}

.favorite-btn:active {
  transform: scale(0.8);
}

.icon-heart {
  width: 32rpx;
  height: 32rpx;
  color: #FFFFFF;
}

/* Loading More */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #8E8E93;
  font-size: 28rpx;
  font-weight: 500;
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-top-color: transparent;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 32rpx;
}

.empty-icon {
  width: 48rpx;
  height: 48rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1C1E;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8E8E93;
}

/* Fullscreen Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.visible {
  opacity: 1;
  visibility: visible;
}

.modal-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1010;
  transition: background 0.3s;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.2);
}

.icon-close {
  width: 40rpx;
  height: 40rpx;
  filter: invert(100%);
}

.modal-swiper {
  width: 100%;
  height: 100%;
}

.modal-swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-image-wrap {
  width: 100%;
  height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-image {
  width: 100%;
  height: 100%;
}

.modal-controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 40rpx 60rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.9), rgba(0,0,0,0.4), transparent);
  display: flex;
  justify-content: center;
  transform: translateY(40rpx);
  opacity: 0;
  transition: all 0.5s ease;
  z-index: 1010;
}

.modal-controls.visible {
  transform: translateY(0);
  opacity: 1;
}

.modal-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  margin-right: 32rpx;
}

.action-btn.pill {
  height: 96rpx;
  padding: 0 64rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

.action-btn.pill text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.icon-heart-large {
  width: 40rpx;
  height: 40rpx;
  color: #FFFFFF;
  filter: invert(100%);
}

.icon-download {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  filter: invert(100%);
}

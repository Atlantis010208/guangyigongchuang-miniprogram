<wxs module="cloud" src="./cloud.wxs"></wxs>

<view class="gallery-root">
  <view class="content-wrapper">
    <!-- Header -->
    <view class="header">
      <view class="header-content">
        <view class="title">实景灯光图库</view>
        <view class="subtitle">高端照明设计灵感</view>
      </view>
    </view>

    <!-- Search Bar -->
    <view class="search-container">
      <view class="search-box">
        <image class="search-icon" src="/images/toolbox/search.svg" mode="aspectFit"></image>
        <input class="search-input" placeholder="搜索灯光场景..." placeholder-class="search-placeholder" value="{{searchQuery}}" bindinput="onSearchInput" />
      </view>
    </view>

    <!-- Categories (Dynamic Infinite Cloud Layout via WXS) -->
    <view class="cloud-wrap" 
          bind:touchstart="{{cloud.touchStart}}" 
          catch:touchmove="{{cloud.touchMove}}" 
          bind:touchend="{{cloud.touchEnd}}"
          bind:touchcancel="{{cloud.touchEnd}}"
          change:activeCategory="{{cloud.onActiveChange}}"
          activeCategory="{{activeCategory}}"
          change:config="{{cloud.onConfigChange}}"
          config="{{categoryCloudConfig}}">
      
      <!-- wxs init 触发器 -->
      <view style="display:none;" 
            change:prop="{{cloud.init}}" prop="{{categoryCloud}}"
            change:config="{{cloud.onConfigChange}}" config="{{categoryCloudConfig}}"
            change:active="{{cloud.onActiveChange}}" active="{{activeCategory}}"></view>

      <view class="cloud-mask-top"></view>
      
      <!-- 视口中心点，所有标签相对于此原点进行 2D 平移 -->
      <view class="cloud-viewport">
        <block wx:for="{{categoryCloud}}" wx:key="name">
          <!-- 标签外层包裹器：用于 WXS 获取 dataset 并应用内联样式 -->
          <view class="cloud-tag-wrap" 
                data-bx="{{item.bx}}" 
                data-by="{{item.by}}" 
                data-name="{{item.name}}">
            <view class="cloud-tag {{activeCategory === item.name ? 'active' : ''}}" 
                  bindtap="onCategorySelect" 
                  data-category="{{item.name}}">
              {{item.name}}
            </view>
          </view>
        </block>
      </view>

      <view class="cloud-mask-bottom"></view>
    </view>

    <!-- Gallery Content (Masonry Layout) -->
    <view class="gallery-container">
      <block wx:if="{{isFetching}}">
        <!-- Skeletons -->
        <view class="masonry">
          <view class="masonry-col">
            <view class="skeleton aspect-4-3"></view>
            <view class="skeleton aspect-square"></view>
            <view class="skeleton aspect-3-4"></view>
          </view>
          <view class="masonry-col">
            <view class="skeleton aspect-square"></view>
            <view class="skeleton aspect-3-4"></view>
            <view class="skeleton aspect-4-3"></view>
          </view>
        </view>
      </block>
      <block wx:elif="{{filteredImages.length > 0}}">
        <!-- Waterfall Columns -->
        <view class="masonry">
          <!-- Left Column -->
          <view class="masonry-col">
            <block wx:for="{{leftColImages}}" wx:key="id">
              <view class="image-card hover-scale" bindtap="onImageSelect" data-id="{{item.id}}" id="img-{{item.id}}">
                <view class="image-wrap {{item.aspect}}">
                  <image class="gallery-img {{item.loaded ? 'loaded' : ''}}" src="{{item.thumbUrl}}" mode="aspectFill" lazy-load bindload="onImageLoad" data-id="{{item.id}}"></image>
                  <view class="favorite-btn" catchtap="onToggleFavorite" data-id="{{item.id}}">
                    <image class="icon-heart" src="/images/toolbox/heart.svg" mode="aspectFit" style="filter: {{favoritesMap[item.id] ? 'invert(29%) sepia(85%) saturate(7386%) hue-rotate(338deg) brightness(108%) contrast(105%)' : 'none'}};"></image>
                  </view>
                </view>
              </view>
            </block>
          </view>
          <!-- Right Column -->
          <view class="masonry-col">
            <block wx:for="{{rightColImages}}" wx:key="id">
              <view class="image-card hover-scale" bindtap="onImageSelect" data-id="{{item.id}}" id="img-{{item.id}}">
                <view class="image-wrap {{item.aspect}}">
                  <image class="gallery-img {{item.loaded ? 'loaded' : ''}}" src="{{item.thumbUrl}}" mode="aspectFill" lazy-load bindload="onImageLoad" data-id="{{item.id}}"></image>
                  <view class="favorite-btn" catchtap="onToggleFavorite" data-id="{{item.id}}">
                    <image class="icon-heart" src="/images/toolbox/heart.svg" mode="aspectFit" style="filter: {{favoritesMap[item.id] ? 'invert(29%) sepia(85%) saturate(7386%) hue-rotate(338deg) brightness(108%) contrast(105%)' : 'none'}};"></image>
                  </view>
                </view>
              </view>
            </block>
          </view>
        </view>
        
        <!-- Loading More -->
        <view class="loading-more" wx:if="{{hasMore}}">
          <view class="spinner" wx:if="{{isLoadingMore}}"></view>
          <text wx:if="{{isLoadingMore}}">加载更多...</text>
        </view>
      </block>
      <block wx:else>
        <!-- Empty State -->
        <view class="empty-state">
          <view class="empty-icon-wrap">
            <image class="empty-icon" src="{{activeCategory === '收藏' && !searchQuery ? '/images/toolbox/heart.svg' : '/images/toolbox/search.svg'}}" mode="aspectFit"></image>
          </view>
          <view class="empty-title">{{activeCategory === '收藏' && !searchQuery ? '暂无收藏内容' : '未找到相关场景'}}</view>
          <view class="empty-desc">{{activeCategory === '收藏' && !searchQuery ? '点击图片右上角的心形图标即可收藏' : '请尝试更换搜索词或分类'}}</view>
        </view>
      </block>
    </view>
  </view>
</view>

<!-- Fullscreen Image Modal -->
<view class="modal-overlay {{showModal ? 'visible' : ''}}" bindtap="onCloseModal" catchtouchmove="true">
  <view class="modal-close" catchtap="onCloseModal">
    <image class="icon-close" src="/images/toolbox/x.svg" mode="aspectFit"></image>
  </view>

  <swiper class="modal-swiper" current="{{currentSwiperIndex}}" bindchange="onSwiperChange" duration="300" circular="{{false}}">
    <block wx:for="{{filteredImages}}" wx:key="id">
      <swiper-item class="modal-swiper-item">
        <view class="modal-image-wrap" catchtap="toggleModalControls">
          <image class="modal-image" src="{{item.thumbUrl}}" mode="aspectFit" lazy-load></image>
        </view>
      </swiper-item>
    </block>
  </swiper>

  <view class="modal-controls {{showControls ? 'visible' : ''}}" catchtap="true">
    <view class="modal-actions">
      <view class="action-btn circle" catchtap="onToggleFavoriteCurrent">
        <image class="icon-heart-large" src="/images/toolbox/heart.svg" mode="aspectFit" style="filter: {{favoritesMap[filteredImages[currentSwiperIndex].id] ? 'invert(29%) sepia(85%) saturate(7386%) hue-rotate(338deg) brightness(108%) contrast(105%)' : 'none'}}"></image>
      </view>
      <view class="action-btn pill" catchtap="onDownloadCurrent">
        <image class="icon-download" src="/images/toolbox/download.svg" mode="aspectFit"></image>
        <text>{{isDownloading ? '下载中...' : '保存高清原图'}}</text>
      </view>
    </view>
  </view>
</view>


page {
  background-color: #ffffff;
}

.page-container {
  min-height: 100vh;
  background-color: #ffffff;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* 上传封面图 */
.upload-cover-section {
  padding: 16px 24px 24px;
}

.upload-cover-box {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 12px;
  border: 2px dashed #d1d5db;
  background-color: #f9fafb;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: background-color 0.2s;
}

.upload-cover-box:active {
  background-color: #f3f4f6;
}

.upload-cover-box.has-image {
  border: none;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.upload-text {
  font-size: 14px;
  font-weight: 500;
  color: #9ca3af;
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.change-cover-mask {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.upload-cover-box:active .change-cover-mask {
  opacity: 1;
}

/* 表单部分 */
.form-section {
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.form-item {
  position: relative;
}

.form-label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 4px;
}

.mb-2 {
  margin-bottom: 8px;
}

.form-input {
  display: block;
  width: 100%;
  border: none;
  border-bottom: 1px solid #e5e7eb;
  background: transparent;
  padding: 10px 0;
  font-size: 16px;
  color: #111827;
  height: 24px;
  min-height: 24px;
  line-height: 24px;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-bottom-color: #000000;
}

.placeholder-style {
  color: #d1d5db;
}

.picker-wrapper {
  position: relative;
}

.picker-inner {
  position: relative;
  width: 100%;
}

.picker-input {
  padding-right: 24px;
}

.arrow-icon {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
}

.form-textarea {
  display: block;
  width: 100%;
  box-sizing: border-box;
  background-color: #f9fafb;
  border-radius: 8px;
  padding: 16px;
  font-size: 14px;
  color: #111827;
  line-height: 1.5;
  height: 120px;
  border: 1px solid transparent;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-textarea:focus {
  border-color: #000000;
  box-shadow: 0 0 0 1px #000000;
  background-color: #ffffff;
}

/* 项目图集 */
.gallery-section {
  padding: 32px 24px;
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: #111827;
  margin-bottom: 16px;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.gallery-item {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 8px;
  overflow: hidden;
  background-color: #f3f4f6;
}

.gallery-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.gallery-upload-btn {
  aspect-ratio: 1 / 1;
  border-radius: 8px;
  border: 2px dashed #d1d5db;
  background-color: #f9fafb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  transition: background-color 0.2s;
}

.gallery-upload-btn:active {
  background-color: #f3f4f6;
}

.gallery-upload-text {
  font-size: 10px;
  font-weight: 500;
  color: #9ca3af;
}

/* 底部操作区 */
.bottom-spacer {
  height: 120px; /* 留出底部按钮的空间 */
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  padding: 24px;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  z-index: 20;
}

.submit-btn {
  width: 100%;
  background-color: #000000;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 9999px;
  padding: 16px 0;
  line-height: 1.5;
  box-shadow: 0 10px 15px -3px rgba(229, 231, 235, 0.5), 0 4px 6px -2px rgba(229, 231, 235, 0.5);
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

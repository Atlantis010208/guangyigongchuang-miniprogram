page {
  background-color: #f6f6f8;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24px 24px calc(24px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  position: relative;
}

/* 主体内容 */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 5vh; /* 视觉补偿，稍微偏上一点看起来更舒服 */
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.icon-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28px;
}

.icon-circle {
  position: relative;
  width: 108px;
  height: 108px;
  border-radius: 50%;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04), 0 2px 8px rgba(0, 0, 0, 0.02);
}

.main-icon {
  width: 54px;
  height: 54px;
}

.badge-red {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 20px;
  height: 20px;
  background-color: #ef4444;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid #ffffff;
  box-shadow: 0 4px 8px rgba(239, 68, 68, 0.25);
}

.close-icon {
  width: 16px;
  height: 16px;
}

.text-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  text-align: center;
  max-width: 320px;
}

.title {
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.5px;
  color: #0f172a;
}

.desc {
  font-size: 15px;
  line-height: 1.6;
  color: #64748b;
  padding: 0 12px;
}

/* 底部区域 */
.bottom-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24px;
  animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
}

/* 联系卡片 */
.contact-card {
  background-color: #ffffff;
  border-radius: 20px;
  padding: 24px;
  display: flex;
  align-items: flex-start;
  gap: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
}

.contact-icon-box {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background-color: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.headset-icon {
  width: 22px;
  height: 22px;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.contact-title {
  font-size: 15px;
  font-weight: 600;
  color: #0f172a;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 8px;
}

.small-icon {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.contact-text {
  font-size: 14px;
  color: #64748b;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
}

.btn-primary {
  width: 100%;
  height: 52px;
  background-color: #0f172a;
  color: #ffffff;
  border-radius: 26px;
  font-size: 17px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: none;
  box-shadow: 0 8px 16px rgba(15, 23, 42, 0.12);
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 4px 8px rgba(15, 23, 42, 0.1);
}

.btn-icon {
  width: 20px;
  height: 20px;
}

.btn-secondary {
  width: 100%;
  height: 48px;
  background-color: transparent;
  color: #64748b;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-secondary::after {
  display: none;
}

.btn-secondary:active {
  background-color: rgba(0, 0, 0, 0.03);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

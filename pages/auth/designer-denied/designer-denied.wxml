<view class="container">
  <view class="main-content">
    <view class="icon-container">
      <view class="icon-circle">
        <image class="main-icon" src="/images/锁定（身份）.png" mode="aspectFit" />
        
        
      </view>
      
      <view class="text-content">
        <view class="title">当前身份受限</view>
        <view class="desc">您当前的账号暂无设计师权限，无法进入设计师端。如需开通，请联系平台管理员。</view>
      </view>
    </view>
  </view>

  <view class="bottom-section">
    <view class="contact-card">
      <view class="contact-icon-box">
        <!-- support_agent icon -->
        <image class="headset-icon" src="data:image/svg+xml;base64," />
      </view>
      <view class="contact-info">
        <view class="contact-title">联系客服</view>
        <view class="contact-list">
          <view class="contact-item" bindtap="makePhoneCall">
            <!-- call icon -->
            <image class="small-icon" src="data:image/svg+xml;base64," />
            <text class="contact-text">{{phoneNumber}}</text>
          </view>
          <view class="contact-item" bindtap="copyWechat">
            <!-- chat_bubble icon -->
            <image class="small-icon" src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSI+PHBhdGggZD0iTTIwIDJINEMyLjkgMiAyIDIuOSAyIDRWMjJMNiAxOEgyMEMyMS4xIDE4IDIyIDE3LjEgMjIgMTZWNEMyMiAyLjkgMjEuMSAyIDIwIDJaIiBmaWxsPSIjNjQ3NDhiIi8+PC9zdmc+" />
            <text class="contact-text">{{wechatId}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <button class="btn-primary" bindtap="contactAdmin">
        <!-- admin panel icon -->
        <image class="btn-icon" src="data:image/svg+xml;base64," />
        联系管理员
      </button>
      <button class="btn-secondary" bindtap="switchIdentity">切换身份</button>
    </view>
  </view>
</view>

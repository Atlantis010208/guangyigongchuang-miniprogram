/* Specific styles for Course Index */

.header-section {
  width: 100%;
}

.avatar-small {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background-color: #e5e5ea;
}

/* Hero Card Styles */
.hero-card {
  width: 100%;
  height: 700rpx; /* Fixed height for immersive effect */
  display: flex;
  flex-direction: column;
  position: relative; /* Context for absolute positioning */
  /* Remove overflow: hidden from parent to allow shadow to show */
  overflow: visible; 
  border-radius: 32rpx; /* Explicitly set border radius for shadow shape */
  backface-visibility: hidden;
  transform: translate3d(0, 0, 0);
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.hero-card:active {
  transform: scale(0.98);
}

.hero-image-wrapper {
  position: relative;
  width: 100%;
  height: 100%; /* Fill the card */
  /* Move clipping to the wrapper */
  border-radius: 32rpx; 
  overflow: hidden;
  /* Fix Safari/iOS border-radius clipping with image */
  transform: translateZ(0); 
  background-color: #000; /* Dark background for letterboxing */
}

/* Background blurred image */
.hero-image-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(20px); /* Apply blur effect */
  opacity: 0.6; /* Dim the background slightly */
  transform: scale(1.1); /* Scale up to avoid blurred edges showing */
}

/* Foreground content image */
.hero-image {
  position: relative; /* Ensure z-index works */
  width: 100%;
  height: 100%;
  z-index: 1; /* Above background */
}

/* Updated Overlay - Fades out at the bottom to let footer glass shine */
.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  /* Gradient stops before the bottom to avoid darkening the glass footer */
  background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.7) 100%);
  z-index: 2; /* Above image */
}

.hero-content {
  position: absolute;
  bottom: 160rpx; /* Raise above the footer */
  left: 0;
  padding: 40rpx;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  z-index: 3; /* Above overlay */
}

.hero-title {
  color: white;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.5); /* Stronger shadow for visibility */
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.95);
  font-size: 28rpx;
  font-weight: 400;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.5);
}

/* Glassmorphism Footer - Improved Transparency */
.hero-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.45); /* More transparent */
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  z-index: 2;
  box-sizing: border-box;
  border-top: none; /* Remove any border */
  box-shadow: none; /* Remove any shadow */
  /* Fix corner overflow: Match the card's border radius at the bottom */
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden; /* Clip any inner content */
}

.text-white {
  color: #ffffff;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3); /* Add shadow for readability */
}

.instructor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #f2f2f7;
}

.price-tag {
  background-color: rgba(255, 255, 255, 0.6); /* Semi-transparent bg */
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  color: #007aff;
  font-weight: 600;
}

.currency {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.amount {
  font-size: 32rpx;
}

/* Play Button Circle (Apple Style) */
.play-btn-circle {
  width: 80rpx;
  height: 80rpx;
  background-color: #007aff; /* Apple Blue */
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.1s, background-color 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

.play-btn-circle:active {
  transform: scale(0.92);
  background-color: #0062cc;
}

.icon-play-fill {
  width: 0;
  height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 24rpx solid #ffffff;
  margin-left: 8rpx; /* Optically centered */
}

/* Section Header */
.section-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.text-blue {
  color: #007aff;
}

/* Course List Item */
.course-item {
  width: 100%;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  /* More breathing room */
  padding: 36rpx;
  border-radius: 32rpx; /* Consistent radius */
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.course-item:active {
  transform: scale(0.96);
}

.course-thumb {
  width: 240rpx; /* Adjusted to 16:9 ratio */
  height: 135rpx;
  flex-shrink: 0;
  background-color: #e5e5ea;
  border-radius: 16rpx; /* Slightly smaller radius for smaller height */
  /* No shadow for thumb to keep it clean */
}

.course-info {
  margin-left: 24rpx; /* Reduced spacing to accommodate wider image */
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 135rpx; /* Match thumb height */
}

.info-top {
  display: flex;
  flex-direction: column;
}

.title-small {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.3;
  margin-bottom: 12rpx; /* More spacing below title */
}

.text-gray {
  color: #8e8e93;
}

.clamp-1 {
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  line-height: 1.4;
  height: 36rpx; /* Fixed height for single line */
}

.info-bottom {
  /* Aligned to bottom */
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
}

.tag-text {
  font-size: 20rpx;
  color: #8e8e93;
  background-color: #f2f2f7;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  margin-right: 12rpx; /* Increased horizontal spacing */
  font-weight: 500;
}

/* Price Get Button (Capsule Style) */
.get-button {
  background-color: #f2f2f7;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 700;
  padding: 10rpx 32rpx;
  border-radius: 32rpx;
  min-width: 100rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s;
}

.footer-space {
  height: 100rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  width: 100%;
}

.empty-icon-bg {
  width: 120rpx;
  height: 120rpx;
  background-color: #f2f2f7;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.icon-box-open {
  width: 48rpx;
  height: 36rpx;
  border: 4rpx solid #c7c7cc;
  border-top: none;
  border-radius: 0 0 4rpx 4rpx;
  position: relative;
  margin-top: 10rpx;
}

.icon-box-open::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: -4rpx;
  width: 28rpx;
  height: 4rpx;
  background-color: #c7c7cc;
  transform: rotate(-25deg);
  transform-origin: left bottom;
}

.icon-box-open::after {
  content: '';
  position: absolute;
  top: -14rpx;
  right: -4rpx;
  width: 28rpx;
  height: 4rpx;
  background-color: #c7c7cc;
  transform: rotate(25deg);
  transform-origin: right bottom;
}

.empty-title {
  font-size: 30rpx;
  color: #8e8e93;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-subtitle {
  font-size: 24rpx;
  color: #aeaeb2;
}

/* Loading State */
.loading-state {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f2f2f7;
  border-top: 6rpx solid #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #8e8e93;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

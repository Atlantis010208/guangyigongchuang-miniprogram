/* Specific styles for Course Index */

.header-section {
  width: 100%;
}

.avatar-small {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background-color: #e5e5ea;
}

/* Hero Card Styles */
.hero-card {
  width: 100%;
  padding-bottom: 100%; /* 1:1 Aspect Ratio (Square) */
  height: 0; /* Let padding define height */
  display: block; /* Change from flex to block */
  position: relative; 
  overflow: hidden; 
  border-radius: 32rpx; 
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.1); 
  margin-bottom: 40rpx;
  background-color: #fff;
  transform: translateZ(0); 
}

.hero-card:active {
  transform: scale(0.98);
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.hero-image-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* Foreground content image */
.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover; 
}

/* Hide the blurred bg since we use aspectFill now */
.hero-image-bg {
  display: none;
}

/* Hide old overlay elements */
.hero-overlay, .hero-content {
  display: none;
}

/* Glassmorphism Footer - Dark Mode Style (Apple Store) */
.hero-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 45%; /* Occupy slightly more space */
  
  /* Strong Blur Effect */
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  
  /* Deep Dark Semi-transparent Gradient (Gray Tone) */
  background: linear-gradient(to bottom, 
    rgba(0, 0, 0, 0.2) 0%, 
    rgba(0, 0, 0, 0.5) 40%, 
    rgba(0, 0, 0, 0.7) 100%
  );
  
  z-index: 3;
  padding: 32rpx 40rpx 40rpx 40rpx; /* Increase bottom padding */
  box-sizing: border-box;
  display: flex;
  flex-direction: column; 
  justify-content: flex-end; /* Align content to bottom */
  align-items: flex-start;
  
  /* Subtle top border for glass separation */
  border-top: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1); /* Subtle shadow upwards */
  
  /* Reduced padding to move content lower */
  padding: 32rpx 40rpx 32rpx 40rpx;
}

.footer-content {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* 1. Small Tag (Subtitle) - Light Grey */
.hero-tag {
  font-size: 24rpx; 
  color: rgba(255, 255, 255, 0.85); 
  font-weight: 600;
  letter-spacing: 2rpx; 
  margin-bottom: 12rpx; /* Reduced from 20rpx */
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 2. Main Title - White */
.hero-title {
  color: #ffffff;
  font-size: 40rpx; /* Slightly reduced from 42rpx */
  font-weight: 600; 
  line-height: 1.4; /* Tighter line height */
  margin-bottom: 32rpx; /* Reduced from 50rpx to move closer to bottom */
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.25);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  letter-spacing: 1rpx;
}

/* 3. Bottom Actions Row */
.hero-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

/* Play Pill Button - Optimized Apple Style */
.play-pill {
  background: rgba(255, 255, 255, 0.3); /* Enhanced Glassy White */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 88rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s;
  border: 1rpx solid rgba(255, 255, 255, 0.25); /* Subtle border for definition */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.play-pill:active {
  background: rgba(255, 255, 255, 0.45);
  transform: scale(0.96);
}

.icon-play-fill {
  width: 0; 
  height: 0; 
  border-top: 12rpx solid transparent;  /* 增大三角形高度 */
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid #ffffff;  /* 增大三角形宽度 */
  margin-right: 12rpx;
}

.play-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

/* Price Pill Button (未购买状态) */
.price-pill {
  background: rgba(255, 255, 255, 0.25); /* 白色背景，更突出 */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.price-pill:active {
  background: rgba(255, 255, 255, 0.4);
  transform: scale(0.96);
}

.currency-symbol {
  color: #ffffff; /* Apple Blue */
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 2rpx;
}

.price-amount {
  color: #ffffff; /* Apple Blue */
  font-size: 32rpx;
  font-weight: 700;
  font-family: -apple-system-monospaced, "SF Mono", Menlo, monospace;
  letter-spacing: -0.5rpx;
}

/* More Button */
.more-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.icon-more {
  width: 8rpx;
  height: 8rpx;
  background-color: #ffffff;
  border-radius: 50%;
  box-shadow: 12rpx 0 0 #ffffff, -12rpx 0 0 #ffffff; /* Three dots using shadow */
  opacity: 0.8;
}

/* Removed old description styles */
.hero-desc-row, .hero-desc-text {
  display: none;
}

/* Section Header */
.section-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.text-blue {
  color: #007aff;
}

/* Course List Item */
.course-item {
  width: 100%;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  background-color: #ffffff;
  /* More breathing room */
  padding: 36rpx;
  border-radius: 32rpx; /* Consistent radius */
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.course-item:active {
  transform: scale(0.96);
}

.course-thumb {
  width: 220rpx; /* Adjusted to 1:1 ratio */
  height: 220rpx;
  flex-shrink: 0;
  background-color: #e5e5ea;
  border-radius: 16rpx;
  /* No shadow for thumb to keep it clean */
}

.course-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 220rpx; /* Match thumb height */
}

.info-top {
  display: flex;
  flex-direction: column;
}

.title-small {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.3;
  margin-bottom: 12rpx; /* More spacing below title */
}

.text-gray {
  color: #8e8e93;
}

.clamp-1 {
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 26rpx;
  line-height: 1.4;
  height: 36rpx; /* Fixed height for single line */
}

.info-bottom {
  /* Aligned to bottom */
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
}

.tag-text {
  font-size: 20rpx;
  color: #8e8e93;
  background-color: #f2f2f7;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  margin-right: 12rpx; /* Increased horizontal spacing */
  font-weight: 500;
}

/* Price Get Button (Capsule Style) */
.get-button {
  background-color: #f2f2f7;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 700;
  padding: 10rpx 32rpx;
  border-radius: 32rpx;
  min-width: 100rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s;
}

/* 
  Apple Style Play Button (Purchased State)
*/
.get-button.play-mode {
  background-color: #f2f2f7; /* System Gray 6 */
  color: #1c1c1e; /* System Label Color */
  padding: 10rpx 24rpx;
  min-width: 150rpx; /* Width for "立即观看" */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s;
}

.get-button.play-mode:active {
  background-color: #e5e5ea; /* Darker on press */
  transform: scale(0.96);
}

.icon-play-small {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;  /* 稍微增大 */
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #1c1c1e;
  margin-right: 10rpx;
  transform: translateX(2rpx); /* Optical alignment */
}

.play-text-small {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* Legacy Progress styles (kept if needed but unused in new design) */
.progress-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  background-color: #34c759; /* Apple Green */
  opacity: 0.2; /* Semi-transparent fill */
  z-index: 1;
  transition: width 0.3s ease-out;
}

.progress-text {
  position: relative;
  z-index: 2;
  font-size: 24rpx;
  color: #34c759;
  font-weight: 700;
  padding: 10rpx 32rpx; /* Restore padding for text */
  width: 100%;
  box-sizing: border-box;
}

.footer-space {
  height: 100rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  width: 100%;
}

.empty-icon-bg {
  width: 120rpx;
  height: 120rpx;
  background-color: #f2f2f7;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.icon-box-open {
  width: 48rpx;
  height: 36rpx;
  border: 4rpx solid #c7c7cc;
  border-top: none;
  border-radius: 0 0 4rpx 4rpx;
  position: relative;
  margin-top: 10rpx;
}

.icon-box-open::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: -4rpx;
  width: 28rpx;
  height: 4rpx;
  background-color: #c7c7cc;
  transform: rotate(-25deg);
  transform-origin: left bottom;
}

.icon-box-open::after {
  content: '';
  position: absolute;
  top: -14rpx;
  right: -4rpx;
  width: 28rpx;
  height: 4rpx;
  background-color: #c7c7cc;
  transform: rotate(25deg);
  transform-origin: right bottom;
}

.empty-title {
  font-size: 30rpx;
  color: #8e8e93;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-subtitle {
  font-size: 24rpx;
  color: #aeaeb2;
}

/* Loading State */
.loading-state {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f2f2f7;
  border-top: 6rpx solid #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #8e8e93;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

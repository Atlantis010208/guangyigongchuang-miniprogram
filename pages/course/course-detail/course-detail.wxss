/* Cover Header */
.cover-wrapper {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(to bottom, transparent, #f2f2f7);
}

/* Info Card */
.info-card {
  margin-top: -60rpx; /* Overlap effect */
  position: relative;
  z-index: 10;
  margin-left: 30rpx;
  margin-right: 30rpx;
  padding-bottom: 50rpx; /* Increased spacing */
  /* 使用 Flex 布局优化垂直排列 */
  display: flex;
  flex-direction: column;
}

.info-card .title-large {
  font-size: 44rpx; /* 稍微调小字号使其更精致 */
  line-height: 1.3;
  color: #1d1d1f;
  margin-bottom: 24rpx !important; /* 强制增加与副标题的间距 */
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.info-card .subtitle-text {
  font-size: 28rpx; /* 增加副标题字号 */
  line-height: 1.6;
  color: #6e6e73; /* 更柔和的灰色 */
  margin-bottom: 40rpx !important;
  font-weight: 400;
}

.avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e5e5ea;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.amount-large {
  font-size: 48rpx;
  font-weight: 700;
  color: #007aff;
}

.original-price {
  font-size: 24rpx;
  color: #8e8e93;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 30rpx; /* Spacing from info above */
}

.apple-tag {
  margin-bottom: 10rpx;
  margin-right: 15rpx; /* Horizontal spacing */
}

/* Segment Control */
.segment-control {
  display: flex;
  justify-content: center;
  border-bottom: 1rpx solid #e5e5ea;
  padding-bottom: 20rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
}

.segment-item {
  position: relative;
  padding: 0 40rpx;
}

.segment-text {
  font-size: 30rpx;
  color: #8e8e93;
  font-weight: 500;
}

.segment-item.active .segment-text {
  color: #000;
  font-weight: 600;
}

.segment-line {
  position: absolute;
  bottom: -22rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #007aff;
  border-radius: 2rpx;
}

/* Tab Content */
.tab-content {
  padding: 0 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.content-block {
  display: block;
  /* width: 100% removed to avoid overflow with padding */
}

.intro-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  text-align: justify;
  display: block; /* Ensure it behaves like a block for text-align */
}

/* Syllabus List */
.chapter-group {
  width: 100%;
}

.chapter-title {
  font-size: 26rpx;
  color: #8e8e93;
  font-weight: 500;
}

.overflow-hidden {
  overflow: hidden;
}

.lesson-item {
  width: 100%;
  background-color: white;
  transition: background-color 0.2s;
}

.hover-bg {
  background-color: #f2f2f7;
}

.icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-blue { background-color: rgba(0, 122, 255, 0.1); }
.bg-green { background-color: rgba(52, 199, 89, 0.1); }

.play-triangle {
  width: 0; 
  height: 0; 
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #007aff;
}

.file-rect {
  width: 24rpx;
  height: 32rpx;
  background-color: #34c759;
  border-radius: 4rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* Locked State */
.locked-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  width: 100%;
}

.lock-icon-bg {
  width: 120rpx;
  height: 120rpx;
  background-color: #f2f2f7;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.icon-lock {
  width: 40rpx;
  height: 50rpx;
  border: 4rpx solid #8e8e93;
  border-bottom: none;
  border-radius: 20rpx 20rpx 0 0;
  position: relative;
  margin-top: -10rpx;
}

.icon-lock::after {
  content: '';
  position: absolute;
  top: 40rpx; /* Below the loop */
  left: -8rpx;
  width: 56rpx;
  height: 40rpx;
  background-color: #8e8e93;
  border-radius: 8rpx;
}

.locked-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.locked-subtitle {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 40rpx;
}

.small-btn {
  width: auto !important;
  min-width: 200rpx !important;
  padding: 0 40rpx !important;
  height: 70rpx !important;
  line-height: 70rpx !important;
  font-size: 28rpx !important;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: rgba(255, 255, 255, 0.95); /* 高透玻璃质感 */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05); /* 极细边框 */
  z-index: 100;
}

.bottom-bar-content {
  padding: 12rpx 32rpx; /* 紧凑的内边距 */
  height: 100rpx; /* 固定高度，更显精致 */
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.align-baseline {
  align-items: baseline;
}

.currency-red {
  font-size: 24rpx;
  color: #ff3b30;
  margin-right: 4rpx;
  font-weight: 600;
}

.amount-red {
  font-size: 44rpx; /* 价格稍微大一点 */
  font-weight: 700;
  color: #ff3b30;
  font-family: -apple-system-monospaced, "SF Mono", Menlo, monospace; /* 数字等宽 */
  letter-spacing: -1rpx;
}

.apple-button {
  margin: 0;
  background-color: #007AFF; /* Apple System Blue */
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx; /* 胶囊圆角 */
  height: 72rpx; /* 精致的高度 (36pt) */
  line-height: 72rpx;
  padding: 0 40rpx;
  min-width: 180rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.apple-button::after {
  border: none;
}

.apple-button[disabled] {
  background-color: #e5e5ea;
  color: #8e8e93;
}

/* 按钮点击态 */
.button-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

/* ========================================
   课程资料包 - Apple 风格设计 (Minimalist)
   ======================================== */

.materials-section {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.materials-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 资料内容列表 */
.content-list-section {
  padding: 32rpx;
}

.content-list-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.content-list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -0.5rpx;
}

.content-list {
  padding-left: 0;
}

.content-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f7;
}

.content-item:last-child {
  border-bottom: none;
}

.item-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.content-item.more .item-text.more-text {
  color: #86868b;
  font-size: 26rpx;
}

/* 分割线 */
.materials-divider {
  height: 1rpx;
  background: #e5e5ea;
  margin: 0 32rpx;
}

/* 链接区域 */
.link-section {
  padding: 24rpx 32rpx;
}

.link-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 24rpx;
  color: #86868b;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.link-input-wrapper {
  display: flex;
  align-items: center;
  background: #F2F2F7;
  border-radius: 16rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  min-height: 80rpx;
}

.link-text {
  flex: 1;
  font-size: 28rpx;
  color: #1d1d1f;
  word-break: break-all;
  line-height: 1.4;
  margin-right: 16rpx;
}

.code-wrapper {
  justify-content: space-between;
}

.code-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: 4rpx;
  font-family: -apple-system-monospaced, "SF Mono", Menlo, monospace;
}

.copy-btn {
  background: #007AFF;
  border-radius: 28rpx;
  padding: 12rpx 32rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.2);
  transition: all 0.2s;
}

.copy-btn-hover {
  background: #0062cc;
  transform: scale(0.96);
}

.copy-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 备注信息 */
.materials-note {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  background: #ffffff;
  margin-top: 0;
  align-items: flex-start;
}

.note-text {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.5;
  flex: 1;
}

/* 课程详情图片 */
.detail-section {
  padding-bottom: 40rpx;
}

.margin-left-small {
  margin-left: 10rpx;
}

.detail-images-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.detail-image {
  width: 100%;
  border-radius: 40rpx; /* Apple style large radius */
  display: block;
  background-color: white; /* Placeholder color */
}

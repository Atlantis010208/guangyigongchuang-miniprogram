/* Scroll Container - Fix bottom scrolling issue */
.scroll-container {
  height: 100vh;
  background-color: #f2f2f7;
  /* 底部栏高度约 124rpx，加上 safe-area，padding-bottom 设为 124rpx */
  padding-bottom: calc(124rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(124rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* Cover Header */
.cover-wrapper {
  position: relative;
  width: 100%;
  height: 750rpx;
}

.cover-swiper {
  width: 100%;
  height: 100%;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(to bottom, transparent, #f2f2f7);
  pointer-events: none; /* 确保不阻挡点击 */
}

/* Info Card */
.info-card {
  margin-top: -30rpx; /* Overlap effect */
  position: relative;
  z-index: 10;
  margin-left: 30rpx;
  margin-right: 30rpx;
  padding-bottom: 50rpx; /* Increased spacing */
  /* 使用 Flex 布局优化垂直排列 */
  display: flex;
  flex-direction: column;
}

.info-card .title-large {
  font-size: 44rpx; /* 稍微调小字号使其更精致 */
  line-height: 1.3;
  color: #1d1d1f;
  margin-bottom: 24rpx !important; /* 强制增加与副标题的间距 */
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.info-card .subtitle-text {
  font-size: 28rpx; /* 增加副标题字号 */
  line-height: 1.6;
  color: #6e6e73; /* 更柔和的灰色 */
  margin-bottom: 40rpx !important;
  font-weight: 400;
}

/* ==========================================================================
   Modal Content Styles (Fix for Truncated Text)
   ========================================================================== */

/* Reset info-card style within modal to avoid conflict with page style */
.modal-body .info-card {
  margin-top: 0;
  margin-left: 0;
  margin-right: 0;
  padding-bottom: 0;
  box-shadow: none;
  background-color: transparent;
  display: block; /* Reset flex if needed */
}

.modal-body .info-row {
  margin-bottom: 32rpx;
}

.modal-body .info-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 16rpx;
  display: block;
}

.modal-body .info-value-box {
  background-color: #f5f5f7; /* Apple System Gray 6 */
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start; /* Align top to handle multi-line text */
  min-height: auto;
}

.modal-body .info-text {
  font-size: 28rpx;
  color: #1d1d1f;
  line-height: 1.6; /* Improve readability and prevent clipping */
  word-break: break-all; /* Ensure long URLs wrap correctly */
  flex: 1;
  margin-right: 24rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.modal-body .info-code {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: 4rpx;
  font-family: -apple-system-monospaced, "SF Mono", Menlo, monospace;
}

.modal-body .copy-icon-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx; /* Visual alignment with text */
}

.modal-body .icon-copy {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #007aff;
  border-radius: 6rpx;
  position: relative;
  background-color: transparent;
}

.modal-body .icon-copy::after {
  content: '';
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #007aff; /* Opacity handled by color */
  border-radius: 6rpx;
  background-color: #f5f5f7; /* Match background to hide underlying line */
  z-index: 1;
}

.modal-body .btn-group {
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.black-btn {
  background-color: #1d1d1f;
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.black-btn:active {
  background-color: #3a3a3c;
  transform: scale(0.98);
}

.full-width {
  width: 100%;
}

.avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e5e5ea;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.amount-large {
  font-size: 48rpx;
  font-weight: 700;
  color: #007aff;
}

.original-price {
  font-size: 24rpx;
  color: #8e8e93;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 30rpx; /* Spacing from info above */
}

.apple-tag {
  margin-bottom: 10rpx;
  margin-right: 15rpx; /* Horizontal spacing */
}

/* Segment Control */
.segment-control {
  display: flex;
  justify-content: center;
  border-bottom: 1rpx solid #e5e5ea;
  padding-bottom: 20rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
}

.segment-item {
  position: relative;
  padding: 0 40rpx;
}

.segment-text {
  font-size: 30rpx;
  color: #8e8e93;
  font-weight: 500;
}

.segment-item.active .segment-text {
  color: #000;
  font-weight: 600;
}

.segment-line {
  position: absolute;
  bottom: -22rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #007aff;
  border-radius: 2rpx;
}

/* Tab Content */
.tab-content {
  padding: 0 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.content-block {
  display: block;
  /* width: 100% removed to avoid overflow with padding */
}

.intro-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  text-align: justify;
  display: block; /* Ensure it behaves like a block for text-align */
}

/* Syllabus List */
.chapter-group {
  width: 100%;
}

.chapter-title {
  display: block;
  font-size: 26rpx;
  color: #1d1d1f;
  font-weight: 600;
  margin-bottom: 24rpx; /* Increased spacing from list */
  margin-left: 32rpx;   /* Align with card content */
  text-transform: uppercase;
  letter-spacing: 2rpx;
  opacity: 1;
}

.overflow-hidden {
  overflow: hidden;
}

/* 课时卡片容器圆角，与课程包卡片一致 */
.chapter-group .apple-card {
  border-radius: 20rpx;
  background-color: white;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.lesson-item {
  width: 110%;
  background-color: white;
  transition: background-color 0.2s;
  padding: 20rpx 32rpx; /* 调整卡片内边距来控制高度 */
  min-height: 100rpx; /* 设置最小高度，确保卡片有统一的基础高度 */
  box-sizing: border-box;
}

/* 确保第一个课时项顶部圆角 */
.lesson-item:first-child {
  border-radius: 20rpx 20rpx 0 0;
}

/* 确保最后一个课时项底部圆角 */
.lesson-item:last-of-type {
  border-radius: 0 0 20rpx 20rpx;
}

/* 如果只有一个课时项，四个角都是圆角 */
.lesson-item:first-child:last-of-type {
  border-radius: 20rpx;
}

.hover-bg {
  background-color: #f2f2f7;
}

.icon-box {
  width: 74rpx; /* 稍微增加尺寸以容纳圆形 */
  height: 74rpx;
  border-radius: 50%; /* 完美圆形 */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0; /* 防止压缩 */
}

.bg-blue { 
  background-color: #eff0f2; /* 苹果风格的高级灰 (System Gray 6 调整版) */
}

.bg-green { 
  background-color: #e8f5e9; /* 保持文件图标的淡绿色，或者也可以统一成灰色 */
}

.play-triangle {
  width: 0; 
  height: 0; 
  border-top: 13rpx solid transparent;
  border-bottom: 13rpx solid transparent;
  border-left: 22rpx solid #1d1d1f; /* 接近黑色的深灰，更有质感 */
  margin-left: 8rpx; /* 视觉居中校正 */
  opacity: 0.9; /* 稍微柔和一点 */
}

.file-rect {
  width: 24rpx;
  height: 32rpx;
  background-color: #34c759;
  border-radius: 4rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* 课时卡片内的标题和时长间距 */
.lesson-item .flex-column .flex-row:last-child {
  margin-top: 4rpx; /* 调整课时名称和时长之间的间距 */
}

/* Locked State */
.locked-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  width: 100%;
}

.lock-icon-bg {
  width: 120rpx;
  height: 120rpx;
  background-color: #f2f2f7;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.icon-lock {
  width: 40rpx;
  height: 50rpx;
  border: 4rpx solid #8e8e93;
  border-bottom: none;
  border-radius: 20rpx 20rpx 0 0;
  position: relative;
  margin-top: -10rpx;
}

.icon-lock::after {
  content: '';
  position: absolute;
  top: 40rpx; /* Below the loop */
  left: -8rpx;
  width: 56rpx;
  height: 40rpx;
  background-color: #8e8e93;
  border-radius: 8rpx;
}

.locked-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.locked-subtitle {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 40rpx;
}

.small-btn {
  width: auto !important;
  min-width: 200rpx !important;
  padding: 0 40rpx !important;
  height: 70rpx !important;
  line-height: 70rpx !important;
  font-size: 28rpx !important;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: rgba(255, 255, 255, 0.95); /* 高透玻璃质感 */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05); /* 极细边框 */
  z-index: 100;
}

.bottom-bar-content {
  padding: 12rpx 32rpx; /* 紧凑的内边距 */
  height: 100rpx; /* 固定高度，更显精致 */
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.align-baseline {
  align-items: baseline;
}

.currency-red {
  font-size: 24rpx;
  color: #ff3b30;
  margin-right: 4rpx;
  font-weight: 600;
}

.amount-red {
  font-size: 44rpx; /* 价格稍微大一点 */
  font-weight: 700;
  color: #ff3b30;
  font-family: -apple-system-monospaced, "SF Mono", Menlo, monospace; /* 数字等宽 */
  letter-spacing: -1rpx;
}

.apple-button {
  margin: 0;
  background-color: #007AFF; /* Apple System Blue */
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx; /* 胶囊圆角 */
  height: 72rpx; /* 精致的高度 (36pt) */
  line-height: 72rpx;
  padding: 0 40rpx;
  min-width: 180rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.apple-button::after {
  border: none;
}

.apple-button[disabled] {
  background-color: #e5e5ea;
  color: #8e8e93;
}

/* 按钮点击态 */
.button-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 学习进度信息 */
.progress-info {
  display: flex;
  flex-direction: row; /* Change to row for left-right layout */
  align-items: baseline; /* Align text baselines */
  gap: 12rpx; /* Space between label and value */
}

.progress-label {
  font-size: 26rpx;
  color: #8e8e93; /* Changed back to Gray */
  font-weight: 500;
}

.progress-value {
  font-size: 32rpx;
  color: #1c1c1e;
  font-weight: 600;
  line-height: 1;
}

/* 课时学习进度状态 */
.lesson-status {
  font-size: 24rpx;
  margin-left: 8rpx;
  font-weight: 500;
}

.lesson-status.completed {
  color: #34c759; /* Apple Green - 已完成 */
}

.lesson-status.learning {
  color: #8e8e93; /* Apple Orange - 学习中 */
}

.lesson-status.not-started {
  color: #8e8e93; /* Apple Gray - 未开始 */
}

/* 辅助样式 */
.align-center {
  align-items: center;
}

/* 课程详情图片 */
.detail-section {
  padding-bottom: 40rpx;
}

.margin-left-small {
  margin-left: 10rpx;
}

.margin-left-medium {
  margin-left: 36rpx; /* 增加图标与文字的间距 */
}

.detail-images-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.detail-image {
  width: 100%;
  border-radius: 40rpx; /* Apple style large radius */
  display: block;
  background-color: white; /* Placeholder color */
}

/* ==========================================================================
   Courseware Bar (New Design)
   ========================================================================== */
.courseware-section {
  margin-top: 40rpx;
  padding: 0 0;
}

.courseware-bar {
  background: #ffffff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.courseware-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.icon-file-wrapper {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background-color: #f2f2f7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-file-doc {
  width: 24rpx;
  height: 32rpx;
  border: 3rpx solid #333;
  border-radius: 4rpx;
  position: relative;
}

.icon-file-doc::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 4rpx;
  width: 12rpx;
  height: 2rpx;
  background-color: #333;
  box-shadow: 0 6rpx 0 #333, 0 12rpx 0 #333;
}

.courseware-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1d1d1f;
}

.download-btn {
  background-color: #007AFF;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600; /* Slightly bolder to match apple-button */
  padding: 14rpx 34rpx; /* Slightly larger touch area */
  border-radius: 36rpx; /* Match apple-button rounded style */
  margin-left: 20rpx;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.download-btn:active {
  background-color: #0056cc;
  transform: scale(0.95);
  opacity: 0.9;
}

/* ==========================================================================
   Download Modal
   ========================================================================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-container {
  width: 620rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 48rpx 0 0 0;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
}

/* 分段控制器 */
.drive-tabs {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.drive-tab-bg {
  background-color: #f2f2f7;
  border-radius: 16rpx;
  height: 72rpx;
  display: flex;
  position: relative;
  padding: 4rpx;
}

.drive-tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #8e8e93;
  font-weight: 500;
  position: relative;
  z-index: 2;
  transition: all 0.3s;
}

.drive-tab-item.active {
  color: #000;
  font-weight: 600;
}

.drive-tab-slider {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: calc(50% - 4rpx);
  height: calc(100% - 8rpx);
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.3s cubic-bezier(0.19, 1, 0.22, 1);
  z-index: 1;
}

.slide-right {
  transform: translateX(100%);
}

.modal-body {
  min-height: 480rpx;
  transition: all 0.3s;
}

.link-section {
  padding: 0 40rpx 32rpx 40rpx;
}

/* 移除旧的 section-title */
.section-title {
  display: none;
}

.modal-header {
  padding: 0 48rpx;
  display: flex;
  justify-content: center; /* 标题居中 */
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.5rpx;
}

.modal-desc {
  padding: 0 48rpx;
  font-size: 28rpx;
  color: #86868b;
  line-height: 1.4;
  display: block;
  margin-bottom: 48rpx;
  text-align: center;
}

/* 网盘链接区域 */
.link-section {
  padding: 24rpx 40rpx 32rpx 40rpx;
}

.link-section:first-child {
  padding-top: 0;
}

.section-title {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: 1rpx;
}

.link-card {
  background-color: #f5f5f7; /* Apple System Gray 6 */
  border-radius: 24rpx;
  padding: 30rpx;
}

.margin-top {
  margin-top: 24rpx;
}

.link-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.content-box {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  min-height: 40rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(0, 0, 0, 0.04); /* 微弱边框增加质感 */

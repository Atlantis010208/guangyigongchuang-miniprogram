}

.action-btn {
  background-color: #007AFF;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx; /* Apple Standard Button Height */
  line-height: 88rpx;
  border-radius: 18rpx;
  text-align: center;
  border: none;
  width: 100%;
  padding: 0;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.btn-hover {
  background-color: #0062cc;
  opacity: 0.9;
  transform: scale(0.99);
}

/* 国际版按钮样式（绿色主题） */
.intl-btn {
  background-color: #34C759;
}

.btn-hover-intl {
  background-color: #2ca048;
  opacity: 0.9;
  transform: scale(0.99);
}

.modal-footer {
  border-top: 1rpx solid #e5e5ea;
  padding: 32rpx 0;
  text-align: center;
  background-color: rgba(255, 255, 255, 0.9);
}

.modal-footer text {
  font-size: 32rpx;
  color: #000;
  font-weight: 400;
}

/* 更多课程更新提示 */
.more-updates-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 0 40rpx;
  width: 100%;
}

.more-updates-tip text {
  font-size: 20rpx;
  color: #8e8e93; /* Apple Gray */
  letter-spacing: 2rpx;
  font-weight: 400;
}

/* ==========================================================================
   Locked State Styles (未购买状态样式)
   ========================================================================== */

/* 锁定状态的课程包 */
.courseware-bar.locked {
  opacity: 0.6;
}

/* 禁用状态的下载按钮 */
.download-btn.disabled {
  background-color: #e5e5ea;
  color: #8e8e93;
  cursor: not-allowed;
  pointer-events: none;
}

.lock-with-text {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 小锁图标（下载按钮） */
.mini-lock-icon {
  width: 16rpx;
  height: 20rpx;
  border: 2rpx solid #8e8e93;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
  position: relative;
}

.mini-lock-icon::after {
  content: '';
  position: absolute;
  top: 16rpx;
  left: -4rpx;
  width: 24rpx;
  height: 16rpx;
  background-color: #8e8e93;
  border-radius: 4rpx;
}

/* 锁定状态的课时 */
.lesson-item.locked {
  opacity: 0.5;
  pointer-events: auto; /* 保留点击能力，用于显示购买提示 */
}

.lesson-item.locked .icon-box {
  opacity: 0.6;
}

.lesson-item.locked .title-small {
  color: #8e8e93;
}

/* 课时标题旁的锁图标 */
.lesson-lock-icon {
  width: 20rpx;
  height: 24rpx;
  border: 3rpx solid #8e8e93;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
  position: relative;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.lesson-lock-icon::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: -6rpx;
  width: 32rpx;
  height: 20rpx;
  background-color: #8e8e93;
  border-radius: 6rpx;
}

/* 购买提示区域 */
.purchase-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  margin: 40rpx 0;
  background: linear-gradient(135deg, #f5f7fa 0%, #f2f2f7 100%);
  border-radius: 40rpx;
  border: 2rpx dashed #d1d1d6;
}

.hint-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #007aff 0%, #0056cc 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 122, 255, 0.3);
}

.hint-lock-icon {
  width: 32rpx;
  height: 40rpx;
  border: 4rpx solid #ffffff;
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
  position: relative;
  margin-top: -8rpx;
}

.hint-lock-icon::after {
  content: '';
  position: absolute;
  top: 32rpx;
  left: -8rpx;
  width: 48rpx;
  height: 32rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
}

.hint-title {
  font-size: 32rpx;
  color: #1d1d1f;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-align: center;
}

.hint-subtitle {
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.5;
}

.hint-purchase-btn {
  background: linear-gradient(135deg, #007aff 0%, #0056cc 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 60rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(0, 122, 255, 0.3);
  transition: all 0.3s;
}

.hint-purchase-btn::after {
  border: none;
}

.hint-purchase-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

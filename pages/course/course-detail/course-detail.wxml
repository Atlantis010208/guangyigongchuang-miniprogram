<wxs module="anim" src="./course-detail.wxs"></wxs>
<scroll-view 
  scroll-y 
  class="scroll-container"
  enhanced="{{true}}"
  bounces="{{true}}"
  show-scrollbar="{{false}}"
  bindscroll="{{anim.onScroll}}"
  bindtouchstart="{{anim.touchStart}}"
  bindtouchmove="{{anim.touchMove}}"
  bindtouchend="{{anim.touchEnd}}"
>
  <!-- Cover Image Header -->
  <view class="cover-wrapper">
    <swiper 
      class="cover-swiper" 
      indicator-dots="{{course.swiperImages.length > 1}}" 
      autoplay="{{true}}" 
      circular="{{true}}" 
      interval="5000" 
      duration="500"
      indicator-color="rgba(255, 255, 255, 0.4)"
      indicator-active-color="#ffffff"
    >
      <block wx:for="{{course.swiperImages}}" wx:key="*this">
        <swiper-item>
          <image src="{{item}}" mode="aspectFill" class="cover-image" bindtap="onPreviewCover" data-current="{{item}}"></image>
        </swiper-item>
      </block>
    </swiper>
    <view class="cover-gradient"></view>
  </view>

  <!-- Info Section -->
  <view class="info-card apple-card padding-medium shadow-medium slide-up" wx:if="{{!isPurchased}}">
    <text class="title-large">{{course.title}}</text>
    <text class="subtitle-text">{{course.subtitle}}</text>
    
    <view class="flex-row flex-between margin-bottom-medium">
      <view class="price-box">
        <text class="currency">¥</text>
        <text class="amount-large">{{course.price}}</text>
        <text class="original-price" wx:if="{{course.originalPrice}}">¥{{course.originalPrice}}</text>
      </view>
    </view>

    <view class="tags-row">
      <text class="apple-tag margin-right-small" wx:for="{{course.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- Segment Control -->
  <view class="segment-control margin-top-medium margin-bottom-medium">
    <view class="segment-item {{activeTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-index="{{0}}">
      <text class="segment-text">简介</text>
      <view class="segment-line" wx:if="{{activeTab === 0}}"></view>
    </view>
    <view class="segment-item {{activeTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-index="{{1}}">
      <text class="segment-text">课程章节</text>
      <view class="segment-line" wx:if="{{activeTab === 1}}"></view>
    </view>
  </view>

  <!-- Tab Content: Intro -->
  <view class="tab-content" wx:if="{{activeTab === 0}}">
    <view class="content-block apple-card padding-medium">
      <text class="title-medium margin-bottom-small" style="display: block;">课程介绍</text>
      <text class="intro-text">{{course.description}}</text>
    </view>

    <!-- 课程详情内容（图片展示） -->
    <view class="detail-section margin-top-medium" wx:if="{{course.detailImages && course.detailImages.length > 0}}">
      <text class="title-medium margin-bottom-medium margin-left-small">课程详情</text>
      <view class="detail-images-list">
        <block wx:for="{{course.detailImages}}" wx:key="*this">
          <image src="{{item}}" mode="widthFix" class="detail-image shadow-medium" lazy-load></image>
        </block>
      </view>
    </view>
  </view>

  <!-- Tab Content: Syllabus -->
  <view class="tab-content" wx:if="{{activeTab === 1}}">
    <!-- Courseware Bar -->
    <view class="courseware-section margin-bottom-medium" wx:if="{{course.driveLink}}">
      <view class="courseware-bar shadow-sm">
        <view class="courseware-left">
           <view class="icon-file-wrapper">
             <view class="icon-file-doc"></view>
           </view>
           <text class="courseware-text">课程包</text>
        </view>
        <view class="download-btn" bindtap="onDownloadTap">
          <text>下载</text>
        </view>
      </view>
    </view>

    <!-- 视频课程章节 -->
    <block wx:for="{{course.chapters}}" wx:key="title">
      <view class="chapter-group margin-bottom-medium" wx:if="{{item.title !== '课程资料包'}}">
        <text class="chapter-title">{{item.title}}</text>
        <view class="apple-card overflow-hidden">
          <block wx:for="{{item.lessons}}" wx:key="id" wx:for-item="lesson" wx:for-index="idx">
            <view class="lesson-item flex-row padding-medium" hover-class="hover-bg" bindtap="onLessonTap" data-type="{{lesson.type}}" data-title="{{lesson.title}}" data-id="{{lesson.id}}" data-free="{{lesson.isFree}}">
              <view class="icon-box {{lesson.type === 'video' ? 'bg-blue' : 'bg-green'}}">
                 <!-- Simple Shapes for Icons -->
                 <view class="play-triangle" wx:if="{{lesson.type === 'video'}}"></view>
                 <view class="file-rect" wx:if="{{lesson.type === 'file'}}"></view>
              </view>
              <view class="flex-column flex-1 margin-left-medium">
                <view class="flex-row align-center">
                  <text class="title-small">{{lesson.title}}</text>
                </view>
                <view class="flex-row align-center margin-top-small">
                  <text class="caption-text" wx:if="{{lesson.type === 'video'}}">{{lesson.duration}} {{lesson.isFree ? '· 试看' : ''}}</text>
                  <text class="caption-text" wx:if="{{lesson.type === 'file'}}">{{lesson.format}} · {{lesson.size}}</text>
                  <!-- 学习进度状态（仅已购买） -->
                  <block wx:if="{{lesson.type === 'video' && isPurchased}}">
                    <text class="lesson-status completed" wx:if="{{lesson.isCompleted}}">· 已学习</text>
                    <text class="lesson-status learning" wx:elif="{{lesson.progress > 0}}">· 已学习 {{lesson.progress}}%</text>
                    <text class="lesson-status not-started" wx:else>· 未学习</text>
                  </block>
                </view>
              </view>
              <view class="action-icon">
                <text class="arrow-right" wx:if="{{lesson.type === 'video'}}">▶</text>
                <text class="arrow-down" wx:if="{{lesson.type === 'file'}}">↓</text>
              </view>
            </view>
            <view class="divider thick" style="margin: 0 40rpx;" wx:if="{{idx < item.lessons.length - 1}}"></view>
          </block>
        </view>
      </view>
    </block>

    <!-- 课程更新提示 -->
    <view class="more-updates-tip">
      <text>更多课程更新中。。。</text>
    </view>
  </view>

</scroll-view>

<!-- Download Modal -->
<view class="modal-mask {{showDownloadModal ? 'show' : ''}}" wx:if="{{showDownloadModal}}" bindtap="onCloseModal" catchtouchmove="true">
  <view class="modal-container" catchtap="stopProp">
    <view class="modal-header">
      <text class="modal-title">获取课程资料</text>
    </view>

    <!-- 分段控制器 (Segmented Control) -->
    <view class="drive-tabs" wx:if="{{course.driveLinkIntl}}">
      <view class="drive-tab-bg">
        <view class="drive-tab-slider {{activeDriveTab === 1 ? 'slide-right' : ''}}"></view>
        <view class="drive-tab-item {{activeDriveTab === 0 ? 'active' : ''}}" bindtap="onDriveTabChange" data-index="0">
          <text>国内版</text>
        </view>
        <view class="drive-tab-item {{activeDriveTab === 1 ? 'active' : ''}}" bindtap="onDriveTabChange" data-index="1">
          <text>国际版</text>
        </view>
      </view>
    </view>
    
    <scroll-view scroll-y class="modal-body">
      <!-- 国内版网盘 -->
      <view class="link-section fade-in" wx:if="{{activeDriveTab === 0 || !course.driveLinkIntl}}">
        <view class="info-card">
          <!-- 链接行 -->
          <view class="info-row">
            <text class="info-label">网盘链接</text>
            <view class="info-value-box" bindtap="onCopyLink" data-text="{{course.driveLink}}">
              <text class="info-text">{{course.driveLink || '暂无链接'}}</text>
              <view class="copy-icon-btn">
                <view class="icon-copy"></view>
              </view>
            </view>
          </view>
          
          <!-- 提取码行 -->
          <view class="info-row" wx:if="{{course.drivePassword}}">
            <text class="info-label">提取码</text>
            <view class="info-value-box" bindtap="onCopyPassword" data-text="{{course.drivePassword}}">
              <text class="info-code">{{course.drivePassword}}</text>
              <view class="copy-icon-btn">
                <view class="icon-copy"></view>
              </view>
            </view>
          </view>
        </view>

        <view class="btn-group">
          <button class="black-btn full-width" bindtap="onCopyAll">一键复制链接和提取码</button>
        </view>
      </view>

      <!-- 国际版网盘 -->
      <view class="link-section fade-in" wx:if="{{activeDriveTab === 1 && course.driveLinkIntl}}">
        <view class="info-card">
          <!-- 链接行 -->
          <view class="info-row">
            <text class="info-label">网盘链接 (TeraBox)</text>
            <view class="info-value-box" bindtap="onCopyLinkIntl" data-text="{{course.driveLinkIntl}}">
              <text class="info-text">{{course.driveLinkIntl}}</text>
              <view class="copy-icon-btn">
                <view class="icon-copy"></view>
              </view>
            </view>
          </view>
          
          <!-- 提取码行 -->
          <view class="info-row" wx:if="{{course.drivePasswordIntl}}">
            <text class="info-label">提取码 (Extraction Code)</text>
            <view class="info-value-box" bindtap="onCopyPasswordIntl" data-text="{{course.drivePasswordIntl}}">
              <text class="info-code">{{course.drivePasswordIntl}}</text>
              <view class="copy-icon-btn">
                <view class="icon-copy"></view>
              </view>
            </view>
          </view>
        </view>

        <view class="btn-group">
          <button class="black-btn full-width" bindtap="onCopyAllIntl">一键复制链接和提取码</button>
        </view>
      </view>
    </scroll-view>

    <view class="modal-footer" bindtap="onCloseModal">
      <text>关闭</text>
    </view>
  </view>
</view>

<!-- Fixed Bottom Bar -->
<view class="bottom-bar shadow-large">
  <view class="bottom-bar-content flex-row flex-between">
    <block wx:if="{{!isPurchased}}">
      <view class="flex-column">
        <text class="caption-text">总价</text>
        <view class="flex-row align-baseline">
          <text class="currency-red">¥</text>
          <text class="amount-red">{{course.price}}</text>
        </view>
      </view>
      <button class="apple-button" hover-class="button-hover" bindtap="onPurchase">立即购买</button>
    </block>
    <block wx:else>
      <view class="flex-column progress-info">
        <text class="progress-label">学习进度</text>
        <text class="progress-value">{{progress}}%</text>
      </view>
      <button class="apple-button" hover-class="button-hover" bindtap="onStartLearning">立即观看</button>
    </block>
  </view>
</view>

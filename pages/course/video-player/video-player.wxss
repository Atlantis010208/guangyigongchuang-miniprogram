/**
 * 视频播放页样式
 * 使用原生控制条
 */

.container-dark {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #000000;
  overflow: hidden;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FF5500;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

/* Error */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40rpx;
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #FF3B30;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.error-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.retry-btn {
  background-color: #FF5500;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}

/* Video Wrapper */
.video-wrapper {
  position: relative;
  width: 100%;
  height: 420rpx;
  background-color: #000000;
  flex-shrink: 0;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 100%;
  background-color: #000000;
}

/* 缓冲提示层 */
.buffering-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 10;
  pointer-events: none;
}

.buffering-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FF5500;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.buffering-text {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 500;
}

.buffering-hint {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
  text-align: center;
  padding: 0 40rpx;
}

/* 视频占位符 */
.video-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #000000;
}

.placeholder-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

/* Playlist Section */
.playlist-section {
  flex: 1;
  height: 0; /* 关键：配合 flex:1 让 scroll-view 能正确滚动 */
  background-color: #1C1C1E;
  padding: 30rpx;
  box-sizing: border-box;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.section-subtitle {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.chapter-group {
  margin-bottom: 30rpx;
}

.chapter-group:last-child {
  margin-bottom: 60rpx; /* 最后一组增加底部间距，确保能滚动到底部 */
}

.chapter-title {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 0;
  display: block;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.lesson-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.lesson-item.active {
  background-color: rgba(255, 85, 0, 0.1);
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
}

.lesson-status {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.status-icon {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
}

.status-icon.playing {
  background-color: #FF5500;
  box-shadow: 0 0 10rpx rgba(255, 85, 0, 0.5);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.7; }
}

.lesson-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.lesson-title {
  color: rgba(255, 255, 255, 0.9);
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.lesson-title.active-text {
  color: #FF5500;
  font-weight: 500;
}

.lesson-duration {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

/* ===== 右上角更多按钮（三个点） ===== */
.more-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  z-index: 20;
}

.more-btn .dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  margin: 0 4rpx;
}

/* ===== 底部播放选项弹窗 ===== */
.options-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 998;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.options-mask.show {
  opacity: 1;
  visibility: visible;
}

.options-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F5F5F5;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.options-panel.show {
  transform: translateY(0);
}

.options-header {
  padding: 30rpx 40rpx 20rpx;
  text-align: center;
}

.options-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.options-content {
  padding: 0 30rpx 40rpx;
}

.option-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
}

.option-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.speed-options {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.speed-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background-color: transparent;
  transition: all 0.2s;
}

.speed-item text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.speed-item.active text {
  color: #FF3B30;
  font-weight: 600;
}
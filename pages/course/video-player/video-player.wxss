/**
 * 视频播放页样式
 * 使用原生控制条
 */

.container-dark {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #000000;
  overflow: hidden;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

/* Error */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40rpx;
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #FF3B30;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.error-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.retry-btn {
  background-color: #007aff;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}

/* Video Wrapper */
.video-wrapper {
  position: relative;
  width: 100%;
  height: 420rpx;
  background-color: #000000;
  flex-shrink: 0;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 100%;
  background-color: #000000;
}

/* 缓冲提示层 */
.buffering-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 10;
  pointer-events: none;
}

.buffering-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #007aff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.buffering-text {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 500;
}

.buffering-hint {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
  text-align: center;
  padding: 0 40rpx;
}

/* 视频占位符 */
.video-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #000000;
}

.placeholder-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

/* Playlist Section */
.playlist-section {
  flex: 1;
  height: 0; /* 关键：配合 flex:1 让 scroll-view 能正确滚动 */
  background-color: #1C1C1E;
  padding: 30rpx;
  box-sizing: border-box;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

/* 🆕 左右布局：当前播放 + 观看人数 */
.section-subtitle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-subtitle {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 🆕 观看人数样式 */
.viewer-info {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.viewer-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.viewer-count {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  white-space: nowrap;
}

/* 已学习人数 */
.learned-count {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  display: block;
  margin-top: 16rpx;
}

.chapter-group {
  margin-bottom: 30rpx;
}

.chapter-group:last-child {
  margin-bottom: 60rpx; /* 最后一组增加底部间距，确保能滚动到底部 */
}

.chapter-title {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 0;
  display: block;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.lesson-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.lesson-item.active {
  background-color: rgba(0, 122, 255, 0.1);
  margin: 0 0rpx;
  padding: 24rpx 20rpx;
  border-radius: 80rpx;
}

.lesson-status {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.status-icon {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
}

.status-icon.playing {
  background-color: #007aff;
  box-shadow: 0 0 10rpx rgba(0, 122, 255, 0.5);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.7; }
}

.lesson-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-right: 20rpx; /* 防止文字太长紧贴按钮 */
}

.lesson-title {
  color: rgba(255, 255, 255, 0.9);
  font-size: 30rpx;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.lesson-title.active-text {
  color: #007aff;
  font-weight: 500;
}

.lesson-duration {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

/* 课程列表元数据容器 */
.lesson-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

/* 课时学习进度状态 */
.lesson-progress {
  font-size: 24rpx;
  margin-left: 8rpx;
  font-weight: 500;
}

.lesson-progress.completed {
  color: #34c759; /* Apple Green - 已完成 */
}

.lesson-progress.learning {
  color: rgba(255, 255, 255, 0.4); /* Apple Orange - 学习中 */
}

.lesson-progress.not-started {
  color: rgba(255, 255, 255, 0.4); /* Gray - 未开始 */
}

/* 课后作业按钮 - 苹果风格 */
.homework-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  background-color: #1C1C1E; /* 深灰/黑色背景，比纯黑更有质感 */
  border: 1rpx solid rgba(255, 255, 255, 0.15); /* 微弱的白色边框 */
  border-radius: 28rpx;
  flex-shrink: 0;
  margin-left: 10rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.homework-btn:active {
  background-color: #2C2C2E; /* 点击时稍微变亮 */
  transform: scale(0.96);
}

.homework-text {
  font-size: 24rpx;
  color: #FFFFFF; /* 白色文字 */
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ===== 右上角更多按钮（三个点） ===== */
.more-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  z-index: 20;
}

.more-btn .dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  margin: 0 4rpx;
}

/* ===== 底部播放选项弹窗 ===== */
.options-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 998;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.options-mask.show {
  opacity: 1;
  visibility: visible;
}

.options-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F5F5F5;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.options-panel.show {
  transform: translateY(0);
}

.options-header {
  padding: 30rpx 40rpx 20rpx;
  text-align: center;
}

.options-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.options-content {
  padding: 0 30rpx 40rpx;
}

.option-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
}

.option-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.speed-options {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.speed-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background-color: transparent;
  transition: all 0.2s;
}

.speed-item text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.speed-item.active text {
  color: #007aff;
  font-weight: 600;
}

/* 🆕 清晰度选项样式 */
.quality-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 24rpx;
}

.quality-item {
  flex: 1;
  min-width: 180rpx;
  height: 72rpx; /* 稍微增加高度 */
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1c1c1e; /* 黑色文字 */
  transition: all 0.2s;
  font-weight: 500;
}

.quality-item.active {
  background: #FFFFFF; /* 白色背景 */
  color: #007aff;      /* 蓝色文字 */
  font-weight: 600;
  
}

.quality-item:active {
  opacity: 0.7;
  transform: scale(0.98);
}
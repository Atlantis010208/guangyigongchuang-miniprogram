<view class="page-container">
  
  <view class="main-content">
    <!-- Header with Search -->
    <view class="header-section">
      <view class="search-container">
        <view class="search-bar">
          <van-icon name="search" size="20px" color="#94a3b8" />
          <input 
            class="search-input" 
            placeholder="搜索项目名称/客户..." 
            placeholder-style="color: #94a3b8;" 
            value="{{searchQuery}}"
            bindinput="onSearchInput"
          />
        </view>
      </view>

      <!-- Category Tabs -->
      <view class="tabs-scroll">
        <view class="tabs-list">
          <view class="tab-item {{currentTab === index ? 'active' : ''}}" 
                wx:for="{{tabs}}" 
                wx:key="index"
                data-index="{{index}}"
                bindtap="switchTab">
            <text class="tab-text">{{item.name}}</text>
            <view class="tab-indicator" wx:if="{{currentTab === index}}"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- Project List -->
    <scroll-view class="project-list-scroll" scroll-y enable-back-to-top bindscrolltolower="onReachBottom" bindrefresherrefresh="onPullDownRefresh" refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}">
      <view class="project-list">
        
        <!-- Empty State -->
        <view class="empty-state" wx:if="{{filteredProjects.length === 0 && !loading}}">
          <van-icon name="orders-o" size="64px" color="#cbd5e1" />
          <text class="empty-text">暂无相关项目</text>
        </view>
        
        <block wx:for="{{filteredProjects}}" wx:key="_id">
          <view class="project-card {{item.status === 'done' ? 'card-completed' : ''}}">
            <view class="card-header">
              <view class="card-title-group">
                <view class="card-title">{{item.title}}</view>
                <view class="card-subtitle">客户: {{item.clientInfo ? item.clientInfo.nickname : '未知'}} | {{item.space || '灯光设计'}}</view>
              </view>
              <!-- 动态状态标签 -->
              <view class="status-tag {{item.status === 'done' ? 'tag-green' : (item.status === 'pending' ? 'tag-amber' : 'tag-blue')}}">
                {{item.statusText}}
              </view>
            </view>

            <view class="stage-info">
              <van-icon name="{{item.status === 'done' ? 'passed' : (item.status === 'pending' ? 'comment-o' : 'edit')}}" 
                        size="16px" 
                        color="{{item.status === 'done' ? '#22c55e' : (item.status === 'pending' ? '#f59e0b' : '#135bec')}}" />
              <text class="stage-text">{{item.currentStepText}}</text>
            </view>

            <view class="progress-bar">
              <view class="progress-inner {{item.status === 'done' ? 'bg-green' : (item.status === 'pending' ? 'bg-amber' : 'bg-blue')}}" 
                    style="width: {{item.progress}}%"></view>
            </view>

            <view class="card-footer">
              <text class="update-time">{{item.timeText}}</text>
              <view class="detail-btn" bindtap="goToDetail" data-id="{{item._id}}">
                <text>查看详情</text>
                <van-icon name="arrow" size="16px" />
              </view>
            </view>
          </view>
        </block>

        <view class="no-more" wx:if="{{!hasMore && filteredProjects.length > 0}}">
          <text>没有更多项目了</text>
        </view>
        <view class="loading-state" wx:if="{{loading && filteredProjects.length > 0}}">
          <van-loading size="24px" type="spinner" color="#94a3b8">加载中...</van-loading>
        </view>
        
      </view>
    </scroll-view>
  </view>
</view>

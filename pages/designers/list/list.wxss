/* pages/designers/list/list.wxss */
page {
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #0f172a;
}

.container {
  min-height: 100vh;
  padding: 0 0 40rpx 0;
  align-items: stretch;
  background-color: #f5f5f7;
}

.main-content {
  padding-top: 20rpx;
}

/* 需求摘要卡片 */
.demand-section {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.demand-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.demand-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.demand-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.demand-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
}

.demand-desc {
  font-size: 28rpx;
  color: #475569;
}

/* 列表标题 */
.list-header {
  padding: 32rpx 40rpx 16rpx;
}

.list-header-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #94a3b8;
}

/* 设计师列表 */
.designer-list {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding: 0 32rpx;
}

.designer-card {
  background-color: #ffffff;
  border: 2rpx solid #f1f5f9;
  border-radius: 48rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.designer-card.selected {
  border: 4rpx solid #000000;
}

.selected-badge {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #000000;
  color: #ffffff;
  padding: 8rpx 32rpx;
  border-bottom-left-radius: 32rpx;
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.card-top {
  display: flex;
  gap: 32rpx;
}

.avatar-container {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f1f5f9;
  border: 2rpx solid #f1f5f9;
}

.check-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background-color: #000000;
  color: #ffffff;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.check-icon {
  font-size: 20rpx;
  font-weight: bold;
}

.info-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #0f172a;
  margin-bottom: 4rpx;
}

.title {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stat-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #FFD700;
}

.rating-val {
  font-size: 24rpx;
  font-weight: bold;
  color: #0f172a;
}

.divider {
  color: #e2e8f0;
  font-size: 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #64748b;
}

.card-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.btn-confirm {
  flex: 1;
  background-color: #000000;
  color: #ffffff;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-confirm:active {
  opacity: 0.8;
}

.btn-detail {
  padding: 0 48rpx;
  height: 96rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #0f172a;
}

.btn-detail:active {
  background-color: #f8fafc;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f1f5f9;
  border-top-color: #0f172a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #64748b;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.empty-description {
  font-size: 28rpx;
  color: #64748b;
}


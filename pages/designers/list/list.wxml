<!-- pages/designers/list/list.wxml -->
<view class="container">
  <view class="main-content">
    <!-- Demand Summary Card -->
    <view class="demand-section" wx:if="{{preselectedRequest}}">
      <view class="demand-card">
        <view class="demand-info">
          <text class="demand-label">当前项目需求</text>
          <text class="demand-title">{{preselectedRequest.title || '照明设计需求'}}</text>
          <text class="demand-desc">{{preselectedRequest.area ? preselectedRequest.area + 'm²' : '未知面积'}} · {{preselectedRequest.budget || '预算待定'}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <view class="spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 列表区域 -->
    <block wx:elif="{{designers.length > 0}}">
      <!-- List Section Header -->
      <view class="list-header">
        <text class="list-header-title">推荐灯光设计师 ({{designers.length}})</text>
      </view>

      <!-- Designer List -->
      <view class="designer-list">
        <view class="designer-card {{item._id === selectedDesignerId ? 'selected' : ''}}" wx:for="{{designers}}" wx:key="_id">
          
          <!-- 选中角标 -->
          <view class="selected-badge" wx:if="{{item._id === selectedDesignerId}}">
            已选定
          </view>

          <view class="card-top">
            <view class="avatar-container">
              <image class="avatar" src="{{item.avatar || '/images/个人中心.png'}}" mode="aspectFill" />
              <view class="check-badge" wx:if="{{item._id === selectedDesignerId}}">
                <text class="check-icon">✓</text>
              </view>
            </view>
            
            <view class="info-container">
              <text class="name">{{item.name}}</text>
              <text class="title">{{item.title || '资深灯光设计师 / 光乙合伙人'}}</text>
              
              <view class="stats-row">
                <view class="stat-rating">
                  <text class="star">★</text>
                  <text class="rating-val">{{item.rating || '4.9'}}</text>
                </view>
                <text class="divider">|</text>
                <text class="stat-text">{{item.experience || 12}}年经验</text>
                <text class="divider">|</text>
                <text class="stat-text">{{item.completionRate || '98%'}} 完成率</text>
              </view>
            </view>
          </view>

          <view class="card-actions">
            <view class="btn-confirm" bindtap="onConfirmSelect" data-id="{{item._id}}" data-name="{{item.name}}">邀请接单</view>
            <view class="btn-detail" bindtap="onDesignerTap" data-id="{{item._id}}">查看详情</view>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <view class="empty-icon">🔍</view>
      <text class="empty-title">未找到推荐的设计师</text>
      <text class="empty-description">请尝试调整需求或稍后再试</text>
    </view>
  </view>
</view>

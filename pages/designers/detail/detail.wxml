<!-- 设计师详情页 -->
<view class="page-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 设计师详情 -->
  <view wx:elif="{{designer}}" class="detail-content">

    <!-- Hero Section: 居中头像 + 姓名 + 职称 + 地点 -->
    <view class="hero-section">
      <view class="avatar-wrapper">
        <image class="hero-avatar" src="{{designer.avatar || '/images/个人中心.png'}}" mode="aspectFill" />
        <view class="verified-badge" wx:if="{{designer.hasCalcExp}}">
          <text class="verified-icon">✓</text>
        </view>
      </view>
      <text class="hero-name">{{designer.name}}</text>
      <text class="hero-title" wx:if="{{designer.title || designer.experience}}">{{designer.title || '灯光设计师'}}{{designer.experience ? ' · ' + designer.experience + '年经验' : ''}}</text>
      <view class="hero-location" wx:if="{{designer.location}}">
        <text class="location-icon">📍</text>
        <text class="location-text">{{designer.location}}</text>
      </view>
    </view>

    <!-- Stats Row: 三栏统计 -->
    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-value">{{designer.projects || 0}}</text>
        <text class="stat-label">完成项目</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{designer.rating || 0}}</text>
        <text class="stat-label">平均评分</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{designer.responseRate || '99%'}}</text>
        <text class="stat-label">响应率</text>
      </view>
    </view>

    <!-- 设计师简介 -->
    <view wx:if="{{designer.bio}}" class="bio-section">
      <text class="section-title">设计师简介</text>
      <text class="bio-text">{{designer.bio}}</text>
    </view>

    <!-- 作品集 -->
    <view class="portfolio-section">
      <view class="section-header">
        <text class="section-title">作品集</text>
        <text class="section-action" wx:if="{{designer.portfolioImages && designer.portfolioImages.length > 2}}">查看全部</text>
      </view>
      <view wx:if="{{designer.portfolioImages && designer.portfolioImages.length > 0}}" class="portfolio-grid">
        <view class="portfolio-item" wx:for="{{designer.portfolioImages}}" wx:key="index" wx:if="{{index < 4}}" bindtap="previewImage" data-url="{{item}}" data-urls="{{designer.portfolioImages}}">
          <image class="portfolio-image" src="{{item}}" mode="aspectFill" />
          <text class="portfolio-name" wx:if="{{designer.portfolioNames[index]}}">{{designer.portfolioNames[index]}}</text>
        </view>
      </view>
      <view wx:else class="empty-content">
        <text class="empty-text">暂无作品展示</text>
      </view>
    </view>

    <!-- 用户评价（评价功能尚未实现，暂时隐藏）
    <view class="reviews-section">
      <view class="section-header">
        <text class="section-title">用户评价</text>
        <view class="rating-summary" wx:if="{{designer.rating}}">
          <text class="rating-star">★</text>
          <text class="rating-value">{{designer.rating}}</text>
        </view>
      </view>

      <view wx:if="{{designer.reviews && designer.reviews.length > 0}}" class="review-list">
        <view class="review-card" wx:for="{{designer.reviews}}" wx:key="date">
          <view class="review-top">
            <view class="review-user-info">
              <view class="review-avatar-placeholder">
                <text class="review-avatar-text">{{item.user[0]}}</text>
              </view>
              <view class="review-user-meta">
                <text class="review-user-name">{{item.user}}</text>
                <text class="review-date">{{item.date}}</text>
              </view>
            </view>
            <view class="review-stars">
              <text class="review-star" wx:for="{{5}}" wx:for-item="starIdx" wx:key="starIdx">{{starIdx < item.rating ? '★' : '☆'}}</text>
            </view>
          </view>
          <text class="review-text">{{item.content}}</text>
        </view>
      </view>
      <view wx:else class="empty-content">
        <text class="empty-text">暂无用户评价</text>
      </view>
    </view>
    -->

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </view>

  <!-- 未找到设计师 -->
  <view wx:else class="empty-state">
    <text class="empty-text">未找到该设计师</text>
  </view>

  <!-- 底部操作栏 -->
  <view wx:if="{{!loading && designer}}" class="action-bar">
    <view class="action-icon-btn" bindtap="onCollect">
      <text class="action-icon-text">♡</text>
      <text class="action-icon-label">收藏</text>
    </view>
    <view class="action-icon-btn" bindtap="onShareTap">
      <text class="action-icon-text">↗</text>
      <text class="action-icon-label">分享</text>
    </view>
    <view class="action-main-btn" bindtap="onInvite">
      <text>邀请抢单</text>
    </view>
  </view>
</view>

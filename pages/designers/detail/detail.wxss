/* 设计师详情页 */
page {
  background-color: #ffffff;
  --foreground: 240 10% 3.9%;
  --muted-foreground: 240 3.8% 46.1%;
  --border: 240 5.9% 90%;
  --primary: 240 5.9% 10%;
  --primary-foreground: 0 0% 98%;
  --card: 0 0% 100%;
}

.page-container {
  min-height: 100vh;
  padding: 0;
  align-items: stretch;
  background-color: #ffffff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f1f5f9;
  border-top-color: #0f172a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #64748b;
}

/* 详情内容 */
.detail-content {
  padding-bottom: 200rpx;
}

/* ===== Hero Section ===== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 48rpx 32rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.hero-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  background-color: #f1f5f9;
}

.verified-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: #000000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.verified-icon {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.hero-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.hero-location {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.location-icon {
  font-size: 24rpx;
}

.location-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ===== Stats Row ===== */
.stats-row {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  background-color: #f8fafc;
  border: 2rpx solid #f1f5f9;
  border-radius: 24rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f172a;
}

.stat-label {
  font-size: 20rpx;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

/* ===== Bio Section ===== */
.bio-section {
  padding: 0 48rpx;
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.bio-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

/* ===== Portfolio Section ===== */
.portfolio-section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 48rpx;
  margin-bottom: 24rpx;
}

.section-action {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.portfolio-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0 32rpx;
}

.portfolio-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.portfolio-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background-color: #e2e8f0;
}

.portfolio-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #0f172a;
  padding: 0 8rpx;
}

/* ===== Reviews Section ===== */
.reviews-section {
  padding: 0 48rpx;
  margin-bottom: 48rpx;
}

.rating-summary {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  font-size: 28rpx;
  color: #0f172a;
}

.rating-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #0f172a;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-card {
  background-color: #f8fafc;
  border: 2rpx solid #f1f5f9;
  border-radius: 32rpx;
  padding: 32rpx;
}

.review-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.review-user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.review-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.review-avatar-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #64748b;
}

.review-user-meta {
  display: flex;
  flex-direction: column;
}

.review-user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #0f172a;
}

.review-date {
  font-size: 20rpx;
  color: #94a3b8;
}

.review-stars {
  display: flex;
}

.review-star {
  font-size: 24rpx;
  color: #f59e0b;
}

.review-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}

/* ===== Empty States ===== */
.empty-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: #94a3b8;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 80rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #64748b;
}

/* ===== Bottom Spacer ===== */
.bottom-spacer {
  height: 40rpx;
}

/* ===== Bottom Action Bar ===== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-top: 2rpx solid #f1f5f9;
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 32rpx;
  z-index: 100;
}

.action-icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.action-icon-text {
  font-size: 40rpx;
  color: #475569;
}

.action-icon-label {
  font-size: 20rpx;
  color: #475569;
  font-weight: 500;
}

.action-icon-btn:active {
  opacity: 0.6;
}

.action-main-btn {
  flex: 1;
  background-color: #000000;
  color: #ffffff;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.action-main-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 预约弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: hsl(var(--card));
  border-radius: 48rpx 48rpx 0 0;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 48rpx;
  border-bottom: 1rpx solid hsl(var(--border));
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: hsl(var(--foreground));
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: hsl(var(--muted-foreground));
  border-radius: 50%;
}

.modal-close:active {
  background: hsl(var(--muted));
}

.modal-body {
  padding: 32rpx 48rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: hsl(var(--foreground));
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.form-label-hint {
  font-size: 24rpx;
  font-weight: 400;
  color: #999;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  background: hsl(var(--background));
  border: 1rpx solid hsl(var(--border));
  border-radius: 16rpx;
  transition: all 0.2s;
  height: 60rpx;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: flex;
  align-items: center;
  height: 100%;
}

.picker-text.placeholder {
  color: #999;
}

.picker-text.selected {
  color: hsl(var(--foreground));
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
  flex-shrink: 0;
  line-height: 60rpx;
}

/* 输入框包装器（带后缀） */
.input-wrapper {
  display: flex;
  align-items: center;
  background: hsl(var(--background));
  border: 1rpx solid hsl(var(--border));
  border-radius: 16rpx;
  padding-right: 32rpx;
  transition: all 0.2s;
  height: 60rpx;
}

.input-wrapper .form-input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 0 32rpx;
  height: 100%;
  line-height: 60rpx;
  display: flex;
  align-items: center;
}

.input-suffix {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.form-input {
  width: 100%;
  height: 60rpx;
  padding: 0 32rpx;
  background: hsl(var(--background));
  border: 1rpx solid hsl(var(--border));
  border-radius: 16rpx;
  font-size: 28rpx;
  color: hsl(var(--foreground));
  box-sizing: border-box;
  transition: all 0.2s;
  line-height: normal;
  display: flex;
  align-items: center;
}

.form-input:focus {
  border-color: hsl(var(--ring));
}

/* placeholder 样式 */
.input-placeholder {
  color: #999 !important;
  font-size: 28rpx;
  line-height: 50rpx;
}

.textarea-placeholder {
  color: #999;
  font-size: 26rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 32rpx;
  background: hsl(var(--background));
  border: 1rpx solid hsl(var(--border));
  border-radius: 16rpx;
  font-size: 28rpx;
  color: hsl(var(--foreground));
  box-sizing: border-box;
  line-height: 1.6;
}

.modal-footer {
  padding: 32rpx 48rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid hsl(var(--border));
}

.submit-btn {
  width: 100%;
  text-align: center;
  padding: 28rpx 0;
  background: hsl(var(--primary));
  border-radius: 24rpx;
  font-size: 32rpx;
  color: hsl(var(--primary-foreground));
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 加载提示 */
.loading-hint {
  text-align: center;
  padding: 40rpx 0;
  color: hsl(var(--muted-foreground));
  font-size: 26rpx;
}

/* 自动填充信息展示 */
.auto-fill-info {
  background: hsl(var(--muted) / 0.5);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid hsl(var(--border) / 0.5);
}

.info-label {
  font-size: 26rpx;
  color: hsl(var(--muted-foreground));
}

.info-value {
  font-size: 26rpx;
  color: hsl(var(--foreground));
  font-weight: 500;
}

/* 无需求提示 */
.no-request-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: hsl(var(--muted) / 0.3);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.hint-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.hint-text {
  font-size: 28rpx;
  color: hsl(var(--foreground));
  font-weight: 500;
  margin-bottom: 8rpx;
}

.hint-sub {
  font-size: 24rpx;
  color: hsl(var(--muted-foreground));
}

/* 表单分隔线 */
.form-divider {
  height: 1rpx;
  background: hsl(var(--border));
  margin: 32rpx 0;
}

/* 必填标记 */
.form-label-required {
  color: #ef4444;
  font-size: 24rpx;
}

/* 购物袋页面样式 */
.page {
  background-color: #f2f2f7;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 页面头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx 20rpx;
}

.page-title {
    margin-right: auto; /* 关键：将标题推到左侧 */
    font-size: 56rpx;   /* 调大标题字号 */
    font-weight: bold;  /* 示例加粗效果 */
}

.edit-btn {
  padding: 10rpx;
}

.edit-text {
  font-size: 28rpx;
  color: #007aff;
}

/* 筛选器样式：参考产品页配件列表的轻量样式 */
.filters { padding: 0 30rpx 16rpx; }
.filter-scroll { white-space: nowrap; }
.filter-chip { display: inline-block; padding: 14rpx 26rpx; margin-right: 16rpx; border-radius: 999rpx; background:#f7f7f9; color:#1c1c1e; font-size: 26rpx; }
.filter-chip.active { background:#000; color:#fff; }

/* 购物车内容 */
.cart-content {
  padding: 0 30rpx;
}

/* 商品列表 */
.cart-items {
  background-color: white;
  border-radius: 50rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  box-shadow: none;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  padding: 35rpx;
  border-bottom: 1rpx solid #f2f2f7;
  position: relative;
}

.cart-item-no-btn {
  /* 已被移除 padding-bottom 逻辑覆盖，可以保留空类或删除 */
}

.cart-item:last-child {
  border-bottom: none;
}

/* 选择框 */
.checkbox {
  margin-right: 20rpx;
  margin-top: 10rpx;
}

.checkbox-icon {
  width: 40rpx;
  height: 40rpx;
}

.checkbox-empty {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #c7c7cc;
  border-radius: 50%;
}

/* 商品内容 */
.item-content {
  display: flex;
  flex: 1;
}

.item-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 30rpx;
  margin-right: 30rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.progress { display:flex; gap: 24rpx; margin-top: 16rpx; align-items:center; flex-wrap:wrap; }
.step { display:flex; align-items:center; gap: 10rpx; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; background:#d1d1d6; }
.dot.done { background:#34c759; }
.step-text { font-size: 22rpx; color:#8e8e93; }
/* 方案订单操作按钮（卡片内的小按钮） */
.req-actions{ display:flex; gap: 12rpx; margin-top: 12rpx; }
.req-btn{ padding: 12rpx 18rpx; border: 1rpx solid #000; border-radius: 999rpx; background:#fff; }
.req-btn-text{ font-size: 22rpx; color:#000; }

.item-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #000;
  line-height: 1.3;
}
.tag-cancel{margin-left:12rpx;padding:4rpx 12rpx;border-radius:999rpx;background:#ffecec;color:#ff3b30;font-size:20rpx}
.tag-status{margin-left:12rpx;padding:4rpx 12rpx;border-radius:999rpx;background:#e6f0ff;color:#007aff;font-size:20rpx}
.tag-priority{margin-left:12rpx;padding:4rpx 12rpx;border-radius:999rpx;background:#000;color:#d4af37;font-size:20rpx;border:1rpx solid #d4af37}

.item-specs {
  font-size: 24rpx;
  color: #8e8e93;
  margin-bottom: 0;
  line-height: 1.4;
}

.item-price {
  font-size: 26rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 20rpx;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  border: 1rpx solid #e5e5ea;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: white;
}

.quantity-btn.disabled {
  opacity: 0.3;
}

.quantity-btn-text {
  font-size: 32rpx;
  color: #007aff;
  font-weight: 500;
}

.quantity-text {
  font-size: 28rpx;
  color: #000;
  margin: 0 30rpx;
  min-width: 60rpx;
  text-align: center;
}

/* 编辑操作 */
.edit-actions {
  display: flex;
  gap: 15rpx;
  margin-top: auto;
}

.request-delete{position:absolute; right:20rpx; bottom:20rpx; width:44rpx; height:44rpx; border-radius:50%; background:#e0e0e0; display:flex; align-items:center; justify-content:center}
.request-delete-text{color:#fff; font-size:30rpx; line-height:1}

.action-btn {
  padding: 15rpx 25rpx;
  border: 1rpx solid #007aff;
  border-radius: 50rpx;
  background-color: white;
}

.action-btn.delete {
  border-color: #ff3b30;
}

.action-text {
  font-size: 24rpx;
  color: #007aff;
}

.action-btn.delete .action-text {
  color: #ff3b30;
}

/* 稍后购买区域 */
.saved-section {
  background-color: white;
  border-radius: 50rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  box-shadow: none;
}

.saved-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.saved-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #000;
}

.toggle-icon {
  font-size: 24rpx;
  color: #8e8e93;
}

.saved-items {
  padding: 0 35rpx 35rpx;
}

.saved-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f2f7;
}

.saved-item:last-child {
  border-bottom: none;
}

.saved-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  margin-right: 30rpx;
}

.saved-info {
  flex: 1;
}

.saved-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 5rpx;
}

.saved-specs {
  font-size: 22rpx;
  color: #8e8e93;
  margin-bottom: 5rpx;
}

.saved-price {
  font-size: 24rpx;
  font-weight: 500;
  color: #000;
}

.saved-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.saved-btn {
  padding: 12rpx 20rpx;
  border: 1rpx solid #007aff;
  border-radius: 50rpx;
  background-color: white;
}

.saved-btn.delete {
  border-color: #ff3b30;
}

.saved-btn-text {
  font-size: 22rpx;
  color: #007aff;
}

.saved-btn.delete .saved-btn-text {
  color: #ff3b30;
}

/* 推荐商品 */
.recommendations {
  margin-bottom: 30rpx;
}

.recommendations-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  display: block;
  margin-bottom: 25rpx;
}

.recommendations-scroll {
  white-space: nowrap;
}

.recommendations-container {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.recommendation-item {
  background-color: white;
  border-radius: 50rpx;
  padding: 30rpx;
  width: 300rpx;
  box-shadow: none;
}

.recommendation-image {
  width: 100%;
  height: 200rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

.recommendation-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #000;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.recommendation-price {
  font-size: 24rpx;
  font-weight: 500;
  color: #007aff;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 220rpx 30rpx 100rpx;
  text-align: center;
}

.empty-icon {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 50rpx;
  opacity: 0.35;
}

.empty-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #000;
  margin-bottom: 20rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #8e8e93;
  margin-bottom: 0;
  line-height: 1.6;
}
.empty-subtitle.center { text-align: center; }

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  padding: 25rpx 30rpx;
  padding-bottom: calc(25rpx + env(safe-area-inset-bottom));
  box-shadow: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-section {
  flex: 1;
}

.total-label {
  font-size: 26rpx;
  color: #8e8e93;
}

.total-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-left: 10rpx;
}

.checkout-btn {
  background-color: #007aff;
  border-radius: 50rpx;
  padding: 25rpx 50rpx;
  margin-left: 40rpx;
}

.checkout-btn.disabled {
  opacity: 0.5;
}

.checkout-text {
  font-size: 28rpx;
  font-weight: 500;
  color: white;
}

/* 编辑模式底部栏 */
.edit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  padding: 25rpx 30rpx;
  padding-bottom: calc(25rpx + env(safe-area-inset-bottom));
  box-shadow: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.selected-count {
  flex: 1;
}

.selected-text {
  font-size: 26rpx;
  color: #8e8e93;
}

.edit-actions-bar {
  display: flex;
  gap: 15rpx;
}

.edit-action-btn {
  padding: 20rpx 40rpx;
  border: 1rpx solid #007aff;
  border-radius: 50rpx;
  background-color: white;
}

.edit-action-btn.delete {
  border-color: #ff3b30;
}

.edit-action-text {
  font-size: 26rpx;
  color: #007aff;
}

.edit-action-btn.delete .edit-action-text {
  color: #ff3b30;
}

/* 方案订单内联操作按钮 */
.inline-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: nowrap;
  align-items: center;
}

/* 🔥 设计师状态行 - 跟在文字下方，靠右 */
.designer-status-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: auto; /* 推到最底部 */
  padding-top: 16rpx;
}

.mini-btn {
  padding: 12rpx 24rpx !important;
  border: 1rpx solid #000 !important;
  border-radius: 999rpx !important;
  background: #fff !important;
  font-size: 22rpx !important;
  color: #000 !important;
  line-height: 1.2 !important;
}

.mini-btn::after {
  border: none;
}

/* 设计师筛选按钮 - 突出显示 */
.designer-btn {
  background: #007AFF !important;
  border-color: #007AFF !important;
  color: #fff !important;
}

/* 已分配设计师信息样式 */
.designer-assigned {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border: 1rpx solid #0ea5e9;
  border-radius: 999rpx;
  font-size: 24rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.designer-label {
  color: #64748b;
}

.designer-name {
  color: #0284c7;
  font-weight: 500;
}

/* 🔥 待确认状态样式 */
.designer-pending {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border: 1rpx solid #f59e0b;
  border-radius: 999rpx;
  font-size: 24rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.designer-status-pending {
  color: #d97706;
  font-weight: 500;
}

/* 🔥 选配服务多行显示 */
.item-specs-multi {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.specs-line {
  font-size: 24rpx;
  color: #666;
}

.specs-line-sub {
  font-size: 22rpx;
  color: #999;
}

/* 未登录提示样式 */
.login-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
}

.login-prompt-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.login-prompt-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.login-prompt-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 16rpx;
}

.login-prompt-desc {
  font-size: 28rpx;
  color: #86868b;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.login-prompt-btn {
  width: 320rpx;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-prompt-btn:active {
  background: #0066d6;
}

.login-prompt-tip {
  font-size: 24rpx;
  color: #86868b;
  margin-top: 24rpx;
}

/* ========== 商城订单卡片样式 ========== */
/* 覆盖默认的 .cart-items 样式，移除容器背景，使卡片间距透出页面背景 */
.mall-order-list {
  background-color: transparent;
  border-radius: 0;
  overflow: visible;
}

.mall-order-card {
  flex-direction: column;
  align-items: stretch; /* 覆盖 .cart-item 的 flex-start，让子元素撑满宽度 */
  padding: 0;
  padding-bottom: 0;
  margin-bottom: 30rpx; /* 增加卡片间距 */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05); /* 增加阴影 */
  border-radius: 24rpx; /* 统一圆角 */
  overflow: hidden;
}

.mall-order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start; /* 支持多行 */
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background-color: #fff;
}

.mall-order-title-wrap {
  flex: 1;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column; /* 垂直排列 */
}

.mall-order-title {
  font-size: 28rpx;
  font-weight: 600; /* 加粗标题 */
  color: #1d1d1f;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.mall-order-time {
  font-size: 24rpx;
  color: #8e8e93;
}

.mall-order-status-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  height: 40rpx; /* 与标题行高度对齐 */
  margin-left: auto; /* 靠右对齐 */
}

.mall-order-status {
  font-size: 26rpx;
  font-weight: 500;
  text-align: right; /* 确保文字靠右 */
}

/* 订单状态颜色 */
.mall-order-status.status-pending { color: #ff9500; }
.mall-order-status.status-paid { color: #007aff; }
.mall-order-status.status-shipped { color: #5856d6; }
.mall-order-status.status-completed { color: #34c759; }
.mall-order-status.status-closed { color: #8e8e93; }
.mall-order-status.status-refunded { color: #ff3b30; }

.mall-order-content {
  display: flex;
  padding: 30rpx;
  background-color: #fff;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx; /* 统一图片圆角 */
  margin-right: 24rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.mall-order-card .item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between; /* 上下对齐 */
  height: 160rpx; /* 与图片高度一致 */
}

.item-specs {
  font-size: 28rpx;
  color: #1d1d1f;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2; /* 最多显示2行 */
  overflow: hidden;
  line-height: 1.4;
}

.item-quantity {
  font-size: 24rpx;
  color: #8e8e93;
  margin-bottom: auto;
}

.item-price {
  font-size: 30rpx; /* 加大价格字号 */
  font-weight: 600;
  color: #1d1d1f;
}

.mall-order-footer {
  display: flex;
  justify-content: flex-end; /* 底部内容全部靠右 */
  align-items: center;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
  background: #fff; /* 改为白色背景 */
}

.mall-order-actions {
  display: flex;
  gap: 20rpx; /* 增加按钮间距 */
  align-items: center;
}

/* 统一按钮样式 */
.mini-btn {
  margin: 0 !important;
  font-size: 26rpx !important;
  height: 60rpx !important;
  line-height: 58rpx !important; /* 减去边框高度 */
  padding: 0 30rpx !important;
  border-radius: 30rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* 去支付按钮 - 醒目样式 */
.pay-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3b30 100%) !important;
  border: none !important;
  color: #fff !important;
  font-weight: 600 !important;
  box-shadow: 0 4rpx 10rpx rgba(255, 59, 48, 0.3);
}

.pay-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 订单详情按钮 */
.detail-btn {
  background: #fff !important;
  border: 1rpx solid #d1d1d6 !important;
  color: #1d1d1f !important;
}

.detail-btn:active {
  background: #f2f2f7 !important;
}

/* 删除按钮样式优化 */
.request-delete {
  position: absolute;
  top: 24rpx;
  right: 30rpx;
  width: 40rpx;
  height: 40rpx;
  background: transparent;
  color: #c7c7cc;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

/* 只有当订单已取消/关闭时，删除按钮才显示，但这会和状态标签冲突 */
/* 建议将删除按钮移到底部操作区，或者仅在左滑时显示，这里先保持在卡片内但不覆盖状态 */

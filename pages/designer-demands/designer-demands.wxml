<view class="page-container">
  
  <view class="main-content">
    <!-- Category Scroll -->
    <view class="sticky-header">
      <scroll-view class="category-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}" enhanced="{{true}}" bounces="{{true}}">
        <view class="category-list">
          <view class="category-btn {{currentCategory === index ? 'active' : ''}}" 
                wx:for="{{categories}}" 
                wx:key="index"
                data-index="{{index}}"
                bindtap="switchCategory">
            {{item}}
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 新需求提示条 -->
    <view class="new-tip" wx:if="{{showNewTip}}" bindtap="onTapNewTip">
      <van-icon name="bell" size="14px" color="#2563EB" />
      <text class="new-tip-text">有 {{newCount}} 条新需求，点击刷新</text>
    </view>

    <!-- Demand List -->
    <view class="demand-list">
      <block wx:for="{{demands}}" wx:key="_id">
        <view class="card">
          <view class="card-header">
            <view>
              <view class="tags-group" wx:if="{{item.tagText || item.timeText}}">
                <view class="tag-{{item.tagType}}" wx:if="{{item.tagText}}">{{item.tagText}}</view>
                <view class="time-text">{{item.timeText}}</view>
              </view>
              <view class="card-title">{{item.title}}</view>
              <view class="card-subtitle">
                <van-icon name="points" size="14px" />
                {{item.service}}
              </view>
              <view class="card-owner" wx:if="{{item.ownerName}}">业主：{{item.ownerName}}</view>
            </view>
            <view class="card-icon">
              <!-- 根据空间类型动态渲染图标 -->
              <van-icon name="{{item.space === '住宅' ? 'wap-home-o' : (item.space === '商铺' ? 'shop-o' : 'hotel-o')}}" size="24px" color="#9CA3AF" />
            </view>
          </view>

          <view class="stats-grid">
            <view class="stat-box">
              <text class="stat-label">预算</text>
              <text class="stat-value">{{item.budget}}</text>
            </view>
            <view class="stat-box">
              <text class="stat-label">面积</text>
              <text class="stat-value">{{item.area}}m²</text>
            </view>
            <view class="stat-box">
              <text class="stat-label">进度</text>
              <text class="stat-value">{{item.stage}}</text>
            </view>
          </view>

          <view class="action-group">
            <button class="btn-secondary" hover-class="btn-secondary-hover" bindtap="onViewDetail" data-id="{{item._id}}">查看详情</button>
            <button class="btn-primary" hover-class="btn-primary-hover" bindtap="onAcceptInList" data-id="{{item._id}}" data-title="{{item.title || (item.space + '灯光设计需求')}}">立即接单</button>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>

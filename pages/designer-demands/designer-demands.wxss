/* CSS Variables representing Tailwind classes */
page {
  --primary: #007AFF;
  --background-light: #F5F5F7;
  --surface-light: #FFFFFF;
  --text-primary-light: #1D1D1F;
  --text-secondary-light: #86868B;
  
  background-color: var(--background-light);
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: var(--text-primary-light);
  -webkit-font-smoothing: antialiased;
}

.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.main-content {
  padding: 0 20px 40px 20px; /* px-5 pb-10 */
  max-width: 448px; /* max-w-md */
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

/* Category Scroll (Sticky Header) */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 40;
  background-color: var(--background-light);
  padding-top: 12px; /* py-3 */
  padding-bottom: 12px;
  margin-left: -20px; /* -mx-5 */
  width: calc(100% + 40px);
  transition: all 0.3s;
}

.category-scroll {
  padding: 0 20px; /* px-5 */
  box-sizing: border-box;
}

.category-list {
  display: flex;
  column-gap: 12px; /* space-x-3 */
}

.category-btn {
  background-color: var(--surface-light);
  color: var(--text-primary-light);
  border: 1px solid #E5E7EB; /* border-gray-200 */
  padding: 8px 20px; /* px-5 py-2 */
  border-radius: 9999px; /* rounded-full */
  font-size: 14px; /* text-sm */
  font-weight: 500; /* font-medium */
  white-space: nowrap;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* shadow-sm */
  transition: all 0.2s;
}

.category-btn.active {
  background-color: #000000; /* bg-black */
  color: #FFFFFF;
  border-color: transparent;
}

/* Demand List */
.demand-list {
  display: flex;
  flex-direction: column;
  row-gap: 20px; /* space-y-5 */
  margin-top: 8px; /* mt-2 */
}

.card {
  background-color: var(--surface-light);
  border-radius: 20px; /* rounded-2xl */
  padding: 20px; /* p-5 */
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04); /* shadow-apple */
  border: 1px solid transparent;
  transition: all 0.2s;
}

.card:active {
  transform: scale(0.99);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px; /* mb-4 */
}

.tags-group {
  display: flex;
  align-items: center;
  gap: 8px; /* gap-2 */
  margin-bottom: 8px; /* mb-2 */
}

.tag-blue, .tag-purple, .tag-gray, .tag-green {
  display: inline-block;
  padding: 2px 10px; /* px-2.5 py-0.5 */
  border-radius: 6px; /* rounded-md */
  font-size: 12px; /* text-xs */
  font-weight: 600; /* font-semibold */
  text-transform: uppercase;
  letter-spacing: 0.025em; /* tracking-wide */
}

.tag-blue {
  background-color: #EFF6FF; /* bg-blue-50 */
  color: #2563EB; /* text-blue-600 */
}

.tag-purple {
  background-color: #FAF5FF; /* bg-purple-50 */
  color: #9333EA; /* text-purple-600 */
}

.tag-gray {
  background-color: #F3F4F6; /* bg-gray-100 */
  color: #4B5563; /* text-gray-600 */
}

.tag-green {
  background-color: #F0FDF4; /* bg-green-50 */
  color: #16A34A; /* text-green-600 */
}

.time-text {
  font-size: 12px; /* text-xs */
  color: var(--text-secondary-light);
}

.card-title {
  font-size: 19px; /* text-[19px] */
  font-weight: 700; /* font-bold */
  line-height: 1.25; /* leading-tight */
  color: var(--text-primary-light);
}

.card-subtitle {
  color: var(--text-secondary-light);
  font-size: 14px; /* text-sm */
  margin-top: 4px; /* mt-1 */
  display: flex;
  align-items: center;
}

.card-subtitle van-icon {
  margin-right: 4px; /* mr-1 */
}

.card-icon {
  height: 40px; /* h-10 */
  width: 40px; /* w-10 */
  border-radius: 9999px; /* rounded-full */
  background-color: #F9FAFB; /* bg-gray-50 */
  border: 1px solid #F3F4F6; /* border-gray-100 */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px; /* gap-3 */
  margin-bottom: 24px; /* mb-6 */
}

.stat-box {
  background-color: #F9FAFB; /* bg-gray-50 */
  border-radius: 12px; /* rounded-xl */
  padding: 12px; /* p-3 */
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 12px; /* text-xs */
  color: var(--text-secondary-light);
  margin-bottom: 4px; /* mb-1 */
}

.stat-value {
  display: block;
  font-weight: 700; /* font-bold */
  color: var(--text-primary-light);
  font-size: 14px; /* text-sm */
}

/* Action Buttons */
.action-group {
  display: flex;
  column-gap: 12px; /* space-x-3 */
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 12px 0; /* py-3 */
  border-radius: 12px; /* rounded-xl */
  font-size: 14px; /* text-sm */
  font-weight: 600; /* font-semibold */
  line-height: 1.5;
  text-align: center;
  border: none;
  transition: background-color 0.2s;
}

.btn-secondary::after, .btn-primary::after {
  display: none;
}

.btn-secondary {
  color: var(--text-primary-light);
  background-color: #F3F4F6; /* bg-gray-100 */
}

.btn-secondary-hover {
  background-color: #E5E7EB; /* hover:bg-gray-200 */
}

.btn-primary {
  color: #FFFFFF;
  background-color: #000000; /* bg-black */
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); /* shadow-lg */
}

.btn-primary-hover {
  background-color: #111827; /* hover:bg-gray-900 */
}

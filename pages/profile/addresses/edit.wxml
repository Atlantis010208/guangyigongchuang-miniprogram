<view class="page">
  <scroll-view class="scroll" scroll-y>
    <!-- 智能识别区域 -->
    <view class="smart-parse-box">
      <textarea class="smart-parse-input" placeholder="复制地址，帮你快速填写" placeholder-class="smart-parse-ph" value="{{parseText}}" bindinput="onParseInput"></textarea>
      <view class="smart-parse-actions">
        <view class="smart-parse-btn" bindtap="onRecognize">{{parseText ? '立即识别' : '粘贴并识别'}}</view>
      </view>
    </view>

    <view class="form-list">
      <!-- 收货人 -->
      <view class="form-item {{!form.name ? 'align-top' : ''}}">
        <view class="item-label {{!form.name ? 'mt-4' : ''}}">收货人<text class="required">*</text></view>
        <view class="item-content column">
          <input class="input" placeholder="姓名" placeholder-class="ph-color" value="{{form.name}}" bindinput="onInput" data-field="name" maxlength="25" />
          <view class="hint-text" wx:if="{{!form.name}}">请填写，不超过25字</view>
        </view>
        <view class="item-right {{!form.name ? 'mt-4' : ''}}" bindtap="onChooseContact">
          <image class="action-icon" src="/images/通讯录.png" mode="aspectFit"></image>
        </view>
      </view>

      <!-- 联系电话 -->
      <view class="form-item">
        <view class="item-label">联系电话<text class="required">*</text></view>
        <view class="item-content">
          <text class="prefix">+86</text>
          <input class="input" placeholder="手机号" placeholder-class="ph-color" value="{{form.phone}}" bindinput="onInput" data-field="phone" type="number" />
        </view>
      </view>

      <!-- 所在地区 -->
      <picker class="picker-cell" mode="region" value="{{form.region}}" bindchange="onRegionChange">
        <view class="form-item">
          <view class="item-label">所在地区<text class="required">*</text></view>
          <view class="item-content">
            <view class="picker-text {{regionText ? '' : 'ph-color'}}">{{ regionText || '省、市、区、街道' }}</view>
          </view>
        </view>
      </picker>

      <!-- 详细地址 -->
      <view class="form-item align-top">
        <view class="item-label mt-4">详细地址<text class="required">*</text></view>
        <view class="item-content">
          <textarea class="textarea" placeholder="社区、门牌号等" placeholder-class="ph-color" value="{{form.detail}}" bindinput="onInput" data-field="detail" auto-height="{{true}}" />
        </view>
        <view class="item-right mt-4" catchtap="openLocationPicker">
          <image class="action-icon" src="/images/定位-位置.png" mode="aspectFit"></image>
        </view>
      </view>

      <!-- 设为默认地址 -->
      <view class="form-item border-none mt-20">
        <view class="item-label" style="width: auto; flex: 1;">设为默认地址</view>
        <view class="item-right">
          <switch class="default-switch" checked="{{form.isDefault}}" bindchange="onDefaultChange" color="#007aff" />
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer">
    <button class="btn btn-save" bindtap="onSave">保存地址</button>
  </view>
</view>




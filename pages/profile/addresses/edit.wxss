.page { background:#ffffff; min-height:100vh; padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); display:flex; flex-direction:column; }
.scroll { flex:1; }

/* 智能识别区域 */
.smart-parse-box { 
  display: flex; 
  flex-direction: column;
  padding: 24rpx; 
  margin: 30rpx 40rpx; 
  background: #f7f7f7; 
  border-radius: 20rpx; 
}
.smart-parse-input { 
  width: 100%;
  height: 120rpx; 
  font-size: 26rpx; 
  color: #333; 
  line-height: 1.5;
}
.smart-parse-ph { 
  color: #b2b2b2; 
}
.smart-parse-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}
.smart-parse-btn { 
  background: #ffffff; 
  border: 1rpx solid #e0e0e0; 
  border-radius: 30rpx; 
  padding: 10rpx 24rpx; 
  font-size: 24rpx; 
  color: #333; 
  font-weight: 500;
}

/* 表单列表 */
.form-list { 
  padding: 0 40rpx; 
}

/* 表单项 */
.form-item { 
  display: flex; 
  align-items: center; 
  padding: 30rpx 0; 
  border-bottom: 1rpx solid #f5f5f5; 
  min-height: 48rpx;
}
.form-item.align-top {
  align-items: flex-start;
}
.form-item.border-none {
  border-bottom: none;
}
.mt-20 {
  margin-top: 20rpx;
}
.mt-4 {
  margin-top: 4rpx;
}

/* 标签 */
.item-label { 
  width: 160rpx; 
  font-size: 30rpx; 
  color: #333; 
  font-weight: 400; 
  display: flex;
}
.required { 
  color: #ff2442; 
  margin-left: 4rpx; 
  font-size: 28rpx;
}

/* 内容区 */
.item-content { 
  flex: 1; 
  display: flex; 
  align-items: center; 
}
.item-content.column {
  flex-direction: column;
  align-items: flex-start;
}
.prefix { 
  font-size: 30rpx; 
  color: #333; 
  margin-right: 20rpx; 
}
.input { 
  flex: 1; 
  font-size: 30rpx; 
  color: #333; 
  width: 100%;
}
.ph-color { 
  color: #cccccc; 
}

/* 提示文字 */
.hint-text {
  font-size: 24rpx;
  color: #f5a623;
  margin-top: 10rpx;
}

/* 地区选择 */
.picker-cell { 
  display: block; 
  width: 100%; 
}
.picker-text { 
  font-size: 30rpx; 
  color: #333; 
}

/* 多行文本 */
.textarea { 
  width: 100%; 
  min-height: 80rpx; 
  font-size: 30rpx; 
  color: #333; 
  line-height: 1.4;
  padding: 0;
  margin: 0;
}

/* 右侧操作按钮 */
.item-right { 
  padding-left: 20rpx; 
  display: flex; 
  align-items: center; 
  justify-content: center;
}
.action-icon { 
  width: 40rpx; 
  height: 40rpx; 
  opacity: 0.5;
}

/* 默认地址开关 */
.default-switch { 
  transform: scale(0.8);
  transform-origin: right center;
}

/* 底部保存按钮 */
.footer { 
  position:fixed; 
  left:0; 
  right:0; 
  bottom:0; 
  padding: 20rpx 40rpx calc(40rpx + env(safe-area-inset-bottom)); 
  background: #ffffff; 
  z-index: 2000; 
}
.btn-save { 
  background: #007aff; 
  color: #ffffff; 
  border: none; 
  border-radius: 44rpx; 
  padding: 24rpx; 
  font-size: 32rpx; 
  font-weight: 500;
  line-height: 1.5;
}



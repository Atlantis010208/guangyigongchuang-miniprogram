<scroll-view class="page" scroll-y>
  <view class="header">
    <text class="title">送货地址</text>
    <view class="header-actions">
      <!-- TODO: chooseAddress 接口暂未开通，后续开放时取消注释
      <button class="wx-addr-btn" bindtap="getWxAddress">
        <image class="wx-icon-img" src="/images/微信.png" mode="aspectFit"></image> 微信地址
      </button>
      -->
      <button class="add-btn" bindtap="addAddress">
        <text style="margin-right: 4rpx; font-size: 32rpx; line-height: 1;">+</text> 新增地址
      </button>
    </view>
  </view>

  <!-- 地址列表 -->
  <view wx:if="{{addresses.length > 0}}" class="address-list">
    <view wx:for="{{addresses}}" wx:key="id" class="address-card" bindtap="onSelectAddress" data-id="{{item.id}}">
      <!-- 顶部右上角删除图标 -->
      <view class="delete-icon" catchtap="deleteAddress" data-id="{{item.id}}">×</view>
      
      <view class="address-header">
        <view class="contact-info">
          <text class="name">{{item.name}}</text>
          <text class="phone">{{item.phone}}</text>
          <view wx:if="{{item.isDefault}}" class="default-tag">默认</view>
        </view>
      </view>
      
      <view class="address-detail">
        <text class="address-text">{{item.full || item.detail || item.address}}</text>
      </view>

      <view class="address-actions">
        <button class="btn btn-ghost" catchtap="onCopy" data-id="{{item.id}}">复制</button>
        <button wx:if="{{!item.isDefault}}" class="btn btn-default" catchtap="setDefault" data-id="{{item.id}}">设为默认</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="empty-icon-placeholder" style="font-size: 80rpx; margin-bottom: 20rpx;">📍</view>
    <text class="empty-text">暂无送货地址</text>
    <button class="btn-primary" bindtap="addAddress">添加地址</button>
  </view>
</scroll-view>

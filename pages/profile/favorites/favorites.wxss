.fav-page { background:#F5F5F7; min-height:100vh; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.header { padding: 40rpx 32rpx; display:flex; align-items:center; justify-content: space-between; }
.title { font-size: 56rpx; font-weight: 700; color:#000; letter-spacing: -1rpx; }
.edit-btn { padding: 10rpx 20rpx; }
.edit-text{ font-size: 32rpx; color:#007AFF; font-weight: 500; }

.list { padding: 0 32rpx; }
.row { 
  display:flex; 
  align-items:center; 
  background:#fff; 
  border-radius: 24rpx; 
  padding: 32rpx; 
  margin-bottom: 24rpx; 
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
  transition: all 0.2s ease;
}
.row:active { transform: scale(0.98); }

.select-box{ width: 44rpx; height: 44rpx; border-radius: 50%; border:2rpx solid #c7c7cc; display:flex; align-items:center; justify-content:center; flex:0 0 44rpx; margin-right: 24rpx; }
.select-box .dot{ display:none }
.tick{ font-size: 28rpx; color: transparent; line-height: 1; }
.select-box.selected{ border-color:#007AFF; background: #007AFF; border: none; }
.select-box.selected .tick{ color:#fff; }

.cover { width: 140rpx; height: 140rpx; border-radius: 16rpx; object-fit: cover; flex:0 0 140rpx; background: #f0f0f0; }
.info { flex:1; min-width: 0; padding-left: 24rpx; padding-right: 16rpx; display: flex; flex-direction: column; justify-content: space-between; height: 140rpx; box-sizing: border-box; }
.name { font-size: 32rpx; color:#1c1c1e; font-weight: 500; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.price { font-size: 34rpx; color:#FF3B30; font-weight: 600; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }

.row-actions{ display:flex; align-items:center; flex: 0 0 auto; margin-left: auto; }
.row-actions .btn{ 
  width: auto; 
  min-width: 140rpx;
  height: 64rpx;
  line-height: 64rpx;
  border:none; 
  border-radius: 32rpx; /* Capsule shape */
  padding: 0 32rpx; 
  font-size: 28rpx; 
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}
.btn.solid{ background:#000; color:#fff; }

.empty { padding: 200rpx 32rpx; text-align:center; display: flex; flex-direction: column; align-items: center; }
.empty-text { font-size: 30rpx; color:#8E8E93; margin-top: 20rpx; }

.edit-bar{ 
  position: fixed; 
  left:0; 
  right:0; 
  bottom:0; 
  display:flex; 
  gap: 24rpx; 
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom)); 
  background: rgba(255,255,255,0.9); 
  backdrop-filter: blur(20px); 
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
}
.edit-bar .btn{ 
  flex: 1; 
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx; 
  font-size: 32rpx;
  font-weight: 600;
  margin: 0;
}
.btn.primary{ background:#007AFF; color:#fff; box-shadow: 0 4rpx 12rpx rgba(0,122,255,0.3); }
.btn.danger{ background:#FF3B30; color:#fff; box-shadow: 0 4rpx 12rpx rgba(255,59,48,0.3); }


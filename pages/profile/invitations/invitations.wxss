/* 复刻 designer-demands 风格 */
page {
  --primary: #007AFF;
  --background-light: #F5F5F7;
  --surface-light: #FFFFFF;
  --text-primary-light: #1D1D1F;
  --text-secondary-light: #86868B;

  background-color: var(--background-light);
  font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: var(--text-primary-light);
  -webkit-font-smoothing: antialiased;
}

.page-container {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.main-content {
  padding: 0 20px 40px 20px;
  max-width: 448px;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

/* Sticky Header */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 40;
  background-color: var(--background-light);
  padding-top: 12px;
  padding-bottom: 12px;
  margin-left: -20px;
  width: calc(100% + 40px);
}

.category-scroll {
  padding: 0 20px;
  box-sizing: border-box;
}

.category-list {
  display: flex;
  column-gap: 12px;
}

.category-btn {
  background-color: var(--surface-light);
  color: var(--text-primary-light);
  border: 1px solid #E5E7EB;
  padding: 8px 20px;
  border-radius: 9999px;
  font-size: 14px;
  font-weight: 500;
  white-space: nowrap;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.category-btn.active {
  background-color: #000000;
  color: #FFFFFF;
  border-color: transparent;
}

/* Card List */
.demand-list {
  display: flex;
  flex-direction: column;
  row-gap: 20px;
  margin-top: 8px;
}

.card {
  background-color: var(--surface-light);
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  border: 1px solid transparent;
  transition: all 0.2s;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px;
}

.tags-group {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

/* Status Tags */
.tag-blue {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  background-color: #EFF6FF;
  color: #2563EB;
}

.tag-green {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  background-color: #F0FDF4;
  color: #16A34A;
}

.tag-gray {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  background-color: #F3F4F6;
  color: #4B5563;
}

.tag-purple {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  background-color: #FAF5FF;
  color: #9333EA;
}

.time-text {
  font-size: 12px;
  color: var(--text-secondary-light);
}

.card-title {
  font-size: 19px;
  font-weight: 700;
  line-height: 1.25;
  color: var(--text-primary-light);
}

.card-subtitle {
  color: var(--text-secondary-light);
  font-size: 14px;
  margin-top: 4px;
}

/* Designer Avatar */
.designer-avatar-box {
  height: 44px;
  width: 44px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.designer-avatar-box.placeholder {
  border: 1px solid #E5E7EB;
}

.designer-avatar {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 16px;
  font-weight: 600;
  color: #6B7280;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 24px;
}

.stat-box {
  background-color: #F9FAFB;
  border-radius: 12px;
  padding: 12px;
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: var(--text-secondary-light);
  margin-bottom: 4px;
}

.stat-value {
  display: block;
  font-weight: 700;
  color: var(--text-primary-light);
  font-size: 14px;
}

/* Action Buttons */
.action-group {
  display: flex;
  column-gap: 12px;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 12px 0;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.5;
  text-align: center;
  border: none;
  transition: background-color 0.2s;
}

.btn-secondary::after, .btn-primary::after {
  display: none;
}

.btn-secondary {
  color: var(--text-primary-light);
  background-color: #F3F4F6;
}

.btn-secondary-hover {
  background-color: #E5E7EB;
}

.btn-primary {
  color: #FFFFFF;
  background-color: #000000;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

.btn-primary-hover {
  background-color: #111827;
}

.btn-primary[disabled], .btn-secondary[disabled] {
  opacity: 0.5;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary-light);
  margin-bottom: 8px;
}

.empty-sub {
  font-size: 14px;
  color: var(--text-secondary-light);
  margin-bottom: 24px;
}

.empty-btn {
  background-color: #000;
  color: #fff;
  border: none;
  border-radius: 12px;
  padding: 12px 32px;
  font-size: 14px;
  font-weight: 600;
}

.empty-btn::after {
  display: none;
}

/* Loading */
.loading-hint {
  text-align: center;
  padding: 40px 0;
  color: var(--text-secondary-light);
  font-size: 14px;
}

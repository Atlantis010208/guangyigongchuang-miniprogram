<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="onBack">
        <van-icon name="arrow-left" size="20px" color="#111827" />
      </view>
      <view class="nav-title">需求详情</view>
    </view>
  </view>

  <view class="content-scroll">
    <!-- 顶部封面区域 -->
    <view class="hero-section">
      <image class="hero-bg" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAdM-2NSx05XD6Mkrdig7xsN4LBoI3F1kJoSP0C_eJquyxzuenbwn9qRf1ubRqi796B1LIFOYJiijMMjwU7dZZz1vkgOirJUIRYQZ0EZooduh6Uur3w5DG_TM2pk30bko3RCQ-CmqN0z-ZUbD7t5e5zZA2YxPm5Yqv5cvGC5BoyZWiVLSiUJejyVJMUvKAu1nPzdIcQEujFM_Lckspqu1DFLmnSYZYzNmb-tG6duJQb3JOb2_zmGCqGE5KF83CqPJovrbSqh4dVeFs" mode="aspectFill"></image>
      <view class="hero-mask"></view>
      <view class="hero-content">
        <view class="hero-tag">住宅照明</view>
        <view class="hero-title">上海静安区 150㎡ 住宅照明设计</view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="section">
      <view class="section-title">基本信息</view>
      <view class="info-grid">
        <view class="info-card">
          <view class="info-label">空间类型</view>
          <view class="info-value">住宅空间</view>
        </view>
        <view class="info-card">
          <view class="info-label">设计面积</view>
          <view class="info-value">150㎡</view>
          <view class="info-sub">(不足50㎡按50㎡计)</view>
        </view>
        <view class="info-card">
          <view class="info-label">设计预算</view>
          <view class="info-value">¥15/㎡</view>
        </view>
        <view class="info-card">
          <view class="info-label">项目地点</view>
          <view class="info-value text-truncate">上海市 静安区</view>
        </view>
      </view>
    </view>

    <!-- 服务与进度 -->
    <view class="section">
      <view class="section-title">服务与进度</view>
      <view class="service-list">
        <view class="service-item">
          <view class="service-left">
            <image class="service-icon" src="/assets/icons/room_service.png" mode="aspectFit"></image>
            <text class="service-label">服务需求</text>
          </view>
          <view class="service-value">整套灯光设计</view>
        </view>
        <view class="service-item">
          <view class="service-left">
            <image class="service-icon" src="/assets/icons/event_upcoming.png" mode="aspectFit"></image>
            <text class="service-label">项目进度</text>
          </view>
          <view class="service-value">正在设计</view>
        </view>
      </view>
    </view>

    <!-- 合作意愿 -->
    <view class="section no-border">
      <view class="section-title">合作意愿</view>
      <view class="coop-list">
        <view class="coop-item">
          <van-icon name="checked" color="#135bec" size="20px" class="coop-icon" />
          <text class="coop-text">分享预算明细</text>
        </view>
        <view class="coop-item">
          <van-icon name="checked" color="#135bec" size="20px" class="coop-icon" />
          <text class="coop-text">共同创作</text>
        </view>
        <view class="coop-item">
          <van-icon name="checked" color="#135bec" size="20px" class="coop-icon" />
          <text class="coop-text">接受平台流程</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部占位，防止内容被底部操作栏遮挡 -->
  <view class="bottom-spacer"></view>

  <!-- 底部操作栏 -->
  <view class="bottom-action">
    <view class="action-container">
      <view class="action-btn-small" bindtap="onToggleCollect">
        <van-icon name="{{isCollected ? 'like' : 'like-o'}}" color="{{isCollected ? '#ef4444' : '#64748b'}}" size="24px" />
        <text class="action-text">收藏</text>
      </view>
      <view class="action-btn-small" bindtap="onConsult">
        <van-icon name="chat-o" color="#64748b" size="24px" />
        <text class="action-text">咨询</text>
      </view>
      <button class="primary-btn" bindtap="onTakeOrder" hover-class="primary-btn-hover">
        <text>立即抢单</text>
        <van-icon name="arrow" size="14px" />
      </button>
    </view>
  </view>
</view>

    overflow: hidden;
    box-shadow: none;
    margin-top: 40rpx;
  }
  
  .disclaimer-image {
    width: 100%;
    height: 300rpx;
  }
  
  .disclaimer-content {
    padding: 30rpx;
  }
  
  .disclaimer-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #000;

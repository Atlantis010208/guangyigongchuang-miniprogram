}

/* 法律信息 */
.legal {
  padding: 20rpx 30rpx;
  text-align: center;
}

.legal-text {
  font-size: 18rpx;
  color: #c7c7cc;
  display: block;
  margin-bottom: 5rpx;
}

/*抵折优惠*/
.disclaimer-card {
    background-color: white;

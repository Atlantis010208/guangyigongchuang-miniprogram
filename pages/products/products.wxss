/* 产品页面样式 */
.page {
  background-color: #f2f2f7;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.header {
    display: flex;
    align-items: center; /* 垂直居中对齐所有元素 */
    padding: 20rpx 30rpx 50rpx;
  }
  
  /* 标题样式 - 向左对齐 */
  .header-title {
    margin-right: auto; /* 关键：将标题推到左侧 */
    font-size: 56rpx;   /* 调大标题字号 */
    font-weight: bold;  /* 示例加粗效果 */
  }
  
  .user-avatar {
    width: 72rpx;
    height: 72rpx;
    border-radius: 50%;
    overflow: hidden;
    background-color: #e5e5ea;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }
  
  .avatar-img {
    width: 100%;
    height: 100%;
  }
  
  .user-avatar:active {
    transform: scale(0.95);
  }

/* 章节容器 */
.section {
  margin-top: 40rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 550;
  color: #000;
  display: block;
  margin-bottom: 40rpx;
}

.section-title.center {
  text-align: center;
  margin-bottom: 40rpx;
}

/* 主打服务竖向列表 */
.hero-section { padding-left: 0; padding-right: 0; }
.hero-section .section-title { margin-left: 30rpx; margin-bottom: 40rpx; }

.hero-list {
  display: flex;
  flex-direction: column;
  padding: 0 30rpx;
  gap: 30rpx;
}
  
/* 主打产品卡片 */
.hero-card {
    width: 100%;
    height: 1033rpx; /* 固定高度，实现沉浸式背景 */
    background: linear-gradient(135deg, #2c1810 0%, #1a0f08 100%);
    border-radius: 50rpx;
    margin-bottom: 0; /* 由 gap 控制 */
    overflow: hidden;
    box-shadow: none;
    position: relative;
  }
  
  .hero-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  .hero-image {
    position: absolute;
    left: 0; right: 0; top: 0; bottom: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    object-fit: cover;
  }
  
  .hero-text {
    position: absolute;
    left: 0; right: 0; top: 0; bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  
  .hero-logo {
    font-size: 200rpx;
    font-weight: 800;
    color: white;
    text-shadow: 0 0 80rpx rgba(255, 255, 255, 0.8);
    letter-spacing: 20rpx;
    text-align: center;
  }
  
  .hero-info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 40rpx;
    
    /* 高斯模糊与渐变背景，实现隐约可见效果 */
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    background: linear-gradient(to bottom, 
      rgba(0, 0, 0, 0.1) 0%, 
      rgba(0, 0, 0, 0.4) 40%, 
      rgba(0, 0, 0, 0.7) 100%
    );
    
    border-top: 1rpx solid rgba(255, 255, 255, 0.15);
    z-index: 2;
    border-radius: 0 0 50rpx 50rpx; /* 底部圆角保持50rpx */
    box-sizing: border-box;
  }
  
  .hero-title {
    font-size: 44rpx;
    font-weight: 600;
    color: white;
    display: block;
    margin-bottom: 10rpx;
  }
  
  .hero-subtitle {
    font-size: 28rpx;
    color: rgba(255, 255, 255, 0.8);
    display: block;
    margin-bottom: 30rpx;
  }
  
  .price-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .price-text {
    font-size: 24rpx;
    color: rgba(255, 255, 255, 0.7);
    flex: 1;
  }
  
  .buy-button {
    background-color: white;
    border-radius: 50rpx;
    padding: 20rpx 50rpx;
    margin-left: 30rpx;
  }
  
  .buy-text {
    font-size: 28rpx;
    font-weight: 500;
    color: #000;
  }
/* 产品分类卡片 - Apple 风格复刻 */
.product-categories {
  padding: 10rpx 0 40rpx 0; /* 增加上下间距 */
  background-color: #f2f2f7;
  overflow-x: hidden; /* 隐藏外层滚动条 */
}

.categories-scroll {
  white-space: nowrap;
  width: 100%;
}

.category-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center; /* 垂直居中，图片和文字整体居中 */
  margin-right: 24rpx; /* 卡片间距 */
  width: 187rpx;      /* 调整宽度，约等于屏幕宽度的1/3.5 */
  height: 240rpx;     /* 调整高度，略高于宽度 */
  background-color: #ffffff;
  border-radius: 36rpx; /* 大圆角 */
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03); /* 极淡的阴影 */
  vertical-align: top;
  padding: 20rpx; /* 内部内边距 */
  box-sizing: border-box;
  transition: transform 0.2s ease;
}

.category-card:active {
  transform: scale(0.96);
  background-color: #f9f9f9;
}

.category-card:first-child {
  margin-left: 40rpx; /* 左侧留白 */
}

.category-card:last-child {
  margin-right: 40rpx; /* 右侧留白 */
}

/* 图片容器 */
.category-image-container {
  width: 80rpx; /* 图标尺寸 */
  height: 80rpx;
  margin-bottom: 30rpx; /* 图片与文字间距 */
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图片本体 */
.category-image {
  width: 100%;
  height: 100%;
  object-fit: contain; /* 保持比例 */
}

/* 标题文字 */
.category-title {
  font-size: 20rpx;
  color: #1d1d1f; /* Apple 深灰黑色 */
  font-weight: 500; /* 中等字重 */
  text-align: center;
  line-height: 1.3;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 针对特定图标的视觉平衡微调 */
/* 灯光测试图标偏小，进行放大 */
.category-card[data-category="hotel"] .category-image {
  transform: scale(1.1); 
}

/* 照度计算图标可能偏瘦高，稍微放大 */
.category-card[data-category="office"] .category-image {
  transform: scale(1.1);
}

/* 案例展示图标可能偏宽，稍微调整 */
.category-card[data-category="case"] .category-image {
  transform: scale(1.1);
}
  
/* 删除：配件横向滚动样式（模块已移除） */
/* 省钱妙招卡片 */
.savings-card {
  background-color: white;
  border-radius: 50rpx;
  overflow: hidden;
  box-shadow: none;
  margin-top: 40rpx;
}
/* 产品功能样式 */
.feature-row{ display:flex; padding:24rpx; border-bottom:1rpx solid #f2f2f7; align-items:flex-start; }
.feature-row:last-child{ border-bottom:none }
.feature-image{ width:200rpx; height:200rpx; border-radius:30rpx; object-fit:cover; margin-right:24rpx; }
.feature-info{ flex:1; display:flex; flex-direction:column; }
.feature-name{ font-size:32rpx; font-weight:600; color:#000; margin-bottom:8rpx; }
.feature-price{ font-size:30rpx; color:#ff3b30; margin-bottom:8rpx; }
.feature-desc{ font-size:24rpx; color:#8e8e93; line-height:1.5; }
/* 电子商城入口样式 */
.mall-card { background:#fff; border-radius: 50rpx; overflow:hidden; box-shadow:none; }
.mall-image { width:100%; height: 320rpx; object-fit: cover; display:block; }
.mall-content { padding: 26rpx 30rpx 32rpx; }
.mall-title { font-size: 36rpx; font-weight: 700; color:#000; display:block; margin-bottom: 8rpx; }
.mall-subtitle { font-size: 26rpx; color:#8e8e93; }

.savings-image {
  width: 100%;
  height: 300rpx;
}

.savings-content {
  padding: 30rpx;
}

.savings-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  display: block;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.savings-subtitle {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.5;
}

/* 体验光环境模块样式已移除 */

/* 附近的精彩活动样式（复用探索页风格，适配本页） */
.nearby-activities-section { padding-left:0; padding-right:0; }
.nearby-activities-section .section-title,
.nearby-activities-section .section-description { margin-left:30rpx; margin-right:30rpx; }
.nearby-activities { display:flex; align-items:center; gap:15rpx; padding: 40rpx 30rpx 30rpx 30rpx; margin-bottom:30rpx; }
.activities-icon { font-size:32rpx; }
.activities-text { font-size:32rpx; font-weight:500; color:#007AFF; flex:1; }
.activities-arrow { font-size:28rpx; color:#666; }
.activities-scroller { width:100%; margin-top:20rpx; padding:0; box-sizing:border-box; overflow-x:auto; -webkit-overflow-scrolling:touch; border:none; }
.activities-track { display:inline-flex; padding: 0 20rpx 6rpx; }
.activity-card { flex:none; width: 520rpx; background:#fff; border-radius:50rpx; overflow:hidden; box-shadow:none; border:none; }
.activity-card + .activity-card { margin-left:24rpx; }
.activity-image { width:100%; height:500rpx; object-fit:cover; }
.activity-content { padding:30rpx; text-align:center; }
.activity-title { font-size:28rpx; font-weight:600; color:#000; display:block; margin-bottom:15rpx; line-height:1.4; overflow:hidden; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; text-align:center; }
.activity-time { font-size:24rpx; color:#007AFF; text-align:center; }
/* 我的灯光需求助手：复用“表达您的需求”容器布局，避免左右滑动被裁剪 */
.assistant-section { padding-left:0; padding-right:0; }
.assistant-section .section-title { margin-left:30rpx; margin-right:30rpx; }
/* 独立的助手滚动与卡片样式 - 改为胶囊按钮风格 */
.assistant-scroller { width:100%; margin-top:0; padding:0; box-sizing:border-box; overflow-x:auto; -webkit-overflow-scrolling:touch; border:none; }
.assistant-track { display:inline-flex; padding: 0 30rpx 40rpx; gap: 24rpx; }

.service-pill {
  flex: none;
  background-color: #ffffff;
  padding: 30rpx 48rpx;
  border-radius: 999rpx; /* 胶囊圆角 */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-pill-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #000000;
  line-height: 1;
}

/* 删除旧的 assistant-card 相关样式 */

.assistant-section .section-title,
.hero-section .section-title {
  font-size: 40rpx;
  font-weight: 600;
}

/* Apple 官方支持区域样式复刻 */
.apple-support-section {
  background-color: #ffffff;
  padding-top: 50rpx;
  padding-bottom: 50rpx;
  margin-top: 40rpx;
  /* 如果希望是全宽白色背景，可以去掉 margin-left/right padding，
     但这里遵循 section 的 padding: 0 30rpx; 
     如果需要铺满屏幕，可以配合 width:100%; box-sizing:border-box; 
     根据复刻要求，通常是白色卡片或白色区块。这里做成白色圆角卡片视觉更佳 */
  width:100%;
  box-sizing:border-box; 
 
}

/* Apple 内容标签 */
.content-tags {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
  flex-wrap: wrap; /* 防止文字过多溢出 */
}

.content-tag {
  font-size: 26rpx;
  color: #1d1d1f; /* Apple 文字黑 */
  font-weight: 400;
  /* 去除原来的胶囊样式 */
  padding: 0;
  border: none;
  background-color: transparent;
}

.tag-separator {
  margin: 0 16rpx;
  color: rgb(0, 0, 0); /* 浅灰色分隔线 */
  font-size: 24rpx;
  font-weight: 400;
}

/* 二维码区域 */
.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 10rpx;
}

.qr-image-container {
  width: 200rpx;
  height: 200rpx;
  background-color: #fff;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  /* 增加轻微阴影，提升质感 */
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08); 
  border: 10rpx solid #000000; /* 加黑加粗边框 */
}

.qr-code {
  width: 180rpx;
  height: 180rpx;
  display: block;
}

.qr-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 1rpx;
  letter-spacing: -0.5rpx;
}

.qr-subtitle {
  font-size: 24rpx;
  color: #86868b; /* Apple 副标题灰 */
  line-height: 1.5;
  max-width: 560rpx;
  text-align: center;
}


/* 免责声明 */
.disclaimer {
  padding: 30rpx;
  margin-top: 40rpx;
}

.disclaimer-text {
  font-size: 20rpx;
  color: #8e8e93;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.disclaimer-link {
  font-size: 20rpx;

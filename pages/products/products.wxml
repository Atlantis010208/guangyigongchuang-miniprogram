<!--产品页面-->
<scroll-view class="page" scroll-y type="list">
  <!-- 页面头部 -->
  <view class="header">
    <text class="header-title">首页</text>
    <view class="user-avatar" bindtap="onUserTap">
      <image class="avatar-img" src="{{userAvatar || '/images/个人中心.png'}}" mode="aspectFill" binderror="onAvatarError"></image>
    </view>
  </view>

   <!-- 用户角度 · 需求入口（灯光空间分类） -->
   <view class="product-categories">
      <scroll-view class="categories-scroll" scroll-x="true">
        <view class="category-card" bindtap="onCategoryTap" data-category="residential" style="height: auto; min-height: 190rpx;">
          <image class="category-full-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/miniprogram-images/避坑指南.png" mode="widthFix"></image>
          <text class="category-overlay-text">避坑指南</text>
        </view>
        <view class="category-card" bindtap="onCategoryTap" data-category="commercial" style="height: auto; min-height: 190rpx;">
          <image class="category-full-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/miniprogram-images/设计流程.png" mode="widthFix"></image>
          <text class="category-overlay-text">设计流程</text>
        </view>
        <view class="category-card" bindtap="onCategoryTap" data-category="office" style="height: auto; min-height: 190rpx;">
          <image class="category-full-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/miniprogram-images/照度计算.png" mode="widthFix"></image>
          <text class="category-overlay-text">照度计算</text>
        </view>
        <view class="category-card" bindtap="onCategoryTap" data-category="hotel" style="height: auto; min-height: 190rpx;">
          <image class="category-full-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/miniprogram-images/灯光测试.png" mode="widthFix"></image>
          <text class="category-overlay-text">灯光测试</text>
        </view>
        <view class="category-card" bindtap="onCategoryTap" data-category="hotel" style="height: auto; min-height: 190rpx;">
          <image class="category-full-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/miniprogram-images/Gemini_Generated_Image_royravroyravroyr.png" mode="widthFix"></image>
          <text class="category-overlay-text">案例展示</text>
        </view>
      </scroll-view>
   </view>


  <!-- 服务（参考苹果商店“配件”胶囊按钮风格） -->
  <view class="section assistant-section">
    <text class="section-title">服务</text>
    <scroll-view class="assistant-scroller" scroll-x show-scrollbar="false" scroll-with-animation>
      <view class="assistant-track">
        <view class="service-pill" bindtap="onAssistantTap" data-activity="video">
            <text class="service-pill-text">灯光工具包</text>
        </view>
        <view class="service-pill" bindtap="onAssistantTap" data-activity="photo">
            <text class="service-pill-text">设计课程</text>
        </view>
        <view class="service-pill" bindtap="onMallTap">
            <text class="service-pill-text">灯具</text>
        </view>
        <view class="service-pill" bindtap="onServiceTap" data-service="full">
            <text class="service-pill-text">设计服务</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 认识一下新朋友（主打服务竖向展示） -->
  <view class="section hero-section">
    <text class="section-title">发布灯光需求</text>
    <view class="hero-list">
        <view class="hero-card" bindtap="onServiceTap" data-service="selection">
          <view class="hero-content">
            <image class="hero-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/主页/7C4F4BFF-2132-4807-B9BD-1DAC271E2B77.jpg" mode="aspectFill"></image>
          </view>
          <view class="hero-info">
            <text class="hero-title">二哥相关服务</text>
            <text class="hero-subtitle">为你的场景快速完成专业选型与搭配。</text>
            <view class="price-section">
              <text class="price-text">结合预算与风格给出清单</text>
              <view class="buy-button"><text class="buy-text">了解</text></view>
            </view>
          </view>
        </view>
        <!-- 优化灯光施工图(注释)
        <view class="hero-card" bindtap="onServiceTap" data-service="optimize">
          <view class="hero-content">
            <image class="hero-image" src="https://images.pexels.com/photos/834892/pexels-photo-834892.jpeg?auto=compress&cs=tinysrgb&w=800" mode="aspectFill"></image>
          </view>
          <view class="hero-info">
            <text class="hero-title">优化灯光施工图</text>
            <text class="hero-subtitle">校对回路与灯位，优化眩光与照度。</text>
            <view class="price-section">
              <text class="price-text">提升落地质量，减少返工</text>
              <view class="buy-button"><text class="buy-text">了解</text></view>
            </view>
          </view>
        </view>
        -->
        <view class="hero-card" bindtap="onServiceTap" data-service="full">
          <view class="hero-content">
            <image class="hero-image" src="cloud://cloud1-5gb9c5u2c58ad6d7.636c-cloud1-5gb9c5u2c58ad6d7-1378684587/主页/87A1212C-B076-4955-89DF-7CEE7D78C4EB(1).jpg" mode="aspectFill"></image>
          </view>
          <view class="hero-info">
            <text class="hero-title">发布共创设计需求</text>
            <text class="hero-subtitle">从勘测到验收，一站式灯光设计服务。</text>
            <view class="price-section">
              <text class="price-text">全流程沟通与交付</text>
              <view class="buy-button"><text class="buy-text">了解</text></view>
            </view>
          </view>
        </view>
    </view>
  </view>


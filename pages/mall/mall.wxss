/* 商城页面整体布局 */
.mall-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #ffffff;
}

/* ========== 搜索栏 ========== */
.search-container {
  padding: 16rpx 32rpx;
  background: #ffffff;
}
.search-box {
  display: flex;
  align-items: center;
  background: #f4f5f9;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 24rpx;
}
.search-icon {
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.search-placeholder {
  color: #94a3b8;
}

/* ========== 分类标签 ========== */
.tabs-scroll {
  width: 100%;
  border-bottom: 1rpx solid #f1f5f9;
}
.tabs {
  display: flex;
  padding: 0 32rpx;
  gap: 48rpx;
  white-space: nowrap;
}
.tab-item {
  position: relative;
  font-size: 28rpx;
  color: #94a3b8;
  padding: 24rpx 0 16rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}
.tab-item.active {
  color: #0f172a;
  font-weight: 700;
  font-size: 30rpx;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #0f172a;
  border-radius: 2rpx;
}

/* ========== 右侧/主体商品列表 ========== */
.main-content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: calc(32rpx + 120rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}
.product-grid { 
  display: grid; 
  grid-template-columns: 1fr 1fr; 
  gap: 32rpx 24rpx; 
}
.product-card { 
  display: flex;
  flex-direction: column;
}
.product-image-wrap { 
  position: relative; 
  width: 100%; 
  padding-bottom: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f8fafc;
  margin-bottom: 16rpx;
}
.product-image { 
  position: absolute;
  top: 0;
  left: 0;
  width: 100%; 
  height: 100%; 
  display: block; 
}
.image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
}
.placeholder-text {
  font-size: 24rpx;
  color: #94a3b8;
}
.product-info { 
  display: flex;
  flex-direction: column;
}
.product-name { 
  font-size: 30rpx; 
  color: #0f172a; 
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box; 
  -webkit-line-clamp: 2; 
  -webkit-box-orient: vertical; 
  overflow: hidden; 
}
.product-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
  display: -webkit-box; 
  -webkit-line-clamp: 1; 
  -webkit-box-orient: vertical; 
  overflow: hidden; 
}
.product-price-wrap {
  display: flex;
  align-items: baseline;
  color: #0f172a;
}
.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
}
.price-value { 
  font-size: 32rpx; 
  font-weight: 700;
}
.price-suffix {
  font-size: 20rpx;
  color: #94a3b8;
  margin-left: 4rpx;
  font-weight: 400;
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f1f5f9;
  border-top: 6rpx solid #0f172a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding-top: 200rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
}

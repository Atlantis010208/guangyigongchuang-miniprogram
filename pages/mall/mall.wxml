<view class="mall-page">
  <!-- Search Bar -->
  <view class="search-container">
    <view class="search-box">
      <icon class="search-icon" type="search" size="18" color="#94a3b8"></icon>
      <input class="search-input" placeholder="搜索商品..." placeholder-class="search-placeholder" bindconfirm="onSearch" confirm-type="search" value="{{keyword}}" />
    </view>
  </view>

  <!-- Categories Tabs -->
  <scroll-view class="tabs-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}" enhanced="{{true}}" bounces="{{true}}">
    <view class="tabs">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="tab-item {{category === item ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item}}"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- Main Product Grid -->
  <view class="main-content">
    <!-- Loading State -->
    <view class="loading-state" wx:if="{{loading && products.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载商品...</text>
    </view>

    <!-- Empty State -->
    <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
      <text class="empty-title">暂无商品</text>
      <text class="empty-desc">商品即将上架，敬请期待</text>
    </view>

    <view class="product-grid" wx:if="{{products.length > 0}}">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="product-image-wrap">
          <image class="product-image" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}" binderror="onImageError" data-index="{{index}}"></image>
          <view class="image-placeholder" wx:if="{{!item.image}}">
            <text class="placeholder-text">暂无图片</text>
          </view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.shortDesc || '专业团队 · 一对一服务'}}</text>
          <view class="product-price-wrap">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
            <text class="price-suffix" wx:if="{{item.type === 'service' || item.price > 1000}}">起</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

page {
  background-color: #F4F5F7; /* 统一浅灰背景色 */
  min-height: 100vh;
  display: block; /* 显式设置为 block，防止继承 flex */
  box-sizing: border-box;
}

/* 使用唯一的容器类名，避开全局 container 样式 */
.toolbox-root {
  padding: 30rpx 40rpx 160rpx; /* 两侧边距 20rpx */
  display: block; /* 块级布局，确保子元素自然撑满 */
  width: 100%;
  box-sizing: border-box;
}

/* Header */
.header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
  width: 100%; /* 显式宽度 */
  box-sizing: border-box;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1A1C;
  letter-spacing: -1rpx;
  text-align: left; /* 确保标题左对齐 */
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #8E8E93;
  margin-top: 10rpx;
  font-weight: 500;
  text-align: left; /* 确保副标题左对齐 */
}

/* Bento Grid Layout */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: 300rpx;
  gap: 30rpx; /* 进一步减小 gap */
  width: 100%; /* 显式宽度 */
  box-sizing: border-box;
}

/* Base Card */
.bento-card {
  background: #FFFFFF;
  border-radius: 56rpx; /* 增大卡片圆角以匹配图二 */
  padding: 36rpx 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02); 
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: auto; /* 自动填充网格区域 */
  height: 100%; /* 撑满网格高度 */
}

.hover-scale {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hover-scale:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.col-span-2 {
  grid-column: span 2;
}

.row-span-2 {
  grid-row: span 2;
}

/* Icon Wrap */
.icon-wrap {
  width: 112rpx; /* 微调放大一点 */
  height: 112rpx;
  border-radius: 40rpx; /* 图二看起来是有点圆角矩形，或者更饱满的圆形，调整圆角适配加大后的尺寸 */
  background: #F4F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #EBECEF; /* 图二有微微的边框感 */
}

/* 如果图二是纯圆，则使用 50% */
.icon-wrap {
  border-radius: 50%; /* 图二图标背景确实是一个正圆，因此强制为 50% */
}

.icon {
  width: 48rpx;
  height: 48rpx;
}

.icon-small {
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
}

.card-title {
  font-size: 34rpx; /* 增大标题字号 */
  font-weight: 700; /* 图二字体更粗 */
  color: #1A1A1C;
  letter-spacing: -0.5rpx;
}

/* Color Temperature Card with Background Image */
.ct-card {
  padding: 0;
}

.ct-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.ct-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,0.35)); /* 顶部完全透明，底部微黑保证文字可读 */
  z-index: 2;
}

.ct-content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  padding: 36rpx;
  box-sizing: border-box;
}

.icon-wrap-light {
  background: transparent !important; /* 完全去除白色叠加 */
  backdrop-filter: blur(4px) !important; /* 仅保留极弱模糊，确保色彩和纹理透出 */
  -webkit-backdrop-filter: blur(4px) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.3) !important; /* 边框稍微提亮一点点勾勒轮廓 */
  box-shadow: none !important;
}

.icon-wrap-light .icon {
  filter: brightness(0) invert(1);
}

.card-title-light {
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* Color Temperature Card Specifics */
.flex-col-between {
  justify-content: space-between;
}

.ct-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx; /* 增加色温条与头部的间距 */
}

.ct-title-wrap {
  display: flex;
  align-items: center;
}

.ct-range {
  font-size: 26rpx;
  color: #8E8E93;
  font-weight: 600; /* 修改字体粗细 */
  letter-spacing: 1rpx;
}

.ct-gradient {
  position: relative;
  height: 120rpx; /* 增加渐变条高度 */
  width: 100%;
  border-radius: 48rpx; /* 增大渐变条圆角 */
  /* 调整渐变颜色与图二对应：左侧橙黄，中间偏白带点黄，右侧浅蓝 */
  background: linear-gradient(to right, #FFA726, #FFF4E0, #D6EAF8); 
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.ct-ticks {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 60rpx; /* 调整刻度间距 */
  opacity: 0.15;
}

.ct-tick {
  width: 4rpx;
  height: 24rpx; /* 减小刻度线的高度，图二的刻度线比较小 */
  background: #000;
  border-radius: 4rpx;
}

/* Gallery Card Specifics */
.gallery-card {
  padding: 0; /* Override default padding */
}

.gallery-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.gallery-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.05), rgba(0,0,0,0.6));
  z-index: 2;
}

.gallery-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 36rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  z-index: 3;
}

.gallery-text-wrap {
  display: flex;
  flex-direction: column;
}

.gallery-title {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: -1rpx;
  margin-bottom: 6rpx;
}

.gallery-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.gallery-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-camera {
  width: 40rpx;
  height: 40rpx;
}

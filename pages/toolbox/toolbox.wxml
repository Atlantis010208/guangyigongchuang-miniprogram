<view class="toolbox-root">
  <view class="header">
    <text class="title">工具箱</text>
    <text class="subtitle">照明设计专业工具</text>
  </view>

  <view class="bento-grid">
    <!-- Small Square 1: 照度计算器 -->
    <view class="bento-card hover-scale" bindtap="navigateToSearch">
      <view class="icon-wrap">
        <image class="icon" src="/images/toolbox/calculator.svg" mode="aspectFit"></image>
      </view>
      <text class="card-title">照度计算器</text>
    </view>

    <!-- Small Square 2: 功率换算 -->
    <view class="bento-card hover-scale" bindtap="navigateToComingSoon">
      <view class="icon-wrap">
        <image class="icon" src="/images/toolbox/zap.svg" mode="aspectFit"></image>
      </view>
      <text class="card-title">功率换算</text>
    </view>

    <!-- Horizontal Rectangle: 色温调节带 -->
    <view class="bento-card col-span-2 flex-col-between hover-scale" bindtap="navigateToComingSoon">
      <view class="ct-header">
        <view class="ct-title-wrap">
          <image class="icon-small" src="/images/toolbox/sliders-horizontal.svg" mode="aspectFit"></image>
          <text class="card-title">色温调节带</text>
        </view>
        <text class="ct-range">2700K - 6500K</text>
      </view>
      <view class="ct-gradient">
        <view class="ct-ticks">
          <view class="ct-tick"></view>
          <view class="ct-tick"></view>
          <view class="ct-tick"></view>
        </view>
      </view>
    </view>

    <!-- Large Square: 实景灯光图库 -->
    <view class="bento-card col-span-2 row-span-2 gallery-card hover-scale" bindtap="navigateToGallery">
      <image class="gallery-bg" src="https://picsum.photos/seed/luxuryinterior/800/800" mode="aspectFill"></image>
      <view class="gallery-overlay"></view>
      <view class="gallery-content">
        <view class="gallery-text-wrap">
          <text class="gallery-title">实景灯光图库</text>
          <text class="gallery-desc">探索高端照明设计灵感</text>
        </view>
        <view class="gallery-icon-wrap">
          <image class="icon-camera" src="/images/toolbox/camera.svg" mode="aspectFit"></image>
        </view>
      </view>
    </view>

  </view>
</view>

/* pages/color-temp/color-temp.wxss */
@import "../search/search.wxss";

.color-temp-page {
  padding-bottom: 60rpx;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #fff;
}

.custom-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16rpx;
}

.nav-back {
  width: 80rpx;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.nav-placeholder {
  width: 80rpx;
}

/* ==================== 结果页样式 ==================== */
.result-container {
  padding-top: 20rpx;
}

/* AI 标识 */
.ai-badge {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.ai-badge-text {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  letter-spacing: 2rpx;
}

/* AI 推荐理由 */
.ai-reasoning {
  padding: 30rpx;
}

.reasoning-text {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.7;
}

.result-hero {
  padding: 50rpx 40rpx;
}

.result-hero-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.temp-val {
  font-size: 88rpx;
  font-weight: 600;
  color: #1E3A5F;
  line-height: 1;
}

.temp-unit {
  font-size: 36rpx;
  font-weight: 500;
  color: #606266;
  margin-left: 8rpx;
}

.temp-tag {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #1E3A5F;
  background: rgba(30, 58, 95, 0.05);
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

/* 色温条 */
.color-scale {
  width: 100%;
}

.scale-bar {
  width: 100%;
  height: 16rpx;
  border-radius: 8rpx;
  background: linear-gradient(to right, #FF8C00, #FFE4B5, #FFFFFF, #E0FFFF, #87CEEB);
  position: relative;
  margin-bottom: 16rpx;
}

.scale-marker {
  position: absolute;
  top: -12rpx;
  width: 4rpx;
  height: 40rpx;
  background: #303133;
  border-radius: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  transition: left 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.scale-marker::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: -8rpx;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #303133;
}

.scale-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #909399;
}

/* 分层建议列表 */
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F2F6FC;
}

.advice-list {
  display: flex;
  flex-direction: column;
}

.advice-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F2F6FC;
}

.advice-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.advice-content {
  flex: 1;
}

.advice-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.advice-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #303133;
}

.advice-temp {
  font-size: 32rpx;
  font-weight: 600;
}

.advice-label {
  font-size: 22rpx;
  color: #909399;
  margin-bottom: 6rpx;
}

.advice-desc {
  font-size: 24rpx;
  color: #606266;
  line-height: 1.4;
}

/* 专业提示 */
.expert-tips {
  background: #FFF8E6;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: none;
  box-shadow: none;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E6A23C;
  margin-bottom: 20rpx;
}

.tip-line {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #606266;
  line-height: 1.5;
}

.tip-line:last-child {
  margin-bottom: 0;
}

.dot {
  color: #E6A23C;
  margin-right: 12rpx;
  font-weight: bold;
}

.v2-picker-arrow {
  font-size: 20rpx;
  color: #C0C4CC;
  margin-left: 8rpx;
}

/* 色温建议提示 */
.v2-input-hint {
  padding: 4rpx 32rpx 16rpx;
  margin-top: -8rpx;
}

.v2-hint-text {
  font-size: 22rpx;
  color: #909399;
}
